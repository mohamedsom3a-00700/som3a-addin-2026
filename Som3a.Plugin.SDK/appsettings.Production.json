{
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Som3a.Plugin.SDK": "Error"
    },
    "MaxLogSizeMB": 100
  },
  "Plugins": {
    "EnableIsolation": true,
    "MaxPluginMemoryMB": 512,
    "PluginTimeoutSeconds": 30,
    "GracefulShutdownTimeoutSeconds": 5,
    "MaxConcurrentPlugins": 10
  }
}
