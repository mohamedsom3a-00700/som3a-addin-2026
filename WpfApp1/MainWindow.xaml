<Window x:Class="Som3a_WPF_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Som3a_WPF_UI"
        mc:Ignorable="d"
        Title="Comparison P6 Activity" Height="672" Width="591" ResizeMode="NoResize">
    <Grid Margin="0,0,10,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <GroupBox HorizontalAlignment="Left" Height="285" Header="GroupBox" Margin="10,10,0,0" VerticalAlignment="Top" Width="567">
            <Grid HorizontalAlignment="Left" Height="260" Margin="10,0,0,0" VerticalAlignment="Top" Width="547">
                <Label Content="Last Update Sheet" HorizontalAlignment="Left" Height="30" Margin="10,10,0,0" VerticalAlignment="Top" Width="213"/>
                <Label Content="New Update Sheet" HorizontalAlignment="Left" Height="30" Margin="10,56,0,0" VerticalAlignment="Top" Width="213"/>
                <Label Content="Activity ID Coulmn" HorizontalAlignment="Left" Height="30" Margin="10,100,0,0" VerticalAlignment="Top" Width="213"/>
                <ComboBox x:Name="cmbOldSheet" HorizontalAlignment="Left" Height="30" Margin="247,10,0,0" VerticalAlignment="Top" Width="290"/>
                <ComboBox x:Name="cmbNewSheet" HorizontalAlignment="Left" Height="30" Margin="247,56,0,0" VerticalAlignment="Top" Width="290"/>
                <Label Content="Activity % Coulmn" HorizontalAlignment="Left" Height="30" Margin="10,140,0,0" VerticalAlignment="Top" Width="213"/>
                <Label Content="WBS New P6 Coulmn" HorizontalAlignment="Left" Height="30" Margin="10,180,0,0" VerticalAlignment="Top" Width="213"/>
                <Label Content="Top Headers Row" HorizontalAlignment="Left" Height="30" Margin="10,220,0,0" VerticalAlignment="Top" Width="213"/>
                <TextBox x:Name="txtCompareCol" HorizontalAlignment="Left" Height="30" Margin="247,140,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="290"/>
                <TextBox x:Name="txtCopyCol" HorizontalAlignment="Left" Height="30" Margin="247,180,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="290"/>
                <TextBox x:Name="txtStartRow" HorizontalAlignment="Left" Height="29" Margin="247,220,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="290"/>
                <TextBox x:Name="txtIDCol" HorizontalAlignment="Left" Height="30" Margin="247,100,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="290"/>
            </Grid>
        </GroupBox>
        <ListView x:Name="ListView1" HorizontalAlignment="Left" Height="237" Margin="10,300,0,0" VerticalAlignment="Top" Width="567" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.View>
                <GridView>
                    <GridViewColumn/>
                </GridView>
            </ListView.View>
        </ListView>
        <ProgressBar x:Name="ProgressBar1" HorizontalAlignment="Left" Height="33" Margin="10,542,0,0" VerticalAlignment="Top" Width="506"/>
        <Label x:Name="lblProgress" Content="0%" HorizontalAlignment="Left" Height="33" Margin="521,542,0,0" VerticalAlignment="Top" Width="56"/>
        <Button x:Name="btnPreview" Content="Preview" HorizontalAlignment="Left" Height="34" Margin="10,588,0,0" VerticalAlignment="Top" Width="101"/>
        <Button x:Name="btnExport" Content="Export Log" HorizontalAlignment="Left" Height="34" Margin="116,588,0,0" VerticalAlignment="Top" Width="101"/>
        <Button x:Name="btnStart" Content="Update" HorizontalAlignment="Left" Height="34" Margin="223,588,0,0" VerticalAlignment="Top" Width="101"/>
        <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left" Height="34" Margin="329,588,0,0" VerticalAlignment="Top" Width="101"/>
        <StatusBar x:Name="StatusBar1" HorizontalAlignment="Center" Height="19" Margin="0,627,0,0" VerticalAlignment="Top" Width="561"/>

    </Grid>
</Window>
