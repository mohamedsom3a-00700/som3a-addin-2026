<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package
        Name="Som3a Planova"
        Manufacturer="Som3a"
        Version="$(var.Version)"
        UpgradeCode="YOUR-UPGRADEGUID-HERE-0000-0000-000000000000"
        Scope="perUser">

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

        <!-- ProductCode auto-generated per version -->
        <ProductCode>*</ProductCode>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="LocalAppDataFolder">
                <Directory Id="INSTALLFOLDER" Name="Som3a\Planova">
                    <!-- Application binaries will be installed here -->
                </Directory>
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="Som3a Planova">
                    <Component Id="StartMenuShortcut" Guid="YOUR-GUID-HERE-0001-0000-000000000000">
                        <Shortcut
                            Id="ApplicationStartMenuShortcut"
                            Name="Som3a Planova"
                            Description="Som3a Planova Excel Add-in"
                            Target="[INSTALLFOLDER]Som3a_WPF_UI.vsto"
                            WorkingDirectory="INSTALLFOLDER"/>
                        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall"/>
                        <RegistryValue Root="HKCU" Key="Software\Som3a\Planova" Name="Installed" Type="integer" Value="1"/>
                    </Component>
                </Directory>
            </Directory>
            <Directory Id="DesktopFolder">
                <Component Id="DesktopShortcut" Guid="YOUR-GUID-HERE-0002-0000-000000000000">
                    <Shortcut
                        Id="ApplicationDesktopShortcut"
                        Name="Som3a Planova"
                        Description="Som3a Planova Excel Add-in"
                        Target="[INSTALLFOLDER]Som3a_WPF_UI.vsto"
                        WorkingDirectory="INSTALLFOLDER"/>
                    <RegistryValue Root="HKCU" Key="Software\Som3a\Planova" Name="DesktopInstalled" Type="integer" Value="1"/>
                </Component>
            </Directory>
        </Directory>

        <!-- VSTO Registry Keys -->
        <Component Id="VSTORegistry" Guid="YOUR-GUID-HERE-0003-0000-000000000000" Directory="INSTALLFOLDER">
          <RegistryValue Root="HKCU"
                         Key="Software\Microsoft\Office\Excel\Addins\Som3aPlanova"
                         Name="Description"
                         Value="Som3a Planova - AI-powered project planning for Excel"
                         Type="string"/>
          <RegistryValue Root="HKCU"
                         Key="Software\Microsoft\Office\Excel\Addins\Som3aPlanova"
                         Name="FriendlyName"
                         Value="Som3a Planova"
                         Type="string"/>
          <RegistryValue Root="HKCU"
                         Key="Software\Microsoft\Office\Excel\Addins\Som3aPlanova"
                         Name="LoadBehavior"
                         Value="3"
                         Type="integer"/>
          <RegistryValue Root="HKCU"
                         Key="Software\Microsoft\Office\Excel\Addins\Som3aPlanova"
                         Name="Manifest"
                         Value="file:///[INSTALLFOLDER]Som3a_WPF_UI.vsto|vstolocal"
                         Type="string"/>
        </Component>

        <Feature Id="ProductFeature" Title="Som3a Planova" Level="1">
            <ComponentRef Id="StartMenuShortcut"/>
            <ComponentRef Id="DesktopShortcut"/>
            <ComponentRef Id="VSTORegistry"/>
        </Feature>
    </Package>
</Wix>
