<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls">

    <Style TargetType="{x:Type controls:ModernWindow}">

        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>

        <Setter Property="WindowStyle"
                Value="SingleBorderWindow"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ModernWindow}">

                    <AdornerDecorator>

                        <Grid>

                            <Border x:Name="WindowBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{DynamicResource ControlStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource WindowRadius}"
                    Effect="{DynamicResource Shadow.Window}">

                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="{TemplateBinding TitleBarHeight}"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Title Bar -->
                                    <Border x:Name="TitleBar"
                            Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="{DynamicResource HeaderCornerRadius}"
                            Padding="12,0">

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <ContentControl Grid.Column="0"
                                            Content="{TemplateBinding TitleIcon}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0"
                                            Width="20"
                                            Height="20"/>

                                            <!-- Title -->
                                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding Title}"
                                       Foreground="{DynamicResource TextMainBrush}"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource SubHeaderFontSize}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="4,0"/>

                                            <!-- Window Buttons -->
                                            <StackPanel x:Name="WindowButtons"
                                        Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                                <!-- Minimize -->
                                                <Button x:Name="MinimizeBtn"
                                        Command="{Binding MinimizeCommand}"
                                        Style="{DynamicResource TitleBarButton}"
                                        Width="36"
                                        Height="32"
                                        Visibility="{Binding ShowMinimizeButton,
                                                             RelativeSource={RelativeSource TemplatedParent},
                                                             Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Minimize">

                                                    <Path Data="M 6 0 L 6 1 L 18 1 L 18 0 L 6 0 Z"
                                          Fill="{DynamicResource TextSubBrush}"
                                          Width="12"
                                          Height="8"
                                          Stretch="Uniform"/>

                                                </Button>

                                                <!-- Maximize -->
                                                <Button x:Name="MaximizeBtn"
                                        Command="{Binding MaximizeCommand}"
                                        Style="{DynamicResource TitleBarButton}"
                                        Width="36"
                                        Height="32"
                                        Visibility="{Binding ShowMaximizeButton,
                                                             RelativeSource={RelativeSource TemplatedParent},
                                                             Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Maximize">

                                                    <Grid>

                                                        <Path x:Name="MaximizeIcon"
                                              Data="M 0 0 L 12 0 L 12 12 L 0 12 Z"
                                              Stroke="{DynamicResource TextSubBrush}"
                                              StrokeThickness="1.2"
                                              Width="12"
                                              Height="12"
                                              Stretch="Uniform"
                                              Visibility="Visible"/>

                                                        <Path x:Name="RestoreIcon"
                                              Data="M 2 0 L 10 0 L 10 8 L 8 8 L 8 2 L 2 2 Z M 0 3 L 0 10 L 7 10 L 7 8 L 2 8 L 2 3 Z"
                                              Stroke="{DynamicResource TextSubBrush}"
                                              StrokeThickness="1.2"
                                              Width="12"
                                              Height="12"
                                              Stretch="Uniform"
                                              Visibility="Collapsed"/>

                                                    </Grid>

                                                </Button>

                                                <!-- Close -->
                                                <Button x:Name="CloseBtn"
                                        Command="{Binding CloseCommand}"
                                        Style="{DynamicResource CloseButton}"
                                        Width="46"
                                        Height="32"
                                        Visibility="{Binding ShowCloseButton,
                                                             RelativeSource={RelativeSource TemplatedParent},
                                                             Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Close"/>

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                    <!-- Content -->
                                    <ContentPresenter Grid.Row="1"
                                      Margin="0"/>

                                </Grid>

                            </Border>

                        </Grid>

                    </AdornerDecorator>

                    <ControlTemplate.Triggers>

                        <Trigger Property="WindowState"
                 Value="Maximized">

                            <Setter TargetName="WindowBorder"
                    Property="CornerRadius"
                    Value="0"/>

                            <Setter TargetName="TitleBar"
                    Property="CornerRadius"
                    Value="0"/>

                            <Setter TargetName="MaximizeIcon"
                    Property="Visibility"
                    Value="Collapsed"/>

                            <Setter TargetName="RestoreIcon"
                    Property="Visibility"
                    Value="Visible"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>