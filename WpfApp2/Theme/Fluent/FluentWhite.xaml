<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#EFEFEF"/>
    <SolidColorBrush x:Key="TextMainBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="TextSubBrush" Color="#555566"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#E0E0E0"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#28A745"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC3545"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#17A2B8"/>

</ResourceDictionary>