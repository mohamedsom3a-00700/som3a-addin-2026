<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         DARK THEME SEMANTIC TOKEN OVERRIDES
         ============================================ -->

    <!-- Background -->
    <SolidColorBrush x:Key="Brush.Background.Primary" Color="#0E1720"/>
    <SolidColorBrush x:Key="Brush.Background.Secondary" Color="#1C2B3A"/>
    <SolidColorBrush x:Key="Brush.Background.Card" Color="#15202B"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#BFFFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="#66FFFFFF"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="#3A86FF"/>
    <SolidColorBrush x:Key="Brush.Accent.Success" Color="#2ED573"/>
    <SolidColorBrush x:Key="Brush.Accent.Warning" Color="#FFA502"/>
    <SolidColorBrush x:Key="Brush.Accent.Danger" Color="#FF4757"/>
    <SolidColorBrush x:Key="Brush.Accent.Info" Color="#1E90FF"/>

    <!-- Stroke -->
    <SolidColorBrush x:Key="Brush.Stroke.Card" Color="#33FFFFFF"/>

    <!-- Control -->
    <SolidColorBrush x:Key="Brush.Control.Background" Color="#330E1720"/>
    <SolidColorBrush x:Key="Brush.Control.Stroke" Color="#33FFFFFF"/>

    <!-- ============================================
         LEGACY FLAT KEYS (Dark theme)
         ============================================ -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3A86FF"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0E1720"/>
    <SolidColorBrush x:Key="CardBrush" Color="#15202B"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1C2B3A"/>
    <SolidColorBrush x:Key="TextMainBrush" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="TextSubBrush" Color="#BFFFFFFF"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#2ED573"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFA502"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF4757"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#1E90FF"/>
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="#330E1720"/>
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#33FFFFFF"/>

</ResourceDictionary>