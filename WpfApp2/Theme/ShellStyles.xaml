<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:Som3a_WPF_UI.Controls.Shell">

    <!-- Sidebar Item Style -->
    <Style x:Key="Style.Sidebar.Item" TargetType="ListBoxItem">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.ListView.HoverBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar ListBox Style -->
    <Style x:Key="Style.Sidebar.ListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Workspace Area Style -->
    <Style x:Key="Style.Workspace.Host" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Status Bar Style -->
    <Style x:Key="Style.StatusBar" TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Card}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Command Palette Overlay Style -->
    <Style x:Key="Style.CommandPalette.Overlay" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Overlay.Background}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Command Palette Input Style -->
    <Style x:Key="Style.CommandPalette.Input" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Stroke.Card}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Command Palette Result Item Style -->
    <Style x:Key="Style.CommandPalette.ResultItem" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.ListView.HoverBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Welcome Page Style -->
    <Style x:Key="Style.WelcomePage.Container" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
    </Style>

    <Style x:Key="Style.WelcomePage.Title" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="Style.WelcomePage.Description" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- WorkspaceHost Default Template -->
    <Style TargetType="shell:WorkspaceHost">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="shell:WorkspaceHost">
                    <Grid>
                        <Frame x:Name="PART_Frame"
                               Background="{DynamicResource Brush.Background.Primary}"
                               NavigationUIVisibility="Hidden"
                               JournalOwnership="OwnsJournal"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                        <Border x:Name="PART_ErrorOverlay"
                                Visibility="Collapsed"
                                Background="{DynamicResource Brush.Background.Primary}">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="PART_ErrorMessage"
                                           Foreground="{DynamicResource Brush.Accent.Danger}"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <Button x:Name="PART_RetryButton"
                                        Content="Retry"
                                        Style="{DynamicResource PrimaryButton}"
                                        HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
