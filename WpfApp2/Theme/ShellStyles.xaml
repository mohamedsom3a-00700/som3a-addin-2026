<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:Som3a_WPF_UI.Controls.Shell"
     >

    <!-- Sidebar Collapse Toggle Button Style -->
    <Style x:Key="Style.ToggleButton.SidebarCollapse" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.ListView.HoverBackground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar Category Header Style (Expander-based) -->
    <Style x:Key="Style.Sidebar.CategoryHeader" TargetType="GroupItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupItem">
                    <Expander IsExpanded="True"
                              Header="{Binding Name}"
                              Style="{DynamicResource Style.Sidebar.CategoryExpander}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                        <ItemsPresenter SnapsToDevicePixels="True"
                                        UseLayoutRounding="True"/>
                    </Expander>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar Category Expander Style -->
    <Style x:Key="Style.Sidebar.CategoryExpander" TargetType="Expander">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton Grid.Column="0"
                                              x:Name="HeaderToggle"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              Content="▶"
                                              Foreground="{DynamicResource Brush.Text.Secondary}"
                                              FontSize="10"
                                              Width="16"
                                              Height="16"
                                              Margin="0,0,4,0"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="True"
                                              UseLayoutRounding="True"/>
                                <TextBlock x:Name="CategoryIcon"
                                           Grid.Column="1"
                                           Text="●"
                                           Width="16" Height="16"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           FontSize="10"/>
                                <TextBlock Grid.Column="2"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ContentPresenter Grid.Row="1"
                                          x:Name="ContentSite"
                                          Visibility="Collapsed"
                                          SnapsToDevicePixels="True"
                                          UseLayoutRounding="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="HeaderToggle" Property="IsChecked" Value="True">
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="HeaderToggle" Property="Content" Value="▼"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" Value="Planning">
                            <Setter TargetName="CategoryIcon" Property="Text" Value="●"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" Value="Analysis">
                            <Setter TargetName="CategoryIcon" Property="Text" Value="●"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" Value="Excel">
                            <Setter TargetName="CategoryIcon" Property="Text" Value="●"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" Value="AI">
                            <Setter TargetName="CategoryIcon" Property="Text" Value="●"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" Value="Settings">
                            <Setter TargetName="CategoryIcon" Property="Text" Value="●"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" Value="Other">
                            <Setter TargetName="CategoryIcon" Property="Text" Value="●"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar Item Style -->
    <Style x:Key="Style.Sidebar.Item" TargetType="ListBoxItem">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.ListView.HoverBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar ListBox Style -->
    <Style x:Key="Style.Sidebar.ListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary.Translucent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Workspace Area Style -->
    <Style x:Key="Style.Workspace.Host" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary.Translucent}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Status Bar Style -->
    <Style x:Key="Style.StatusBar" TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Card}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Command Palette Overlay Style -->
    <Style x:Key="Style.CommandPalette.Overlay" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Overlay.Background}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Command Palette Input Style -->
    <Style x:Key="Style.CommandPalette.Input" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Stroke.Card}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Command Palette Result Item Style -->
    <Style x:Key="Style.CommandPalette.ResultItem" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.ListView.HoverBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Skip Link Style -->
    <Style x:Key="Style.SkipLink" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Height" Value="0"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="IsTabStop" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="Height" Value="Auto"/>
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="IsTabStop" Value="True"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Welcome Page Style -->
    <Style x:Key="Style.WelcomePage.Container" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary.Translucent}"/>
    </Style>

    <Style x:Key="Style.WelcomePage.Title" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="Style.WelcomePage.Description" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Blueprint overlay drawing brush -->
    <DrawingBrush x:Key="Brush.Blueprint.Overlay" Stretch="None"
                  TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute"
                  Opacity="0.04">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Geometry="M0,0 L40,0 M0,0 L0,40">
                    <GeometryDrawing.Pen>
                        <Pen Thickness="0.5" Brush="#2D9CFF"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- WorkspaceHost Default Template -->
    <Style TargetType="shell:WorkspaceHost">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="shell:WorkspaceHost">
                    <Grid>
                        <Frame x:Name="PART_Frame"
                               Background="{DynamicResource Brush.Background.Primary}"
                               NavigationUIVisibility="Hidden"
                               JournalOwnership="OwnsJournal"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                        <Rectangle x:Name="PART_BlueprintOverlay"
                                   Fill="{DynamicResource Brush.Blueprint.Overlay}"
                                   IsHitTestVisible="False"
                                   Visibility="Visible"/>
                        <ProgressBar x:Name="PART_LoadingIndicator"
                                      IsIndeterminate="True"
                                      Visibility="Collapsed"
                                      Height="3"
                                      VerticalAlignment="Top"
                                      Foreground="{DynamicResource Brush.Accent.Primary}"
                                      Background="{DynamicResource Brush.Background.Card}"
                                      SnapsToDevicePixels="True"
                                      UseLayoutRounding="True"/>
                        <Border x:Name="PART_ErrorOverlay"
                                Visibility="Collapsed"
                                Background="{DynamicResource Brush.Background.Primary}">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="PART_ErrorMessage"
                                           Foreground="{DynamicResource Brush.Accent.Danger}"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <Button x:Name="PART_RetryButton"
                                        Content="Retry"
                                        Style="{DynamicResource PrimaryButton}"
                                        HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
