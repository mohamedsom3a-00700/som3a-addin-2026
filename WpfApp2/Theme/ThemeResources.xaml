<!--
    ThemeResources.xaml — Aggregator ResourceDictionary
    ====================================================
    Resource loading order (per constitution):
    1. Primitive Tokens       → Base/Colors.xaml
    2. Semantic Tokens       → Base/Colors.xaml (continued)
    3. Typography            → Base/Typography.xaml
    4. Radius                → Base/Radius.xaml
    5. Effects               → Effects/Shadows + Glow + Animations
    6. Controls              → All control styles
    7. Theme Overrides       → Applied at runtime via ThemeManager
    8. Window Styles         → ModernWindow + WindowButtonStyles

    Theme switching: ThemeManager replaces merged theme dictionaries
    at runtime (Dark/Light/Custom) while this aggregator stays loaded.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Som3a_WPF_UI.Converters">

    <ResourceDictionary.MergedDictionaries>

        <!-- Base -->
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Base/Colors.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Base/Typography.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Base/Spacing.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Base/Radius.xaml"/>

        <!-- Effects Library -->
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Effects/Shadows.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Effects/Glow.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Effects/Animations.xaml"/>

        <!-- Controls -->
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ButtonStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/AccentSwatchStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ThemeCardStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/TextBoxStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ComboBoxStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/DataGridStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ListViewStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ScrollBarStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/CheckBoxStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/RadioButtonStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ToggleButtonStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ScrollViewerStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/WindowStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/GroupBoxStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/LabelStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ListViewItemStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ComboBoxItemStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ProgressBarStyles.xaml"/>

        <!-- Modern Window -->
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/WindowButtonStyles.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ModernWindow.xaml"/>
        <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/WindowAnimations.xaml"/>

    </ResourceDictionary.MergedDictionaries>

    <!-- Converters -->
    <conv:ProgressWidthConverter x:Key="ProgressWidthConverter"/>
    <conv:PercentToScaleConverter x:Key="PercentToScaleConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    <conv:WindowStateConverter x:Key="WindowStateConverter"/>
    <conv:WindowStateToBoolConverter x:Key="WindowStateToBoolConverter"/>
    <conv:InverseWindowStateConverter x:Key="InverseWindowStateConverter"/>

</ResourceDictionary>