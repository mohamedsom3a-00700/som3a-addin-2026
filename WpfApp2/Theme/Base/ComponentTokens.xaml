<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================
         COMPONENT TOKENS
         Component-specific styling values.
         These mirror semantic/utility tokens for
         component-level theming. Values MUST match
         the corresponding tokens in Spacing.xaml,
         Radius.xaml, and Size tokens above.
         ============================================ -->

    <!-- Button -->
    <Thickness x:Key="Component.Button.Padding">12,6</Thickness>
    <CornerRadius x:Key="Component.Button.Radius">10</CornerRadius>
    <sys:Double x:Key="Component.Button.Height">32</sys:Double>

    <!-- ComboBox -->
    <CornerRadius x:Key="Component.ComboBox.Radius">10</CornerRadius>
    <sys:Double x:Key="Component.ComboBox.Height">30</sys:Double>

    <!-- TextBox -->
    <CornerRadius x:Key="Component.TextBox.Radius">10</CornerRadius>
    <Thickness x:Key="Component.TextBox.Padding">10,6</Thickness>
    <sys:Double x:Key="Component.TextBox.Height">30</sys:Double>

    <!-- Card -->
    <Thickness x:Key="Component.Card.Padding">16,12</Thickness>
    <CornerRadius x:Key="Component.Card.Radius">12</CornerRadius>

    <!-- DataGrid -->
    <Thickness x:Key="Component.DataGrid.CellPadding">8,4</Thickness>
    <Thickness x:Key="Component.DataGrid.HeaderPadding">8,6</Thickness>

    <!-- Theme Card -->
    <sys:Double x:Key="Component.ThemeCard.Width">140</sys:Double>
    <sys:Double x:Key="Component.ThemeCard.Height">120</sys:Double>
    <CornerRadius x:Key="Component.ThemeCard.Radius">12</CornerRadius>

    <!-- Accent Swatch -->
    <sys:Double x:Key="Component.AccentSwatch.Size">28</sys:Double>

    <!-- Progress Bar -->
    <CornerRadius x:Key="Component.ProgressBar.Radius">10</CornerRadius>

</ResourceDictionary>