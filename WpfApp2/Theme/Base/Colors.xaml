<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         PRIMITIVE TOKENS (raw palette - immutable)
         ============================================
         Primitive tokens contain raw color values with NO UI semantics.
         They MUST NOT be referenced directly from control templates.
         Use Semantic Tokens (Brush.*) or Component Tokens instead.
         ============================================ -->

    <!-- Blue family -->
    <Color x:Key="Primitive.Blue.500">#3A86FF</Color>
    <Color x:Key="Primitive.Blue.600">#1E90FF</Color>

    <!-- Slate family -->
    <Color x:Key="Primitive.Slate.900">#0E1720</Color>
    <Color x:Key="Primitive.Slate.800">#1C2B3A</Color>
    <Color x:Key="Primitive.Slate.700">#15202B</Color>

    <!-- White alpha family -->
    <Color x:Key="Primitive.White.95">#F2FFFFFF</Color>
    <Color x:Key="Primitive.White.75">#BFFFFFFF</Color>
    <Color x:Key="Primitive.White.40">#66FFFFFF</Color>
    <Color x:Key="Primitive.White.20">#33FFFFFF</Color>
    <Color x:Key="Primitive.White.10">#1AFFFFFF</Color>
    <Color x:Key="Primitive.White.5">#0DFFFFFF</Color>

    <!-- Green family -->
    <Color x:Key="Primitive.Green.500">#2ED573</Color>

    <!-- Orange family -->
    <Color x:Key="Primitive.Orange.500">#FFA502</Color>

    <!-- Red family -->
    <Color x:Key="Primitive.Red.500">#FF4757</Color>

    <!-- Black alpha family -->
    <Color x:Key="Primitive.Black.13">#22000000</Color>

    <!-- ============================================
         FLAT KEY ALIASES (backward compatibility)
         These alias primitive colors for existing code.
         New work SHOULD NOT use these keys.
         ============================================ -->
    <SolidColorBrush x:Key="Blue500" Color="{StaticResource Primitive.Blue.500}"/>
    <SolidColorBrush x:Key="Slate900" Color="{StaticResource Primitive.Slate.900}"/>
    <SolidColorBrush x:Key="Slate800" Color="{StaticResource Primitive.Slate.800}"/>
    <SolidColorBrush x:Key="Slate700" Color="{StaticResource Primitive.Slate.700}"/>
    <SolidColorBrush x:Key="WhiteAlpha95" Color="{StaticResource Primitive.White.95}"/>
    <SolidColorBrush x:Key="WhiteAlpha75" Color="{StaticResource Primitive.White.75}"/>
    <SolidColorBrush x:Key="WhiteAlpha40" Color="{StaticResource Primitive.White.40}"/>
    <SolidColorBrush x:Key="WhiteAlpha20" Color="{StaticResource Primitive.White.20}"/>
    <SolidColorBrush x:Key="WhiteAlpha10" Color="{StaticResource Primitive.White.10}"/>
    <SolidColorBrush x:Key="WhiteAlpha5" Color="{StaticResource Primitive.White.5}"/>

    <!-- ============================================
         SEMANTIC TOKENS (UI meaning aliases)
         These reference primitive colors.
         Controls MUST consume these (or Component Tokens).
         ============================================ -->

    <!-- Background -->
    <SolidColorBrush x:Key="Brush.Background.Primary" Color="{StaticResource Primitive.Slate.900}"/>
    <SolidColorBrush x:Key="Brush.Background.Secondary" Color="{StaticResource Primitive.Slate.800}"/>
    <SolidColorBrush x:Key="Brush.Background.Card" Color="{StaticResource Primitive.Slate.700}"/>
    <SolidColorBrush x:Key="Brush.Background.CardSubtle" Color="#10FFFFFF"/>
    <LinearGradientBrush x:Key="Brush.Background.Root" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF102A43" Offset="0"/>
        <GradientStop Color="#FF0F3B3B" Offset="1"/>
    </LinearGradientBrush>

    <!-- Text -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Primitive.White.95}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Primitive.White.75}"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="{StaticResource Primitive.White.40}"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="White"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{StaticResource Primitive.Blue.500}"/>
    <SolidColorBrush x:Key="Brush.Accent.Success" Color="{StaticResource Primitive.Green.500}"/>
    <SolidColorBrush x:Key="Brush.Accent.Warning" Color="{StaticResource Primitive.Orange.500}"/>
    <SolidColorBrush x:Key="Brush.Accent.Danger" Color="{StaticResource Primitive.Red.500}"/>
    <SolidColorBrush x:Key="Brush.Accent.Info" Color="{StaticResource Primitive.Blue.600}"/>
    <LinearGradientBrush x:Key="Brush.Accent.ProgressFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Primitive.Blue.500}" Offset="0"/>
        <GradientStop Color="{DynamicResource AccentColorLight}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Stroke -->
    <SolidColorBrush x:Key="Brush.Stroke.Card" Color="{StaticResource Primitive.White.20}"/>
    <SolidColorBrush x:Key="Brush.Stroke.Info" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Stroke.Status" Color="#1FFFFFFF"/>

    <!-- Fill -->
    <SolidColorBrush x:Key="Brush.Fill.Info" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Fill.Status" Color="#18FFFFFF"/>

    <!-- Control -->
    <SolidColorBrush x:Key="Brush.Control.Background" Color="#330E1720"/>
    <SolidColorBrush x:Key="Brush.Control.Stroke" Color="{StaticResource Primitive.White.20}"/>
    <SolidColorBrush x:Key="Brush.Control.HoverBackground" Color="#22007ACC"/>
    <SolidColorBrush x:Key="Brush.Control.SelectedBackground" Color="#44007ACC"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBorder" Color="#4C7EFF"/>
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBackground" Color="#161F2B"/>

    <!-- Button (semantic tokens for inline colors found in audit) -->
    <SolidColorBrush x:Key="Brush.Button.Background" Color="#2FFFFFFF"/>
    <SolidColorBrush x:Key="Brush.Button.HoverBackground" Color="#3FFFFFFF"/>
    <SolidColorBrush x:Key="Brush.Button.PressedBackground" Color="#22FFFFFF"/>

    <!-- DataGrid (semantic tokens for inline colors found in audit) -->
    <SolidColorBrush x:Key="Brush.DataGrid.AlternatingRow" Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="Brush.DataGrid.HoverRow" Color="#15FFFFFF"/>
    <SolidColorBrush x:Key="Brush.DataGrid.SelectedRow" Color="#333A86FF"/>

    <!-- Progress (semantic token for inline color found in audit) -->
    <SolidColorBrush x:Key="Brush.Progress.Background" Color="{StaticResource Primitive.Black.13}"/>

    <!-- ============================================
         LEGACY FLAT KEYS (backward compatibility)
         Kept for existing windows. Prefer semantic
         tokens for new work.
         ============================================ -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Primitive.Blue.500}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Primitive.Slate.900}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Primitive.Slate.700}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Primitive.Slate.800}"/>
    <SolidColorBrush x:Key="TextMainBrush" Color="{StaticResource Primitive.White.95}"/>
    <SolidColorBrush x:Key="TextSubBrush" Color="{StaticResource Primitive.White.75}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource Primitive.White.40}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Primitive.Green.500}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Primitive.Orange.500}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Primitive.Red.500}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Primitive.Blue.600}"/>
    <SolidColorBrush x:Key="CardStrokeBrush" Color="{StaticResource Primitive.White.20}"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="#330E1720"/>
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="{StaticResource Primitive.White.20}"/>

    <!-- ComboBox Popup -->
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#0F172A"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorder" Color="#334155"/>
    <SolidColorBrush x:Key="ComboBoxItemHighlight" Color="#1E3A5F"/>

    <!-- CheckBox foreground -->
    <SolidColorBrush x:Key="CheckMarkForeground" Color="White"/>

    <!-- Theme Card -->
    <SolidColorBrush x:Key="CardHoverBorder" Color="#4C7EFF"/>

    <SolidColorBrush x:Key="TextOnAccentBrush" Color="White"/>
    <SolidColorBrush x:Key="StrokeInfoBrush" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="StrokeStatusBrush" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="FillInfoBrush" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="FillStatusBrush" Color="#18FFFFFF"/>

    <Color x:Key="AccentColorLight">#6688FF</Color>

</ResourceDictionary>
