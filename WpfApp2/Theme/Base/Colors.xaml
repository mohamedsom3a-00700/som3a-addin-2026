<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         PRIMITIVE TOKENS (raw palette - immutable)
         ============================================
         Primitive tokens contain raw color values with NO UI semantics.
         They MUST NOT be referenced directly from control templates.
         Use Semantic Tokens (Brush.*) or Component Tokens instead.
         ============================================ -->

    <!-- Blue family -->
    <Color x:Key="Primitive.Blue.500">#3A86FF</Color>
    <Color x:Key="Primitive.Blue.600">#1E90FF</Color>

    <!-- Slate family -->
    <Color x:Key="Primitive.Slate.900">#0E1720</Color>
    <Color x:Key="Primitive.Slate.900.Translucent">#800E1720</Color>
    <Color x:Key="Primitive.Slate.800">#1C2B3A</Color>
    <Color x:Key="Primitive.Slate.800.Translucent">#801C2B3A</Color>
    <Color x:Key="Primitive.Slate.700">#15202B</Color>

    <!-- White alpha family -->
    <Color x:Key="Primitive.White.95">#F2FFFFFF</Color>
    <Color x:Key="Primitive.White.75">#BFFFFFFF</Color>
    <Color x:Key="Primitive.White.40">#66FFFFFF</Color>
    <Color x:Key="Primitive.White.20">#33FFFFFF</Color>
    <Color x:Key="Primitive.White.10">#1AFFFFFF</Color>
    <Color x:Key="Primitive.White.5">#0DFFFFFF</Color>

    <!-- Green family -->
    <Color x:Key="Primitive.Green.500">#2ED573</Color>

    <!-- Orange family -->
    <Color x:Key="Primitive.Orange.500">#FFA502</Color>

    <!-- ============================================
         BRAND PALETTE (Planova Platform)
         Primitive brand tokens for rebranding.
         Dark values are default; light values are
         provided by theme overrides.
         ============================================ -->
    <Color x:Key="Primitive.Brand.Background">#0E1720</Color>
    <Color x:Key="Primitive.Brand.Surface">#13202B</Color>
    <Color x:Key="Primitive.Brand.Border">#243647</Color>
    <Color x:Key="Primitive.Brand.AccentBlue">#2D9CFF</Color>
    <Color x:Key="Primitive.Brand.AccentCyan">#00D1FF</Color>
    <Color x:Key="Primitive.Brand.AccentOrange">#FF8A3D</Color>
    <Color x:Key="Primitive.Brand.TextPrimary">#FFFFFF</Color>
    <Color x:Key="Primitive.Brand.TextSecondary">#B7C5D3</Color>
    <Color x:Key="Primitive.Brand.BlueprintGlow">#00D1FF</Color>
    <Color x:Key="Primitive.Brand.GlassBorder">#2A3F52</Color>

    <!-- Red family -->
    <Color x:Key="Primitive.Red.500">#FF4757</Color>

    <!-- Black alpha family -->
    <Color x:Key="Primitive.Black.8">#14000000</Color>
    <Color x:Key="Primitive.Black.13">#22000000</Color>
    <Color x:Key="Primitive.Black.53">#88000000</Color>

    <!-- White alpha additions -->
    <Color x:Key="Primitive.White.33">#54FFFFFF</Color>

    <!-- Transparency tokens (documentation/validation for alpha composition) -->
    <Color x:Key="Primitive.Transparency.Subtle">#0DFFFFFF</Color>
    <Color x:Key="Primitive.Transparency.Light">#1AFFFFFF</Color>
    <Color x:Key="Primitive.Transparency.MediumLow">#1FFFFFFF</Color>
    <Color x:Key="Primitive.Transparency.Medium">#2FFFFFFF</Color>
    <Color x:Key="Primitive.Transparency.Strong">#3FFFFFFF</Color>

    <!-- ============================================
         FLAT KEY ALIASES (backward compatibility)
         These alias primitive colors for existing code.
         New work SHOULD NOT use these keys.
         ============================================ -->
    <SolidColorBrush x:Key="Blue500" Color="{StaticResource Primitive.Blue.500}"/>
    <SolidColorBrush x:Key="Slate900" Color="{StaticResource Primitive.Slate.900}"/>
    <SolidColorBrush x:Key="Slate800" Color="{StaticResource Primitive.Slate.800}"/>
    <SolidColorBrush x:Key="Slate700" Color="{StaticResource Primitive.Slate.700}"/>
    <SolidColorBrush x:Key="WhiteAlpha95" Color="{StaticResource Primitive.White.95}"/>
    <SolidColorBrush x:Key="WhiteAlpha75" Color="{StaticResource Primitive.White.75}"/>
    <SolidColorBrush x:Key="WhiteAlpha40" Color="{StaticResource Primitive.White.40}"/>
    <SolidColorBrush x:Key="WhiteAlpha20" Color="{StaticResource Primitive.White.20}"/>
    <SolidColorBrush x:Key="WhiteAlpha10" Color="{StaticResource Primitive.White.10}"/>
    <SolidColorBrush x:Key="WhiteAlpha5" Color="{StaticResource Primitive.White.5}"/>

    <!-- ============================================
         SEMANTIC COLOR TOKENS (resolved values)
         These provide Color entries referenced by
         semantic brushes and legacy aliases.
         Theme overrides can replace these tokens.
         ============================================ -->
    <Color x:Key="Color.Background.CardSubtle">#10FFFFFF</Color>
    <Color x:Key="Color.Background.RootStart">#FF102A43</Color>
    <Color x:Key="Color.Background.RootEnd">#FF0F3B3B</Color>
    <Color x:Key="Color.Text.OnAccent">#FFFFFFFF</Color>
    <Color x:Key="Color.Stroke.Info">#12FFFFFF</Color>
    <Color x:Key="Color.Stroke.Status">#1FFFFFFF</Color>
    <Color x:Key="Color.Fill.Info">#12FFFFFF</Color>
    <Color x:Key="Color.Fill.Status">#18FFFFFF</Color>
    <Color x:Key="Color.Control.Background">#330E1720</Color>
    <Color x:Key="Color.Control.HoverBackground">#22007ACC</Color>
    <Color x:Key="Color.Control.SelectedBackground">#44007ACC</Color>
    <Color x:Key="Color.ComboBox.HoverBorder">#4C7EFF</Color>
    <Color x:Key="Color.ComboBox.HoverBackground">#161F2B</Color>
    <Color x:Key="Color.Button.Background">#2FFFFFFF</Color>
    <Color x:Key="Color.Button.HoverBackground">#3FFFFFFF</Color>
    <Color x:Key="Color.Button.PressedBackground">#22FFFFFF</Color>
    <Color x:Key="Color.DataGrid.AlternatingRow">#0AFFFFFF</Color>
    <Color x:Key="Color.DataGrid.HoverRow">#15FFFFFF</Color>
    <Color x:Key="Color.DataGrid.SelectedRow">#333A86FF</Color>
    <Color x:Key="Color.ComboBoxPopup">#0F172A</Color>
    <Color x:Key="Color.ComboBoxPopupBorder">#334155</Color>
    <Color x:Key="Color.ComboBoxItemHighlight">#1E3A5F</Color>
    <Color x:Key="Color.CheckMark">#FFFFFFFF</Color>
    <Color x:Key="Color.CardHoverBorder">#4C7EFF</Color>
    <Color x:Key="Color.SwatchStroke">#FFFFFFFF</Color>
    <Color x:Key="Color.ScrollBar.Thumb">#55FFFFFF</Color>
    <Color x:Key="Color.ScrollBar.ThumbHover">#88FFFFFF</Color>
    <Color x:Key="Color.GroupBox.Background">#14000000</Color>
    <Color x:Key="Color.Overlay.Background">#88000000</Color>
    <Color x:Key="Color.Animation.ThumbFade">#66FFFFFF</Color>
    <Color x:Key="Color.Animation.ButtonHoverDanger">#22FF4757</Color>
    <Color x:Key="Color.Background.RootStart.Light">#FFF0F4F8</Color>
    <Color x:Key="Color.Background.RootEnd.Light">#FFE2E8F0</Color>
    <Color x:Key="Color.CloseButton.HoverBackground">#22FF4757</Color>
    <Color x:Key="Color.CloseButton.PressedBackground">#33FF4757</Color>
    <Color x:Key="Color.Loading.Background">#88000000</Color>
    <Color x:Key="Color.TitleBar.ButtonHover">#15FFFFFF</Color>
    <Color x:Key="Color.TitleBar.ButtonPressed">#22FFFFFF</Color>
    <Color x:Key="Color.ListView.HoverBackground">#15FFFFFF</Color>
    <Color x:Key="Color.ListView.SelectedBackground">#40FFFFFF</Color>
    <Color x:Key="Color.ColumnHeader.HoverBackground">#1AFFFFFF</Color>

    <!-- ============================================
         SEMANTIC TOKENS (UI meaning aliases)
         These reference primitive colors and semantic
         color tokens. Controls MUST consume these
         (or Component Tokens).
         ============================================ -->

    <!-- Background -->
    <SolidColorBrush x:Key="Brush.Background.Primary" Color="{StaticResource Primitive.Slate.900}"/>
    <SolidColorBrush x:Key="Brush.Background.Primary.Translucent" Color="{StaticResource Primitive.Slate.900.Translucent}"/>
    <SolidColorBrush x:Key="Brush.Background.Secondary" Color="{StaticResource Primitive.Slate.800}"/>
    <SolidColorBrush x:Key="Brush.Background.Secondary.Translucent" Color="{StaticResource Primitive.Slate.800.Translucent}"/>
    <SolidColorBrush x:Key="Brush.Background.Card" Color="{StaticResource Primitive.Slate.700}"/>
    <SolidColorBrush x:Key="Brush.Background.CardSubtle" Color="{StaticResource Color.Background.CardSubtle}"/>
    <LinearGradientBrush x:Key="Brush.Background.Root" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Color.Background.RootStart}" Offset="0"/>
        <GradientStop Color="{StaticResource Color.Background.RootEnd}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Text -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Primitive.White.95}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Primitive.White.75}"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="{StaticResource Primitive.White.40}"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{StaticResource Color.Text.OnAccent}"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{StaticResource Primitive.Brand.AccentBlue}"/>
    <SolidColorBrush x:Key="Brush.Accent.Cyan" Color="{StaticResource Primitive.Brand.AccentCyan}"/>
    <SolidColorBrush x:Key="Brush.Accent.Orange" Color="{StaticResource Primitive.Brand.AccentOrange}"/>
    <SolidColorBrush x:Key="Brush.Accent.Success" Color="{StaticResource Primitive.Green.500}"/>
    <SolidColorBrush x:Key="Brush.Accent.Warning" Color="{StaticResource Primitive.Orange.500}"/>
    <SolidColorBrush x:Key="Brush.Accent.Danger" Color="{StaticResource Primitive.Red.500}"/>
    <SolidColorBrush x:Key="Brush.Accent.Info" Color="{StaticResource Primitive.Blue.600}"/>
    <LinearGradientBrush x:Key="Brush.Accent.ProgressFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Primitive.Brand.AccentBlue}" Offset="0"/>
        <GradientStop Color="{DynamicResource AccentColorLight}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Brand Window / Surface / Border -->
    <SolidColorBrush x:Key="Brush.Window.Background" Color="{StaticResource Primitive.Brand.Background}"/>
    <SolidColorBrush x:Key="Brush.Surface.Default" Color="{StaticResource Primitive.Brand.Surface}"/>
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{StaticResource Primitive.Brand.Border}"/>
    <SolidColorBrush x:Key="Brush.Glow.Default" Color="{StaticResource Primitive.Brand.BlueprintGlow}"/>
    <SolidColorBrush x:Key="Brush.Effect.GlassBorder" Color="{StaticResource Primitive.Brand.GlassBorder}"/>

    <!-- Stroke -->
    <SolidColorBrush x:Key="Brush.Stroke.Card" Color="{StaticResource Primitive.White.20}"/>
    <SolidColorBrush x:Key="Brush.Stroke.Info" Color="{StaticResource Color.Stroke.Info}"/>
    <SolidColorBrush x:Key="Brush.Stroke.Status" Color="{StaticResource Color.Stroke.Status}"/>

    <!-- Fill -->
    <SolidColorBrush x:Key="Brush.Fill.Info" Color="{StaticResource Color.Fill.Info}"/>
    <SolidColorBrush x:Key="Brush.Fill.Status" Color="{StaticResource Color.Fill.Status}"/>

    <!-- Control -->
    <SolidColorBrush x:Key="Brush.Control.Background" Color="{StaticResource Color.Control.Background}"/>
    <SolidColorBrush x:Key="Brush.Control.Stroke" Color="{StaticResource Primitive.White.20}"/>
    <SolidColorBrush x:Key="Brush.Control.HoverBackground" Color="{StaticResource Color.Control.HoverBackground}"/>
    <SolidColorBrush x:Key="Brush.Control.SelectedBackground" Color="{StaticResource Color.Control.SelectedBackground}"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBorder" Color="{StaticResource Color.ComboBox.HoverBorder}"/>
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBackground" Color="{StaticResource Color.ComboBox.HoverBackground}"/>

    <!-- Button -->
    <SolidColorBrush x:Key="Brush.Button.Background" Color="{StaticResource Color.Button.Background}"/>
    <SolidColorBrush x:Key="Brush.Button.HoverBackground" Color="{StaticResource Color.Button.HoverBackground}"/>
    <SolidColorBrush x:Key="Brush.Button.PressedBackground" Color="{StaticResource Color.Button.PressedBackground}"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="Brush.DataGrid.AlternatingRow" Color="{StaticResource Color.DataGrid.AlternatingRow}"/>
    <SolidColorBrush x:Key="Brush.DataGrid.HoverRow" Color="{StaticResource Color.DataGrid.HoverRow}"/>
    <SolidColorBrush x:Key="Brush.DataGrid.SelectedRow" Color="{StaticResource Color.DataGrid.SelectedRow}"/>

    <!-- Progress -->
    <SolidColorBrush x:Key="Brush.Progress.Background" Color="{StaticResource Primitive.Black.13}"/>

    <!-- Swatch -->
    <SolidColorBrush x:Key="Brush.Swatch.Stroke" Color="{StaticResource Color.SwatchStroke}"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb" Color="{StaticResource Color.ScrollBar.Thumb}"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.ThumbHover" Color="{StaticResource Color.ScrollBar.ThumbHover}"/>

    <!-- GroupBox -->
    <SolidColorBrush x:Key="Brush.GroupBox.Background" Color="{StaticResource Color.GroupBox.Background}"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="Brush.Overlay.Background" Color="{StaticResource Color.Overlay.Background}"/>

    <!-- Close Button -->
    <SolidColorBrush x:Key="Brush.CloseButton.HoverBackground" Color="{StaticResource Color.CloseButton.HoverBackground}"/>
    <SolidColorBrush x:Key="Brush.CloseButton.PressedBackground" Color="{StaticResource Color.CloseButton.PressedBackground}"/>

    <!-- Loading -->
    <SolidColorBrush x:Key="Brush.Loading.Background" Color="{StaticResource Color.Overlay.Background}"/>

    <!-- Title Bar -->
    <SolidColorBrush x:Key="Brush.TitleBar.ButtonHover" Color="{StaticResource Color.TitleBar.ButtonHover}"/>
    <SolidColorBrush x:Key="Brush.TitleBar.ButtonPressed" Color="{StaticResource Color.TitleBar.ButtonPressed}"/>

    <!-- ListView -->
    <SolidColorBrush x:Key="Brush.ListView.HoverBackground" Color="{StaticResource Color.ListView.HoverBackground}"/>
    <SolidColorBrush x:Key="Brush.ListView.SelectedBackground" Color="{StaticResource Color.ListView.SelectedBackground}"/>
    <SolidColorBrush x:Key="Brush.ListView.ColumnHeaderHover" Color="{StaticResource Color.ColumnHeader.HoverBackground}"/>

    <!-- ============================================
         LEGACY FLAT KEYS (backward compatibility)
         DEPRECATED: Use Brush.* namespace instead.
         Removal: Phase 6
         ============================================ -->
    <!-- DEPRECATED: Use Brush.Accent.Primary instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Primitive.Blue.500}"/>
    <!-- DEPRECATED: Use Brush.Background.Primary instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Primitive.Slate.900}"/>
    <!-- DEPRECATED: Use Brush.Background.Card instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Primitive.Slate.700}"/>
    <!-- DEPRECATED: Use Brush.Background.Secondary instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Primitive.Slate.800}"/>
    <!-- DEPRECATED: Use Brush.Text.Primary instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="TextMainBrush" Color="{StaticResource Primitive.White.95}"/>
    <!-- DEPRECATED: Use Brush.Text.Secondary instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="TextSubBrush" Color="{StaticResource Primitive.White.75}"/>
    <!-- DEPRECATED: Use Brush.Text.Disabled instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource Primitive.White.40}"/>
    <!-- DEPRECATED: Use Brush.Accent.Success instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Primitive.Green.500}"/>
    <!-- DEPRECATED: Use Brush.Accent.Warning instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Primitive.Orange.500}"/>
    <!-- DEPRECATED: Use Brush.Accent.Danger instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Primitive.Red.500}"/>
    <!-- DEPRECATED: Use Brush.Accent.Info instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Primitive.Blue.600}"/>
    <!-- DEPRECATED: Use Brush.Stroke.Card instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="CardStrokeBrush" Color="{StaticResource Primitive.White.20}"/>
    <!-- DEPRECATED: Use Brush.Control.Background instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="ControlBgBrush" Color="{StaticResource Color.Control.Background}"/>
    <!-- DEPRECATED: Use Brush.Control.Stroke instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="{StaticResource Primitive.White.20}"/>

    <!-- DEPRECATED: Use Brush.ComboBox.* instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="{StaticResource Color.ComboBoxPopup}"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorder" Color="{StaticResource Color.ComboBoxPopupBorder}"/>
    <SolidColorBrush x:Key="ComboBoxItemHighlight" Color="{StaticResource Color.ComboBoxItemHighlight}"/>

    <!-- DEPRECATED: Use Brush.Text.OnAccent instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="CheckMarkForeground" Color="{StaticResource Color.CheckMark}"/>

    <!-- DEPRECATED: Use Brush.Stroke.Card (hover state) instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="CardHoverBorder" Color="{StaticResource Color.CardHoverBorder}"/>

    <!-- DEPRECATED: Use Brush.Text.OnAccent instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource Color.CheckMark}"/>
    <!-- DEPRECATED: Use Brush.Stroke.Info instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="StrokeInfoBrush" Color="{StaticResource Color.Stroke.Info}"/>
    <!-- DEPRECATED: Use Brush.Stroke.Status instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="StrokeStatusBrush" Color="{StaticResource Color.Stroke.Status}"/>
    <!-- DEPRECATED: Use Brush.Fill.Info instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="FillInfoBrush" Color="{StaticResource Color.Fill.Info}"/>
    <!-- DEPRECATED: Use Brush.Fill.Status instead. Removal: Phase 6 -->
    <SolidColorBrush x:Key="FillStatusBrush" Color="{StaticResource Color.Fill.Status}"/>

    <Color x:Key="Color.AcceptedRow.Background">#1A00AA00</Color>
    <Color x:Key="Color.WarningBanner.Background">#33FFA500</Color>
    <Color x:Key="Color.WarningBanner.Border">#FFFFA502</Color>

    <!-- Accepted Row -->
    <SolidColorBrush x:Key="AcceptedRowBackgroundBrush" Color="{StaticResource Color.AcceptedRow.Background}"/>
    <!-- Warning Banner (No API Key) -->
    <SolidColorBrush x:Key="WarningBannerBackground" Color="{StaticResource Color.WarningBanner.Background}"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="{StaticResource Color.WarningBanner.Border}"/>

    <Color x:Key="AccentColorLight">#6688FF</Color>

</ResourceDictionary>
