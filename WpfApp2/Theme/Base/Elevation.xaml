<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         ELEVATION TOKENS
         Map semantic elevation levels to shadow effects.
         Controls consume Elevation.*, not Shadow.* directly.
         Each Elevation.* key duplicates the matching
         Shadow.* values for .NET Framework 4.8 compat.
         ============================================ -->

    <DropShadowEffect x:Key="Elevation.Card"
        BlurRadius="16" ShadowDepth="4" Direction="270"
        Color="#000000" Opacity="0.25"/>
    <DropShadowEffect x:Key="Elevation.Popup"
        BlurRadius="15" ShadowDepth="3" Direction="270"
        Color="#000000" Opacity="0.3"/>
    <DropShadowEffect x:Key="Elevation.Window"
        BlurRadius="30" ShadowDepth="8" Direction="270"
        Color="#000000" Opacity="0.4"/>
    <DropShadowEffect x:Key="Elevation.Small"
        BlurRadius="8" ShadowDepth="2" Direction="270"
        Color="#000000" Opacity="0.2"/>
    <DropShadowEffect x:Key="Elevation.Medium"
        BlurRadius="12" ShadowDepth="3" Direction="270"
        Color="#000000" Opacity="0.25"/>
    <DropShadowEffect x:Key="Elevation.Large"
        BlurRadius="20" ShadowDepth="5" Direction="270"
        Color="#000000" Opacity="0.3"/>

    <!-- Safe-mode elevation variants (for FallbackSafe rendering) -->
    <DropShadowEffect x:Key="Elevation.Card.Safe"
        BlurRadius="10" ShadowDepth="3" Direction="270"
        Color="#000000" Opacity="0.2"/>
    <DropShadowEffect x:Key="Elevation.Popup.Safe"
        BlurRadius="8" ShadowDepth="2" Direction="270"
        Color="#000000" Opacity="0.2"/>
    <DropShadowEffect x:Key="Elevation.Window.Safe"
        BlurRadius="16" ShadowDepth="4" Direction="270"
        Color="#000000" Opacity="0.25"/>

</ResourceDictionary>