<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================
         ELEVATION TOKENS (abstraction layer)
         Semantic elevation levels mapped to shadow
         parameters. Controls reference these tokens
         for elevation values; DropShadowEffect
         definitions are in Effects/Shadows.xaml.
         ============================================ -->

    <!-- Card elevation -->
    <sys:Double x:Key="Elevation.Card.OffsetX">0</sys:Double>
    <sys:Double x:Key="Elevation.Card.OffsetY">4</sys:Double>
    <sys:Double x:Key="Elevation.Card.BlurRadius">16</sys:Double>
    <sys:Double x:Key="Elevation.Card.Opacity">0.25</sys:Double>

    <!-- Popup elevation -->
    <sys:Double x:Key="Elevation.Popup.OffsetX">0</sys:Double>
    <sys:Double x:Key="Elevation.Popup.OffsetY">3</sys:Double>
    <sys:Double x:Key="Elevation.Popup.BlurRadius">15</sys:Double>
    <sys:Double x:Key="Elevation.Popup.Opacity">0.3</sys:Double>

    <!-- Window elevation -->
    <sys:Double x:Key="Elevation.Window.OffsetX">0</sys:Double>
    <sys:Double x:Key="Elevation.Window.OffsetY">8</sys:Double>
    <sys:Double x:Key="Elevation.Window.BlurRadius">30</sys:Double>
    <sys:Double x:Key="Elevation.Window.Opacity">0.4</sys:Double>

    <!-- Small elevation -->
    <sys:Double x:Key="Elevation.Small.OffsetX">0</sys:Double>
    <sys:Double x:Key="Elevation.Small.OffsetY">2</sys:Double>
    <sys:Double x:Key="Elevation.Small.BlurRadius">8</sys:Double>
    <sys:Double x:Key="Elevation.Small.Opacity">0.2</sys:Double>

    <!-- Medium elevation -->
    <sys:Double x:Key="Elevation.Medium.OffsetX">0</sys:Double>
    <sys:Double x:Key="Elevation.Medium.OffsetY">3</sys:Double>
    <sys:Double x:Key="Elevation.Medium.BlurRadius">12</sys:Double>
    <sys:Double x:Key="Elevation.Medium.Opacity">0.25</sys:Double>

    <!-- Large elevation -->
    <sys:Double x:Key="Elevation.Large.OffsetX">0</sys:Double>
    <sys:Double x:Key="Elevation.Large.OffsetY">5</sys:Double>
    <sys:Double x:Key="Elevation.Large.BlurRadius">20</sys:Double>
    <sys:Double x:Key="Elevation.Large.Opacity">0.3</sys:Double>

</ResourceDictionary>