<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================
         Z-INDEX TOKENS
         Layering constants for visual stacking.
         Higher values render on top of lower values.
         ============================================ -->

    <sys:Int32 x:Key="ZIndex.Base">0</sys:Int32>
    <sys:Int32 x:Key="ZIndex.Content">10</sys:Int32>
    <sys:Int32 x:Key="ZIndex.Popup">100</sys:Int32>
    <sys:Int32 x:Key="ZIndex.Tooltip">200</sys:Int32>
    <sys:Int32 x:Key="ZIndex.Overlay">300</sys:Int32>
    <sys:Int32 x:Key="ZIndex.Dialog">400</sys:Int32>
    <sys:Int32 x:Key="ZIndex.Toast">500</sys:Int32>
    <sys:Int32 x:Key="ZIndex.Loading">600</sys:Int32>

</ResourceDictionary>
