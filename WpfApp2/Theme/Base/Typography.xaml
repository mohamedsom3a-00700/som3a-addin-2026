<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <FontFamily x:Key="FontFamilyPrimary">Segoe UI</FontFamily>

    <sys:Double x:Key="TitleFontSize">20</sys:Double>
    <sys:Double x:Key="HeaderFontSize">16</sys:Double>
    <sys:Double x:Key="SubHeaderFontSize">14</sys:Double>
    <sys:Double x:Key="BodyFontSize">13</sys:Double>
    <sys:Double x:Key="CaptionFontSize">11</sys:Double>

    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightMedium">Medium</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

</ResourceDictionary>