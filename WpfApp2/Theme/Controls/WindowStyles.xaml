<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls">

    <!-- ModernWindow Style -->
    <Style TargetType="{x:Type controls:ModernWindow}">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ModernWindow}">
                    <Border x:Name="WindowBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource ControlStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource WindowRadius}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="4" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="{DynamicResource HeaderHeight}"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header Bar -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="{DynamicResource HeaderCornerRadius}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Title -->
                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding Title}"
                                               Foreground="{DynamicResource TextMainBrush}"
                                               VerticalAlignment="Center"
                                               Margin="16,0,0,0"
                                               FontSize="{DynamicResource SubHeaderFontSize}"
                                               FontWeight="Medium"/>

                                    <!-- Window Controls -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="0,6,8,6">
                                        <!-- Minimize Button -->
                                        <Button x:Name="MinimizeBtn"
                                                Style="{DynamicResource TitleBarButton}"
                                                Command="{Binding MinimizeCommand}"
                                                Width="32" Height="28"
                                                ToolTip="Minimize"
                                                Margin="0,0,4,0">
                                            <Path Data="M 0 0 L 10 0"
                                                  Stroke="{DynamicResource TextSubBrush}"
                                                  StrokeThickness="1"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                        </Button>

                                        <!-- Close Button -->
                                        <Button x:Name="CloseBtn"
                                                Style="{DynamicResource TitleBarButton}"
                                                Command="{Binding CloseCommand}"
                                                Width="32" Height="28"
                                                ToolTip="Close">
                                            <Path Data="M 0 0 L 10 10 M 10 0 L 0 10"
                                                  Stroke="{DynamicResource TextSubBrush}"
                                                  StrokeThickness="1.5"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Content -->
                            <ContentPresenter Grid.Row="1"
                                              Margin="0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CloseBtn" Property="Background" Value="#22FF4757"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>