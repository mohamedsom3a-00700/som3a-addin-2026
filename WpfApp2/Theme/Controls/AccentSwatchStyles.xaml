<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <CubicEase x:Key="SwatchEase" EasingMode="EaseOut"/>

    <!-- Accent Swatch Base -->
    <Style x:Key="AccentSwatch" TargetType="{x:Type Ellipse}">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Stroke" Value="Transparent"/>
        <Setter Property="StrokeThickness" Value="0"/>
    </Style>

    <!-- Accent Swatch Interactive -->
    <Style x:Key="AccentSwatchInteractive" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatch}">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                To="1.15" Duration="0:0:0.12"
                                EasingFunction="{StaticResource SwatchEase}"/>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.15" Duration="0:0:0.12"
                                EasingFunction="{StaticResource SwatchEase}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                To="1" Duration="0:0:0.12"
                                EasingFunction="{StaticResource SwatchEase}"/>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                To="1" Duration="0:0:0.12"
                                EasingFunction="{StaticResource SwatchEase}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Accent Swatch Selected -->
    <Style x:Key="AccentSwatchSelected" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatch}">
        <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="StrokeThickness" Value="3"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1.15" ScaleY="1.15"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>