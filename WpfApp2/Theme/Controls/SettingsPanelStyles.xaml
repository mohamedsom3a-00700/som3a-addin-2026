<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:fluentIcons="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf">

    <!-- Sidebar Navigation Styles -->
    <Style x:Key="SidebarListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="UseLayoutRounding" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{DynamicResource CardStrokeBrush}"
                                        BorderThickness="0"
                                        CornerRadius="{DynamicResource MediumRadius}"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Grid Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="True"
                                          UseLayoutRounding="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="IconText"
                                                   Grid.Column="0"
                                                   Text="{Binding Icon}"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource TextSubBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextMainBrush}"
                                                   VerticalAlignment="Center"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="IconText" Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource Brush.Control.HoverBackground}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar Icon-Only Template (used when sidebar is collapsed) -->
    <DataTemplate x:Key="SidebarIconTemplate">
        <Grid>
            <fluentIcons:FluentIcon Icon="{Binding Icon, Converter={StaticResource FluentIconConverter}}"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
        </Grid>
    </DataTemplate>

    <!-- Sidebar Item Template -->
    <DataTemplate x:Key="SidebarFullTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <fluentIcons:FluentIcon Grid.Column="0"
                                   Icon="{Binding Icon, Converter={StaticResource FluentIconConverter}}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding DisplayName}"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Foreground="{DynamicResource TextMainBrush}"
                       SnapsToDevicePixels="True"
                       UseLayoutRounding="True"/>
        </Grid>
    </DataTemplate>

    <!-- Panel Container Style -->
    <Style x:Key="PanelContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LargeRadius}"/>
        <Setter Property="Padding" Value="{DynamicResource Padding.XLarge}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Panel Section Style -->
    <Style x:Key="PanelSectionStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Section Header Style -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSubBrush}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- Setting Label Style -->
    <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSubBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- Action Button Style -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Status Text Style -->
    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSubBrush}"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>


    <!-- ComboBox Style for Settings Panels -->
    <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource RoundComboBox}"/>

    <!-- Toggle Switch Style for Settings Panels -->
    <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton" BasedOn="{StaticResource FluentToggleButton}"/>

</ResourceDictionary>
