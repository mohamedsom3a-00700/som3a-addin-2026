<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!-- ROUND COMBOBOX -->
    <!-- ===================================================== -->

    <Style x:Key="RoundComboBox"
           TargetType="{x:Type ComboBox}">

        <Setter Property="Foreground"
                Value="{DynamicResource Brush.Text.Primary}"/>

        <Setter Property="Background"
                Value="{DynamicResource Brush.Control.Background}"/>

        <Setter Property="BorderBrush"
                Value="{DynamicResource Brush.Control.Stroke}"/>

        <Setter Property="BorderThickness"
                Value="1"/>

        <Setter Property="Padding"
                Value="{DynamicResource InputPadding}"/>

        <Setter Property="Height"
                Value="{DynamicResource ControlHeight}"/>

        <Setter Property="SnapsToDevicePixels"
                Value="True"/>

        <Setter Property="UseLayoutRounding"
                Value="True"/>

        <Setter Property="FocusVisualStyle"
                Value="{DynamicResource FocusVisualStyle}"/>

        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                Value="Disabled"/>

        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                Value="Auto"/>

        <Setter Property="ScrollViewer.CanContentScroll"
                Value="False"/>

        <!-- TEMPLATE -->

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="{x:Type ComboBox}">

                    <Grid UseLayoutRounding="True">

                        <!-- BORDER -->

                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource MediumRadius}"
                                SnapsToDevicePixels="True"/>

                        <!-- TOGGLE -->

                        <ToggleButton x:Name="ToggleButton"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen,
                                                          Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}">

                            <Grid Margin="12,0,12,0">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="24"/>

                                    <ColumnDefinition Width="*"/>

                                </Grid.ColumnDefinitions>

                                <!-- TEXT -->

                                <ContentPresenter Grid.Column="1"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Left"
                  RecognizesAccessKey="True"
                   TextElement.Foreground="{DynamicResource Brush.Text.Primary}"
                  Content="{TemplateBinding SelectionBoxItem}"
                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                <!-- ARROW -->

                                <Path x:Name="Arrow"
                                      Grid.Column="0"
                                      Data="M 0 0 L 5 5 L 10 0"
                                      Stroke="{DynamicResource Brush.Text.Secondary}"
                                      StrokeThickness="2"
                                      Width="10"
                                      Height="6"
                                      Stretch="Fill"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>

                            </Grid>

                        </ToggleButton>

                        <!-- POPUP -->

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                               AllowsTransparency="False"
                               Focusable="False"
                               PopupAnimation="Fade"
                               IsOpen="{TemplateBinding IsDropDownOpen}">

                            <Border x:Name="PopupBorder"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,6,0,0"
                                    Background="{DynamicResource Brush.Background.Card}"
                                    BorderBrush="{DynamicResource Brush.Control.Stroke}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource MediumRadius}"
                                    Effect="{DynamicResource Shadow.Popup}">
                                <Grid>
                                    <ScrollViewer MaxHeight="250"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="False">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                    <TextBlock x:Name="EmptyText"
                                               Text="No items available"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                                               FontStyle="Italic"
                                               Padding="12,8"/>
                                </Grid>
                            </Border>

                        </Popup>

                    </Grid>

                    <!-- TRIGGERS -->

                    <ControlTemplate.Triggers>

                        <!-- Hover -->

                        <Trigger Property="IsMouseOver"
         Value="True">

                            <!-- Border -->

<Setter TargetName="Bd"
             Property="BorderBrush"
             Value="{DynamicResource Brush.ComboBox.HoverBorder}"/>

                            <!-- Soft Background -->

                            <Setter TargetName="Bd"
             Property="Background"
             Value="{DynamicResource Brush.ComboBox.HoverBackground}"/>
                             <Setter TargetName="Arrow"
             Property="Stroke"
             Value="{DynamicResource Brush.ComboBox.HoverBorder}"/>

                        </Trigger>

                        <!-- Focus -->

                        <Trigger Property="IsKeyboardFocused"
                                 Value="True">

                            <Setter TargetName="Bd"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.Accent.Primary}"/>

                            <Setter TargetName="Bd"
                                    Property="Effect"
                                    Value="{DynamicResource Glow.Focus}"/>

                        </Trigger>

                        <!-- Open -->

                        <Trigger Property="IsDropDownOpen"
                                 Value="True">

                            <Setter TargetName="Bd"
                                    Property="Background"
                                    Value="{DynamicResource Brush.Background.Card}"/>

                            <Setter TargetName="Bd"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.Accent.Primary}"/>

                            <Setter TargetName="Arrow"
                                    Property="Stroke"
                                    Value="{DynamicResource Brush.Accent.Primary}"/>

                            <Setter TargetName="Arrow"
                                    Property="RenderTransform">

                                <Setter.Value>

                                    <RotateTransform Angle="180"/>

                                </Setter.Value>

                            </Setter>

                        </Trigger>

                        <!-- Disabled -->

                        <Trigger Property="IsEnabled"
                                 Value="False">

                            <Setter Property="Opacity"
                                    Value="0.5"/>

                        </Trigger>

                        <!-- Empty items: show indicator when no items -->
                        <Trigger Property="HasItems"
                                 Value="False">
                            <Setter TargetName="EmptyText"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

</ResourceDictionary>