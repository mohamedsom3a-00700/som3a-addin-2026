<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Slim modern ScrollBar (applies to all ScrollBars) -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="6"/>
        <Setter Property="MinWidth" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" AutomationProperties.Name="Scroll up"
                                              SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Focusable="False" AutomationProperties.Name="Scroll position"
                                       SnapsToDevicePixels="True" UseLayoutRounding="True">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
<Border x:Name="ThumbBd"
                                                     Background="{DynamicResource Brush.ScrollBar.Thumb}"
                                                     CornerRadius="3"
                                                     Margin="1,0"/>
                                             <ControlTemplate.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter TargetName="ThumbBd" Property="Background" Value="{DynamicResource Brush.ScrollBar.ThumbHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" AutomationProperties.Name="Scroll down"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="6"/>
                <Setter Property="MinHeight" Value="6"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Accent ScrollBar -->
    <Style x:Key="AccentScrollBar" TargetType="{x:Type ScrollBar}">
        <Setter Property="Width"      Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand"
                                              Opacity="0" Focusable="False" AutomationProperties.Name="Scroll up"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Focusable="False" AutomationProperties.Name="Scroll position">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border x:Name="ThumbBd"
                                                    CornerRadius="3"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Opacity="0.35"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBd" Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbBd" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="ThumbBd" Property="Opacity" Value="0.2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand"
                                              Opacity="0" Focusable="False" AutomationProperties.Name="Scroll down"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>