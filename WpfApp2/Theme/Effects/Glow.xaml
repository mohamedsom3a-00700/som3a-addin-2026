<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DropShadowEffect x:Key="Glow.Focus"
        BlurRadius="10" ShadowDepth="0"
        Color="{DynamicResource AccentColorValue}" Opacity="0.35"/>

    <DropShadowEffect x:Key="Glow.ButtonHover"
        BlurRadius="8" ShadowDepth="0"
        Color="{DynamicResource AccentColorValue}" Opacity="0.3"/>

    <DropShadowEffect x:Key="Glow.Primary"
        BlurRadius="12" ShadowDepth="0"
        Color="{DynamicResource AccentColorValue}" Opacity="0.4"/>

    <DropShadowEffect x:Key="Glow.Selection"
        BlurRadius="6" ShadowDepth="0"
        Color="{DynamicResource AccentColorValue}" Opacity="0.5"/>

    <DropShadowEffect x:Key="Glow.Accent"
        BlurRadius="8" ShadowDepth="0"
        Color="{DynamicResource AccentColorValue}" Opacity="0.4"/>

    <DropShadowEffect x:Key="Glow.ThemeCard.Selected"
        BlurRadius="14" ShadowDepth="0"
        Color="{DynamicResource AccentColorValue}" Opacity="0.45"/>

    <!-- ============================================
         BRAND GLOW EFFECTS (Planova Platform)
         Cyan and orange accent glows for rebranding
         ============================================ -->
    <DropShadowEffect x:Key="Glow.Brand.Cyan"
        BlurRadius="16" ShadowDepth="0"
        Color="#00D1FF" Opacity="0.5"/>

    <DropShadowEffect x:Key="Glow.Brand.Cyan.Intense"
        BlurRadius="24" ShadowDepth="0"
        Color="#00D1FF" Opacity="0.7"/>

    <DropShadowEffect x:Key="Glow.Brand.Orange"
        BlurRadius="16" ShadowDepth="0"
        Color="#FF8A3D" Opacity="0.5"/>

    <DropShadowEffect x:Key="Glow.Brand.Orange.Intense"
        BlurRadius="24" ShadowDepth="0"
        Color="#FF8A3D" Opacity="0.7"/>

    <DropShadowEffect x:Key="Glow.Brand.Blueprint"
        BlurRadius="20" ShadowDepth="0"
        Color="#00D1FF" Opacity="0.35"/>

    <DropShadowEffect x:Key="Glow.Splash.Text"
        BlurRadius="20" ShadowDepth="0"
        Color="{DynamicResource AccentColorValue}" Opacity="0.6"/>

</ResourceDictionary>