<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <CubicEase x:Key="AnimEase" EasingMode="EaseOut"/>
    <CubicEase x:Key="AnimEaseIn" EasingMode="EaseIn"/>

    <Storyboard x:Key="HoverEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="1" Duration="0:0:0.15"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

    <Storyboard x:Key="HoverExit">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="0.85" Duration="0:0:0.15"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

    <Storyboard x:Key="FocusEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="1" Duration="0:0:0.1"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

    <Storyboard x:Key="FocusExit">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="0.85" Duration="0:0:0.1"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

    <Storyboard x:Key="PopupOpen">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="1" Duration="0:0:0.15"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

    <Storyboard x:Key="PopupClose">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="0" Duration="0:0:0.1"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

    <Storyboard x:Key="FadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="1" Duration="0:0:0.2"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

    <Storyboard x:Key="FadeOut">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
            To="0" Duration="0:0:0.15"
            EasingFunction="{StaticResource AnimEase}"/>
    </Storyboard>

</ResourceDictionary>