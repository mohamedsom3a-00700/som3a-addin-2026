<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- MaterialDesign theme is loaded dynamically by ThemeManager.ApplyTheme() -->
    <ResourceDictionary.MergedDictionaries/>
    <DynamicResource x:Key="MaterialDesignBody" ResourceKey="Brush.Text.Primary"/>
    <DynamicResource x:Key="MaterialDesignPaper" ResourceKey="Brush.Background.Primary"/>
    <DynamicResource x:Key="MaterialDesignCardBackground" ResourceKey="Brush.Background.Card"/>
    <DynamicResource x:Key="MaterialDesignTextBoxBorder" ResourceKey="Brush.Control.Stroke"/>

</ResourceDictionary>
