<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         LIGHT THEME SEMANTIC TOKEN OVERRIDES
         ============================================ -->

    <!-- Background -->
    <SolidColorBrush x:Key="Brush.Background.Primary" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Brush.Background.Secondary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Background.Card" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Background.CardSubtle" Color="#0D000000"/>
    <LinearGradientBrush x:Key="Brush.Background.Root" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF0F4F8" Offset="0"/>
        <GradientStop Color="#FFE2E8F0" Offset="1"/>
    </LinearGradientBrush>

    <!-- Text -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#666666"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="White"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="#3A86FF"/>
    <SolidColorBrush x:Key="Brush.Accent.Success" Color="#2ED573"/>
    <SolidColorBrush x:Key="Brush.Accent.Warning" Color="#FFA502"/>
    <SolidColorBrush x:Key="Brush.Accent.Danger" Color="#FF4757"/>
    <SolidColorBrush x:Key="Brush.Accent.Info" Color="#1E90FF"/>
    <LinearGradientBrush x:Key="Brush.Accent.ProgressFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3A86FF" Offset="0"/>
        <GradientStop Color="{DynamicResource AccentColorLight}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Stroke -->
    <SolidColorBrush x:Key="Brush.Stroke.Card" Color="#1A000000"/>
    <SolidColorBrush x:Key="Brush.Stroke.Info" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="Brush.Stroke.Status" Color="#E5E7EB"/>

    <!-- Fill -->
    <SolidColorBrush x:Key="Brush.Fill.Info" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="Brush.Fill.Status" Color="#E5E7EB"/>

    <!-- Control -->
    <SolidColorBrush x:Key="Brush.Control.Background" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="Brush.Control.Stroke" Color="#1A000000"/>
    <SolidColorBrush x:Key="Brush.Control.HoverBackground" Color="#22007ACC"/>
    <SolidColorBrush x:Key="Brush.Control.SelectedBackground" Color="#44007ACC"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBorder" Color="#4C7EFF"/>
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBackground" Color="#E8F0FE"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb" Color="#55000000"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.ThumbHover" Color="#88000000"/>

    <!-- GroupBox -->
    <SolidColorBrush x:Key="Brush.GroupBox.Background" Color="#0D000000"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="Brush.Overlay.Background" Color="#88000000"/>

    <!-- Close Button -->
    <SolidColorBrush x:Key="Brush.CloseButton.HoverBackground" Color="#22FF4757"/>
    <SolidColorBrush x:Key="Brush.CloseButton.PressedBackground" Color="#44FF4757"/>

    <!-- Title Bar -->
    <SolidColorBrush x:Key="Brush.TitleBar.ButtonHover" Color="#15000000"/>
    <SolidColorBrush x:Key="Brush.TitleBar.ButtonPressed" Color="#22000000"/>

    <!-- ListView -->
    <SolidColorBrush x:Key="Brush.ListView.HoverBackground" Color="#15000000"/>
    <SolidColorBrush x:Key="Brush.ListView.SelectedBackground" Color="#22000000"/>
    <SolidColorBrush x:Key="Brush.ListView.ColumnHeaderHover" Color="#1A000000"/>

    <!-- Button (Light overrides) -->
    <SolidColorBrush x:Key="Brush.Button.Background" Color="#33000000"/>
    <SolidColorBrush x:Key="Brush.Button.HoverBackground" Color="#44000000"/>
    <SolidColorBrush x:Key="Brush.Button.PressedBackground" Color="#22000000"/>

    <!-- DataGrid (Light overrides) -->
    <SolidColorBrush x:Key="Brush.DataGrid.AlternatingRow" Color="#0A000000"/>
    <SolidColorBrush x:Key="Brush.DataGrid.HoverRow" Color="#15000000"/>
    <SolidColorBrush x:Key="Brush.DataGrid.SelectedRow" Color="#333A86FF"/>

    <!-- Progress -->
    <SolidColorBrush x:Key="Brush.Progress.Background" Color="#22000000"/>

    <!-- Swatch -->
    <SolidColorBrush x:Key="Brush.Swatch.Stroke" Color="#FFFFFFFF"/>

    <!-- Close Button -->
    <SolidColorBrush x:Key="Brush.CloseButton.HoverBackground" Color="#22FF4757"/>

    <!-- Loading -->
    <SolidColorBrush x:Key="Brush.Loading.Background" Color="#88000000"/>

    <!-- ============================================
         LEGACY FLAT KEYS (Light theme)
         ============================================ -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3A86FF"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextMainBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextSubBrush" Color="#666666"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#2ED573"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFA502"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF4757"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#1E90FF"/>
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#1A000000"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#1A000000"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="White"/>
    <SolidColorBrush x:Key="StrokeInfoBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="StrokeStatusBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="FillInfoBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="FillStatusBrush" Color="#E5E7EB"/>

    <Color x:Key="AccentColorLight">#6688FF</Color>

    <!-- Light theme color overrides for inline violation replacements -->
    <Color x:Key="Color.ScrollBar.Thumb">#55000000</Color>
    <Color x:Key="Color.ScrollBar.ThumbHover">#88000000</Color>
    <Color x:Key="Color.GroupBox.Background">#0D000000</Color>
    <Color x:Key="Color.Overlay.Background">#88000000</Color>
    <Color x:Key="Color.Animation.ThumbFade">#66000000</Color>
    <Color x:Key="Color.Animation.ButtonHoverDanger">#22FF4757</Color>
    <Color x:Key="Color.Background.RootStart.Light">#FFF0F4F8</Color>
    <Color x:Key="Color.Background.RootEnd.Light">#FFE2E8F0</Color>
    <Color x:Key="Color.CloseButton.HoverBackground">#22FF4757</Color>
    <Color x:Key="Color.CloseButton.PressedBackground">#44FF4757</Color>
    <Color x:Key="Color.Loading.Background">#88000000</Color>
    <Color x:Key="Color.TitleBar.ButtonHover">#15000000</Color>
    <Color x:Key="Color.TitleBar.ButtonPressed">#22000000</Color>
    <Color x:Key="Color.ListView.HoverBackground">#15000000</Color>
    <Color x:Key="Color.ListView.SelectedBackground">#22000000</Color>
    <Color x:Key="Color.ColumnHeader.HoverBackground">#1A000000</Color>

</ResourceDictionary>