<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="Font.Arabic.Primary">Cairo</FontFamily>
    <FontFamily x:Key="Font.Arabic.Alternative">IBM Plex Sans Arabic</FontFamily>
    <FontFamily x:Key="Font.Arabic.Fallback">Segoe UI</FontFamily>

    <Style x:Key="Style.Text.Arabic" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Arabic.Primary}"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
    </Style>

    <Style x:Key="Style.Text.Arabic.Body" TargetType="TextBlock" BasedOn="{StaticResource Style.Text.Arabic}">
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="Style.Text.Arabic.Heading" TargetType="TextBlock" BasedOn="{StaticResource Style.Text.Arabic}">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Style.Text.Arabic.SubHeading" TargetType="TextBlock" BasedOn="{StaticResource Style.Text.Arabic}">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
</ResourceDictionary>
