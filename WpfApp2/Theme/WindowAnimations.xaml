<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Easing Functions -->
    <CubicEase x:Key="WindowFadeEase" EasingMode="EaseOut"/>
    <CubicEase x:Key="WindowSlideEase" EasingMode="EaseOut"/>
    <QuadraticEase x:Key="WindowPressEase" EasingMode="EaseOut"/>

    <!-- ===================================================================
         Window Animations
         Duration Limits (FR-009): open ≤ 200ms, close ≤ 150ms
         
         Safe-Mode Gating (FR-005): When RenderModeService.IsSafeModeRequired()
         returns true, ALL animations must be skipped. ModernWindow.OnLoaded()
         and ModernWindow.OnClosing() already gate animations on _useSafeMode.
         Any code consuming these storyboards must also check safe mode before
         calling BeginStoryboard.
         =================================================================== -->

    <!-- Window Fade In Animation (≤200ms) -->
    <Storyboard x:Key="WindowFadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="0:0:0.2"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard> 

    <!-- Window Fade Out Animation (≤150ms) -->
    <Storyboard x:Key="WindowFadeOut">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0"
                         Duration="0:0:0.1"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <!-- Button Hover Animation -->
    <Storyboard x:Key="ButtonHoverEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         To="1" Duration="0:0:0.12"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <Storyboard x:Key="ButtonHoverExit">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         To="0" Duration="0:0:0.1"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <!-- Button Press Animation -->
    <Storyboard x:Key="ButtonPressEnter">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="0.97" Duration="0:0:0.05"
                         EasingFunction="{StaticResource WindowPressEase}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="0.97" Duration="0:0:0.05"
                         EasingFunction="{StaticResource WindowPressEase}"/>
    </Storyboard>

    <Storyboard x:Key="ButtonPressExit">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1" Duration="0:0:0.08"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1" Duration="0:0:0.08"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <!-- Title Bar Button Hover Animation -->
    <Storyboard x:Key="TitleBarButtonHoverEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         To="1" Duration="0:0:0.08"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <Storyboard x:Key="TitleBarButtonHoverExit">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         To="0" Duration="0:0:0.06"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <!-- Window Scale Animation (≤200ms) -->
    <Storyboard x:Key="WindowScaleEnter">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         From="0.95" To="1" Duration="0:0:0.2"
                         EasingFunction="{StaticResource WindowSlideEase}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         From="0.95" To="1" Duration="0:0:0.2"
                         EasingFunction="{StaticResource WindowSlideEase}"/>
    </Storyboard>

    <!-- Close Button Hover Animation -->
    <Storyboard x:Key="CloseButtonHoverEnter">
        <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                        To="{DynamicResource Color.CloseButton.HoverBackground}" Duration="0:0:0.1"
                        EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <Storyboard x:Key="CloseButtonHoverExit">
        <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                        To="Transparent" Duration="0:0:0.08"
                        EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <!-- Focus Enter Animation -->
    <Storyboard x:Key="FocusEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="0.35" Duration="0:0:0.15"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

    <!-- Focus Exit Animation -->
    <Storyboard x:Key="FocusExit">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.35" To="0" Duration="0:0:0.1"
                         EasingFunction="{StaticResource WindowFadeEase}"/>
    </Storyboard>

</ResourceDictionary>