<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         CUSTOM THEME SEMANTIC TOKEN OVERRIDES
         Base: Dark theme structure
         Accent: Swappable via Brush.Accent.Primary
         ============================================ -->

    <!-- Background (Dark base) -->
    <SolidColorBrush x:Key="Brush.Background.Primary" Color="#0E1720"/>
    <SolidColorBrush x:Key="Brush.Background.Secondary" Color="#1C2B3A"/>
    <SolidColorBrush x:Key="Brush.Background.Card" Color="#15202B"/>
    <SolidColorBrush x:Key="Brush.Background.CardSubtle" Color="#10FFFFFF"/>
    <LinearGradientBrush x:Key="Brush.Background.Root" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF102A43" Offset="0"/>
        <GradientStop Color="#FF0F3B3B" Offset="1"/>
    </LinearGradientBrush>

    <!-- Text (Dark base) -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#BFFFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="White"/>

    <!-- Accent (swappable via Brush.Accent.Primary) -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{DynamicResource AccentColorValue}"/>
    <SolidColorBrush x:Key="Brush.Accent.Success" Color="#2ED573"/>
    <SolidColorBrush x:Key="Brush.Accent.Warning" Color="#FFA502"/>
    <SolidColorBrush x:Key="Brush.Accent.Danger" Color="#FF4757"/>
    <SolidColorBrush x:Key="Brush.Accent.Info" Color="#1E90FF"/>
    <LinearGradientBrush x:Key="Brush.Accent.ProgressFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{DynamicResource AccentColorValue}" Offset="0"/>
        <GradientStop Color="{DynamicResource AccentColorLight}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Stroke -->
    <SolidColorBrush x:Key="Brush.Stroke.Card" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Stroke.Info" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Stroke.Status" Color="#1FFFFFFF"/>

    <!-- Fill -->
    <SolidColorBrush x:Key="Brush.Fill.Info" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Fill.Status" Color="#18FFFFFF"/>

    <!-- Control -->
    <SolidColorBrush x:Key="Brush.Control.Background" Color="#330E1720"/>
    <SolidColorBrush x:Key="Brush.Control.Stroke" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Control.HoverBackground" Color="#22007ACC"/>
    <SolidColorBrush x:Key="Brush.Control.SelectedBackground" Color="#44007ACC"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBorder" Color="#4C7EFF"/>
    <SolidColorBrush x:Key="Brush.ComboBox.HoverBackground" Color="#161F2B"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb" Color="#55FFFFFF"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.ThumbHover" Color="#88FFFFFF"/>

    <!-- GroupBox -->
    <SolidColorBrush x:Key="Brush.GroupBox.Background" Color="#14000000"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="Brush.Overlay.Background" Color="#88000000"/>

    <!-- Button (Custom - Dark base) -->
    <SolidColorBrush x:Key="Brush.Button.Background" Color="#2FFFFFFF"/>
    <SolidColorBrush x:Key="Brush.Button.HoverBackground" Color="#3FFFFFFF"/>
    <SolidColorBrush x:Key="Brush.Button.PressedBackground" Color="#22FFFFFF"/>

    <!-- DataGrid (Custom - Dark base) -->
    <SolidColorBrush x:Key="Brush.DataGrid.AlternatingRow" Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="Brush.DataGrid.HoverRow" Color="#15FFFFFF"/>
    <SolidColorBrush x:Key="Brush.DataGrid.SelectedRow" Color="#333A86FF"/>

    <!-- Progress -->
    <SolidColorBrush x:Key="Brush.Progress.Background" Color="#22000000"/>

    <!-- Swatch -->
    <SolidColorBrush x:Key="Brush.Swatch.Stroke" Color="#FFFFFFFF"/>

    <!-- Close Button -->
    <SolidColorBrush x:Key="Brush.CloseButton.HoverBackground" Color="#22FF4757"/>
    <SolidColorBrush x:Key="Brush.CloseButton.PressedBackground" Color="#33FF4757"/>

    <!-- Title Bar -->
    <SolidColorBrush x:Key="Brush.TitleBar.ButtonHover" Color="#15FFFFFF"/>
    <SolidColorBrush x:Key="Brush.TitleBar.ButtonPressed" Color="#22FFFFFF"/>

    <!-- ListView -->
    <SolidColorBrush x:Key="Brush.ListView.HoverBackground" Color="#15FFFFFF"/>
    <SolidColorBrush x:Key="Brush.ListView.SelectedBackground" Color="#40FFFFFF"/>
    <SolidColorBrush x:Key="Brush.ListView.ColumnHeaderHover" Color="#1AFFFFFF"/>

    <!-- Loading -->
    <SolidColorBrush x:Key="Brush.Loading.Background" Color="#88000000"/>

    <!-- ============================================
         LEGACY FLAT KEYS (Custom theme - Dark base)
         ============================================ -->
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColorValue}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0E1720"/>
    <SolidColorBrush x:Key="CardBrush" Color="#15202B"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1C2B3A"/>
    <SolidColorBrush x:Key="TextMainBrush" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="TextSubBrush" Color="#BFFFFFFF"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#2ED573"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFA502"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF4757"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#1E90FF"/>
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="#330E1720"/>
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="White"/>
    <SolidColorBrush x:Key="StrokeInfoBrush" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="StrokeStatusBrush" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="FillInfoBrush" Color="#12FFFFFF"/>
    <SolidColorBrush x:Key="FillStatusBrush" Color="#18FFFFFF"/>

    <!-- ============================================
         ACCENT COLOR SWATCH PRESETS
         ============================================ -->
    <SolidColorBrush x:Key="Swatch.Blue" Color="#3A86FF"/>
    <SolidColorBrush x:Key="Swatch.Green" Color="#2ED573"/>
    <SolidColorBrush x:Key="Swatch.Purple" Color="#A855F7"/>
    <SolidColorBrush x:Key="Swatch.Orange" Color="#FFA502"/>
    <SolidColorBrush x:Key="Swatch.Pink" Color="#EC4899"/>
    <SolidColorBrush x:Key="Swatch.Teal" Color="#14B8A6"/>
    <SolidColorBrush x:Key="Swatch.Red" Color="#EF4444"/>
    <SolidColorBrush x:Key="Swatch.Cyan" Color="#06B6D4"/>

    <!-- Accent color brush (dynamically set by ThemeManager) -->
    <SolidColorBrush x:Key="AccentColorBrush" Color="{DynamicResource AccentColorValue}"/>

    <!-- Accent color value (Color type for glow effects) -->
    <Color x:Key="AccentColorValue">#3A86FF</Color>
    <Color x:Key="AccentColorLight">#6688FF</Color>

    <!-- Custom theme color overrides for inline violation replacements -->
    <Color x:Key="Color.ScrollBar.Thumb">#55FFFFFF</Color>
    <Color x:Key="Color.ScrollBar.ThumbHover">#88FFFFFF</Color>
    <Color x:Key="Color.GroupBox.Background">#14000000</Color>
    <Color x:Key="Color.Overlay.Background">#88000000</Color>
    <Color x:Key="Color.Animation.ThumbFade">#66FFFFFF</Color>
    <Color x:Key="Color.Animation.ButtonHoverDanger">#22FF4757</Color>
    <Color x:Key="Color.CloseButton.HoverBackground">#22FF4757</Color>
    <Color x:Key="Color.CloseButton.PressedBackground">#33FF4757</Color>
    <Color x:Key="Color.Loading.Background">#88000000</Color>
    <Color x:Key="Color.TitleBar.ButtonHover">#15FFFFFF</Color>
    <Color x:Key="Color.TitleBar.ButtonPressed">#22FFFFFF</Color>
    <Color x:Key="Color.ListView.HoverBackground">#15FFFFFF</Color>
    <Color x:Key="Color.ListView.SelectedBackground">#40FFFFFF</Color>
    <Color x:Key="Color.ColumnHeader.HoverBackground">#1AFFFFFF</Color>

</ResourceDictionary>