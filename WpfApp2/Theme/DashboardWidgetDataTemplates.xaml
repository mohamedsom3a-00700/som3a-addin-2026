<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dashboard="clr-namespace:Som3a_WPF_UI.ViewModels.Dashboard"
    xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls">

    <DataTemplate DataType="{x:Type dashboard:VersionWidgetViewModel}">
        <StackPanel>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text="App: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding AppVersion, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text=".NET: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding DotNetVersion, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13">
                <Run Text="OS: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding OsVersion, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:UpdatesWidgetViewModel}">
        <StackPanel>
            <TextBlock Foreground="{DynamicResource Brush.Accent.Primary}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8">
                <Run Text="v"/>
                <Run Text="{Binding Version, Mode=OneWay}"/>
            </TextBlock>
            <ItemsControl ItemsSource="{Binding Changes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:RecentToolsWidgetViewModel}">
        <ItemsControl ItemsSource="{Binding RecentTools}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding DisplayName}"
                            Command="{Binding DataContext.NavigateToToolCommand, RelativeSource={RelativeSource AncestorType=controls:WidgetCard}}"
                            CommandParameter="{Binding ToolId}"

                            HorizontalContentAlignment="Left"
                            Foreground="{DynamicResource Brush.Text.Primary}"
                            Padding="4,2"
                            Margin="0,0,0,2"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:RecentProjectsWidgetViewModel}">
        <ItemsControl ItemsSource="{Binding RecentProjects}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13"/>
                        <TextBlock Text="{Binding FilePath}" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:DiagnosticsSummaryWidgetViewModel}">
        <StackPanel>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text="Render: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding RenderMode, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text="Theme: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding ActiveTheme, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text="Memory: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding MemoryUsageMB, StringFormat='{}{0:F1} MB', Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13">
                <Run Text="GPU: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding GpuAvailable, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:AIProviderStatusWidgetViewModel}">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource Brush.Accent.Danger}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHostRunning}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource Brush.Accent.Success}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13"/>
            </StackPanel>
            <Button Content="Configure AI Settings"
                    Command="{Binding NavigateToSettingsCommand}"
                    Style="{DynamicResource GhostButton}"
                    HorizontalContentAlignment="Left"
                    Foreground="{DynamicResource Brush.Accent.Primary}"
                    Padding="4,2"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:PerformanceSummaryWidgetViewModel}">
        <StackPanel>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text="Startup: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding StartupTimeMs, StringFormat='{}{0:F0} ms', Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text="Last Nav: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding LastNavigationTimeMs, StringFormat='{}{0:F0} ms', Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12"
                       Text="{Binding LastNavigationTarget}" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:QuickActionsWidgetViewModel}">
        <StackPanel>
            <Button Content="WBS Generator"
                    Command="{Binding NavigateToWBSCommand}"
                    Style="{DynamicResource GhostButton}"
                    HorizontalContentAlignment="Left"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Padding="4,4"
                    Margin="0,0,0,4"/>
            <Button Content="BOQ Activity Generator"
                    Command="{Binding NavigateToBOQCommand}"
                    Style="{DynamicResource GhostButton}"
                    HorizontalContentAlignment="Left"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Padding="4,4"
                    Margin="0,0,0,4"/>
            <Button Content="Settings"
                    Command="{Binding NavigateToSettingsCommand}"
                    Style="{DynamicResource GhostButton}"
                    HorizontalContentAlignment="Left"
                    Foreground="{DynamicResource Brush.Text.Primary}"
                    Padding="4,4"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="{x:Type dashboard:PluginStatusWidgetViewModel}">
        <StackPanel>
            <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13" Margin="0,0,0,4">
                <Run Text="Total: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource Brush.Accent.Success}" FontSize="13" Margin="0,0,0,4">
                <Run Text="Active: "/>
                <Run Text="{Binding ActiveCount, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock FontSize="13" Margin="0,0,0,4">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FailedCount, Converter={StaticResource IntGreaterThanZeroConverter}}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Danger}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="Failed: "/>
                <Run Text="{Binding FailedCount, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Text="{Binding HealthStatus}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HealthStatus}" Value="Healthy">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Success}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HealthStatus}" Value="Unhealthy">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Danger}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HealthStatus}" Value="Degraded">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Warning}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
