<UserControl x:Class="Som3a_WPF_UI.Views.DiagnosticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Export Section -->
            <Border Style="{DynamicResource PanelSectionStyle}">
                <StackPanel>
                    <TextBlock Text="Settings Export / Import"
                               Style="{DynamicResource SectionHeaderStyle}"/>
                    <TextBlock Text="Export your current settings to a JSON file for backup or transfer to another machine."
                               FontSize="12"
                               Foreground="{DynamicResource TextSubBrush}"
                               Margin="0,0,0,16"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Export Settings"
                                Style="{DynamicResource ActionButtonStyle}"
                                Margin="0,0,12,0"
                                Command="{Binding ExportSettingsCommand}"/>
                        <Button Content="Import Settings"
                                Style="{DynamicResource ActionButtonStyle}"
                                Command="{Binding ImportSettingsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- System Info -->
            <Border Style="{DynamicResource PanelSectionStyle}">
                <StackPanel>
                    <TextBlock Text="System Information"
                               Style="{DynamicResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Application Version"
                                   Style="{DynamicResource SettingLabelStyle}"/>
                        <TextBlock Grid.Column="1"
                                   Text="2026.1.0.0"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1"
                                   Text="Settings Version"
                                   Style="{DynamicResource SettingLabelStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="1.0.0"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2"
                                   Text="Status"
                                   Style="{DynamicResource SettingLabelStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="All settings saved"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
