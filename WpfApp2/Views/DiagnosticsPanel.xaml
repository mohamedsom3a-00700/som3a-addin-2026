<UserControl x:Class="Som3a_WPF_UI.Views.DiagnosticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid SnapsToDevicePixels="True"
          UseLayoutRounding="True">

        <!-- Loading State -->
        <Border Style="{DynamicResource PanelSectionStyle}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Visibility="{Binding DiagnosticsVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                <ProgressBar IsIndeterminate="True"
                             Width="200"
                             Height="4"
                             Margin="10"
                             Foreground="{DynamicResource Brush.Accent.Primary}"
                             SnapsToDevicePixels="True"
                             UseLayoutRounding="True"/>
                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.Capturing]}"
                           FontSize="14"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           HorizontalAlignment="Center"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Style="{DynamicResource PanelSectionStyle}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Visibility="{Binding DiagnosticsVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.Unavailable]}"
                           FontSize="14"
                           Foreground="{DynamicResource Brush.Accent.Danger}"
                           HorizontalAlignment="Center"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"/>
                <TextBlock Text="{Binding DiagnosticsVM.ErrorMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"/>
                <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.Retry]}"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding DiagnosticsVM.RefreshCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"/>
            </StackPanel>
        </Border>



        <!-- Content State (shown when data is available) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding DiagnosticsVM.IsDataAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
        <StackPanel SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

            <!-- Diagnostics Status -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.Heading]}"
                               Style="{DynamicResource SectionHeaderStyle}"/>
                    <TextBlock Text="{Binding DiagnosticsVM.StatusMessage}"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.Refresh]}"
                                Style="{DynamicResource ActionButtonStyle}"
                                Margin="0,0,10,0"
                                Command="{Binding DiagnosticsVM.RefreshCommand}"/>
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.RunValidation]}"
                                Style="{DynamicResource ActionButtonStyle}"
                                Command="{Binding DiagnosticsVM.RunValidationCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Render Mode -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.RenderMode]}"
                               Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.RenderMode}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                               Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.RenderSource]}"
                               Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.RenderModeSource}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2"
                               Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.GpuAvailable]}"
                               Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.GpuAvailable}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- GPU Info -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.GpuName]}"
                               Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.GpuName}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Theme Info -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.ActiveTheme]}"
                               Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.ActiveTheme}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                                Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.AccentColor]}"
                                Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.AccentColor}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="2"
                                Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.FallbackMode]}"
                                Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.IsFallbackMode}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Memory Usage -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.WorkingSet]}"
                               Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.MemoryWorkingSetMB, StringFormat={}{0:F1}, TargetNullValue=N/A}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                                Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.ManagedHeap]}"
                                Style="{DynamicResource SettingLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding DiagnosticsVM.CurrentSnapshot.MemoryManagedMB, StringFormat={}{0:F1}, TargetNullValue=N/A}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Popup Health -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.PopupHealth]}"
                               Style="{DynamicResource SectionHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding DiagnosticsVM.CurrentSnapshot.PopupStatus}"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           FontSize="12"
                                           Margin="0,2,0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Module Diagnostics -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.PluginModules]}"
                               Style="{DynamicResource SectionHeaderStyle}"/>

                    <ItemsControl ItemsSource="{Binding DiagnosticsVM.ModuleSnapshots}"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Background.Card}"
                                        CornerRadius="{DynamicResource SmallRadius}"
                                        Padding="{DynamicResource Padding.Small}"
                                        Margin="0,0,0,6"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Grid SnapsToDevicePixels="True"
                                          UseLayoutRounding="True">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding ModuleId}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding State}"
                                                   Foreground="{DynamicResource Brush.Accent.Success}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Version}"
                                                   Foreground="{DynamicResource Brush.Text.Disabled}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="3"
                                                    Orientation="Horizontal"
                                                    Margin="0,4,0,0"
                                                    SnapsToDevicePixels="True"
                                                    UseLayoutRounding="True">
                                            <TextBlock Text="{Binding MemoryMB, StringFormat={}{0:F1} MB}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontSize="11"
                                                       Margin="0,0,16,0"/>
                                            <TextBlock Text="{Binding LoadTimeMs, StringFormat={}{0}ms load time}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Validation Results -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.ValidationResults]}"
                               Style="{DynamicResource SectionHeaderStyle}"/>

                    <DataGrid ItemsSource="{Binding DiagnosticsVM.ValidationResults}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              EnableRowVirtualization="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              MaxHeight="200"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsValidationGrid.Severity]}" Binding="{Binding Severity}" Width="70"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsValidationGrid.Category]}" Binding="{Binding Category}" Width="100"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsValidationGrid.Dictionary]}" Binding="{Binding DictionaryName}" Width="120"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsValidationGrid.Location]}" Binding="{Binding Location}" Width="120"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsValidationGrid.Description]}" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsValidationGrid.Fix]}" Binding="{Binding SuggestedFix}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Log Viewer -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <Grid SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.ApplicationLogs]}"
                                   Style="{DynamicResource SectionHeaderStyle}"/>

                        <ToggleButton Grid.Column="1"
                                      Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.ViewLogs]}"
                                      IsChecked="{Binding DiagnosticsVM.IsLogViewVisible}"
                                      Style="{DynamicResource ActionButtonStyle}"
                                      Margin="0,0,0,8"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding DiagnosticsVM.RecentLogs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              EnableRowVirtualization="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              MaxHeight="200"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                        <DataGrid.Style>
                            <Style TargetType="DataGrid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiagnosticsVM.IsLogViewVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsLogGrid.Time]}" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="70"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsLogGrid.Severity]}" Binding="{Binding Severity}" Width="70"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsLogGrid.Source]}" Binding="{Binding Source}" Width="100"/>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsLogGrid.Message]}" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Export / Import (existing) -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.SettingsExportImport]}"
                               Style="{DynamicResource SectionHeaderStyle}"/>
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.SettingsExportHint]}"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               Margin="0,0,0,16"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.ExportSettings]}"
                                Style="{DynamicResource ActionButtonStyle}"
                                Margin="0,0,12,0"
                                Command="{Binding ExportSettingsCommand}"/>
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPanel.ImportSettings]}"
                                Style="{DynamicResource ActionButtonStyle}"
                                Command="{Binding ImportSettingsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Grid>
</UserControl>
