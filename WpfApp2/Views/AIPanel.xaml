<UserControl x:Class="Som3a_WPF_UI.Views.AIPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <ResourceDictionary/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
        <StackPanel SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

            <!-- AI Enable/Disable -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.AiFeatures]}"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <CheckBox Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.EnableAiGeneration]}"
                              IsChecked="{Binding IsAIEnabled, Mode=TwoWay}"
                              Foreground="{DynamicResource TextMainBrush}"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable AI generation"/>
                </StackPanel>
            </Border>

            <!-- Local Provider Detection Status -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.LocalAiDetection]}"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <StackPanel Margin="0,0,0,12"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <!-- Scanning indicator -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsDetectionScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,0,0,4">
                            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.ScanningForProviders]}"
                                       Foreground="{DynamicResource TextMainBrush}"
                                       FontSize="13"/>
                        </StackPanel>

                        <!-- Detection status -->
                        <TextBlock Text="{Binding DetectionStatusText}"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="13"
                                   Margin="0,0,0,4"
                                   Visibility="{Binding IsDetectionScanning, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <!-- Local provider selector (when multiple detected) -->
                        <StackPanel Visibility="{Binding ShowLocalProviderSelector, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,8,0,0">
                            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.SelectLocalProvider]}"
                                       Foreground="{DynamicResource TextMainBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DetectedLocalProviders}"
                                      SelectedItem="{Binding SelectedLocalProvider, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Width="400"
                                      HorizontalAlignment="Left"
                                      Height="32"/>
                        </StackPanel>

                        <!-- No API key warning -->
                        <Border Background="{DynamicResource WarningBannerBackground}"
                                BorderBrush="{DynamicResource WarningBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,6"
                                Margin="0,8,0,0"
                                Visibility="{Binding ShowApiKeyWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.NoApiKey]}"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           FontSize="13"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.UsingLocalAutomatically]}"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
<Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.UseLocalAi]}"
                                         Command="{Binding SwitchToLocalAICommand}"
                                        Width="200"
                                        Height="32"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Cloud AI Settings (visible when Cloud is effective provider) -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Visibility="{Binding IsCloudSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.CloudAiConfig]}"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <StackPanel Margin="0,0,0,12"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.ApiKey]}"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="13"
                                   Margin="0,0,0,4"/>
                        <PasswordBox x:Name="ApiKeyBox"
                                     PasswordChar="*"
                                     Width="400"
                                     HorizontalAlignment="Left"
                                     Height="32"
                                     AutomationProperties.Name="AI API Key"
                                     PasswordChanged="OnApiKeyChanged"/>
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.ApiKeyHint]}"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>

                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.MainModel]}"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="13"
                                   Margin="0,12,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      Text="{Binding AICloudMainModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding AvailableModels}"
                                      IsEditable="True"
                                      Width="400"
                                      HorizontalAlignment="Left"
                                      Height="32"
                                      AutomationProperties.Name="AI Main Model"/>
                            <Button Grid.Column="1" Content="⟳" Width="32" Height="32"
                                    Command="{Binding RefreshModelsCommand}"
                                    ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.RefreshModelsTooltip]}"
                                    Margin="4,0,0,0"/>
                        </Grid>

                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.FallbackModel]}"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="13"
                                   Margin="0,12,0,4"/>
                        <ComboBox Text="{Binding AICloudSubModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AvailableModels}"
                                  IsEditable="True"
                                  Width="400"
                                  HorizontalAlignment="Left"
                                  Height="32"
                                  AutomationProperties.Name="AI Fallback Model"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Local AI Settings (visible when Local is effective) -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Visibility="{Binding IsOllamaSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.LocalAiConfig]}"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <StackPanel Margin="0,0,0,12"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.EndpointUrl]}"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="13"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding AIOllamaEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="400"
                                 HorizontalAlignment="Left"
                                 Height="32"
                                 IsReadOnly="True"
                                 AutomationProperties.Name="Local AI Endpoint URL"/>

                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.LocalModel]}"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="13"
                                   Margin="0,12,0,4"/>
                        <ComboBox Text="{Binding AIOllamaModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AvailableLocalModels}"
                                  IsEditable="True"
                                  Width="400"
                                  HorizontalAlignment="Left"
                                  Height="32"
                                  AutomationProperties.Name="Local AI Model"/>

                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[AIPanel.LocalFallbackModel]}"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="13"
                                   Margin="0,12,0,4"/>
                        <ComboBox Text="{Binding AIOllamaSubModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AvailableLocalModels}"
                                  IsEditable="True"
                                  Width="400"
                                  HorizontalAlignment="Left"
                                  Height="32"
                                  AutomationProperties.Name="Local AI Fallback Model"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
