<UserControl x:Class="Som3a_WPF_UI.Views.AppearancePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <ResourceDictionary/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
        <StackPanel SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

            <!-- Theme Cards Section -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Theme"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">

                        <ToggleButton Width="{DynamicResource Component.ThemeCard.Width}"
                                      Height="{DynamicResource Component.ThemeCard.Height}"
                                      Margin="0,0,16,0"
                                      Tag="Dark"
                                      Command="{Binding ThemeCardCommand}"
                                      CommandParameter="Dark"
                                      IsChecked="{Binding IsDarkSelected, Mode=OneWay}"
                                      Style="{DynamicResource ThemeCardToggleStyle}"
                                      AutomationProperties.Name="Dark Theme Card"
                                      SnapsToDevicePixels="True"
                                      UseLayoutRounding="True">
                            <Grid SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                                <Border CornerRadius="{DynamicResource MediumRadius}"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource Color.Background.RootStart}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource Color.Background.RootEnd}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border VerticalAlignment="Bottom" Height="6" Background="{DynamicResource Brush.Accent.Primary}"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True"/>
                                <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10"
                                            SnapsToDevicePixels="True"
                                            UseLayoutRounding="True">
                                    <TextBlock Text="Dark" Foreground="{DynamicResource Brush.Text.Primary}" FontWeight="SemiBold" FontSize="13"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"/>
                                    <TextBlock Text="Full dark theme" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="10"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"/>
                                </StackPanel>
                            </Grid>
                        </ToggleButton>

                        <ToggleButton Width="{DynamicResource Component.ThemeCard.Width}"
                                      Height="{DynamicResource Component.ThemeCard.Height}"
                                      Margin="0,0,16,0"
                                      Tag="Light"
                                      Command="{Binding ThemeCardCommand}"
                                      CommandParameter="Light"
                                      IsChecked="{Binding IsLightSelected, Mode=OneWay}"
                                      Style="{DynamicResource ThemeCardToggleStyle}"
                                      AutomationProperties.Name="Light Theme Card"
                                      SnapsToDevicePixels="True"
                                      UseLayoutRounding="True">
                            <Grid SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                                <Border CornerRadius="{DynamicResource MediumRadius}"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource Color.Background.RootStart.Light}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource Color.Background.RootEnd.Light}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border VerticalAlignment="Bottom" Height="6" Background="{DynamicResource Brush.Accent.Primary}"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True"/>
                                <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10"
                                            SnapsToDevicePixels="True"
                                            UseLayoutRounding="True">
                                    <TextBlock Text="Light" Foreground="{DynamicResource Brush.Text.Primary}" FontWeight="SemiBold" FontSize="13"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"/>
                                    <TextBlock Text="Clean light theme" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="10"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"/>
                                </StackPanel>
                            </Grid>
                        </ToggleButton>

                        <ToggleButton Width="{DynamicResource Component.ThemeCard.Width}"
                                      Height="{DynamicResource Component.ThemeCard.Height}"
                                      Tag="Custom"
                                      Command="{Binding ThemeCardCommand}"
                                      CommandParameter="Custom"
                                      IsChecked="{Binding IsCustomSelected, Mode=OneWay}"
                                      Style="{DynamicResource ThemeCardToggleStyle}"
                                      AutomationProperties.Name="Custom Theme Card"
                                      SnapsToDevicePixels="True"
                                      UseLayoutRounding="True">
                            <Grid SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                                <Border CornerRadius="{DynamicResource MediumRadius}"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource Color.Background.RootStart}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource Color.Background.RootEnd}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border VerticalAlignment="Bottom" Height="6"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{DynamicResource AccentColorValue}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource AccentColorLight}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10"
                                            SnapsToDevicePixels="True"
                                            UseLayoutRounding="True">
                                    <TextBlock Text="Custom" Foreground="{DynamicResource Brush.Text.Primary}" FontWeight="SemiBold" FontSize="13"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"/>
                                    <TextBlock Text="Your accent color" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="10"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"/>
                                </StackPanel>
                            </Grid>
                        </ToggleButton>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Accent Swatches -->
            <Border SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PanelSectionStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccentSwatchesVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Accent Color"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                    <ItemsControl Grid.Column="1"
                                  ItemsSource="{Binding AccentSwatches}"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            SnapsToDevicePixels="True"
                                            UseLayoutRounding="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.AccentSwatchCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding Hex}"
                                        ToolTip="{Binding Name}"
                                        Focusable="True"
                                        FocusVisualStyle="{DynamicResource FocusVisualStyle}"
                                        AutomationProperties.Name="{Binding AutomationName}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="0,0,10,0"
                                        Width="26"
                                        Height="26"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid SnapsToDevicePixels="True"
                                                  UseLayoutRounding="True">
                                                <Ellipse Fill="{Binding Brush}"
                                                         Width="22" Height="22"
                                                         Stroke="{DynamicResource Brush.Control.Stroke}"
                                                         StrokeThickness="1"
                                                         SnapsToDevicePixels="True"
                                                         UseLayoutRounding="True"/>
                                                <Border Width="26" Height="26"
                                                        CornerRadius="13"
                                                         BorderBrush="{DynamicResource Brush.Accent.Primary}"
                                                        BorderThickness="2"
                                                        Opacity="0"
                                                        SnapsToDevicePixels="True"
                                                        UseLayoutRounding="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Color Wheel and Hex Input -->
            <Border SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PanelSectionStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccentSwatchesVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Color Wheel"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <controls:ColorWheel x:Name="AccentColorWheel"
                                             Width="180" Height="180"
                                             SelectedColor="{Binding SelectedCustomColor, Mode=TwoWay}"
                                             SnapsToDevicePixels="True"
                                             UseLayoutRounding="True"/>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Hex Color" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12"/>
                            <TextBox Text="{Binding HexColorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100"
                                     FontSize="14"
                                     Margin="0,4,0,12"
                                     Style="{DynamicResource DefaultTextBoxStyle}"/>
                            <TextBlock Text="Preview" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12"/>
                            <Border Width="40" Height="40" CornerRadius="4"
                                    Background="{Binding AccentPreviewBrush}"
                                    Margin="0,4"
                                    BorderBrush="{DynamicResource Brush.Control.Stroke}"
                                    BorderThickness="1"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Accent Variant Swatches -->
            <Border SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PanelSectionStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccentSwatchesVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Variants"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <ItemsControl Grid.Column="1"
                                  ItemsSource="{Binding AccentVariants}"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            SnapsToDevicePixels="True"
                                            UseLayoutRounding="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,12,0">
                                    <Border Width="28" Height="28"
                                            CornerRadius="14"
                                            Background="{Binding Brush}"
                                            BorderBrush="{DynamicResource Brush.Control.Stroke}"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True"
                                            UseLayoutRounding="True"/>
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="9"
                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Background Image & Blur Section -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Background Image"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    <StackPanel Grid.Column="1" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Choose Image..."
                                    Width="100" Height="28"
                                    Style="{DynamicResource PrimaryButton}"
                                    Command="{Binding SelectImageCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Clear"
                                    Width="60" Height="28"
                                    Style="{DynamicResource GhostButton}"
                                    Command="{Binding ClearImageCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ImageFileName}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="11" Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding ImageValidationError}"
                                   Foreground="{DynamicResource Brush.Accent.Danger}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Custom Base Theme -->
            <Border SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PanelSectionStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccentSwatchesVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Base Theme"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <RadioButton Content="Dark" GroupName="CustomBaseTheme" Margin="0,0,20,0"
                                     IsChecked="{Binding CustomBaseIsDark}"
                                     Command="{Binding CustomBaseThemeCommand}"
                                     CommandParameter="Dark"
                                     Foreground="{DynamicResource Brush.Text.Primary}"/>
                        <RadioButton Content="Light" GroupName="CustomBaseTheme"
                                     IsChecked="{Binding CustomBaseIsLight}"
                                     Command="{Binding CustomBaseThemeCommand}"
                                     CommandParameter="Light"
                                     Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Wallpaper Gallery -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <TextBlock Text="Wallpapers"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding WallpaperImages}"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,8,8" Padding="0"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource Brush.Stroke.Card}"
                                        Background="{DynamicResource Brush.Background.Card}"
                                        Command="{Binding DataContext.SetWallpaperImageCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding ImagePath}"
                                        Width="120" Height="72" Cursor="Hand"
                                        Focusable="True"
                                        SnapsToDevicePixels="True" UseLayoutRounding="True">
                                    <Image Source="{Binding Thumbnail}"
                                           Stretch="UniformToFill"
                                           Width="120" Height="72"
                                           SnapsToDevicePixels="True"
                                           UseLayoutRounding="True"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Blur Controls -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Blur Intensity"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    <StackPanel Grid.Column="1" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="BlurSlider"
                                    Minimum="0" Maximum="100"
                                    Value="{Binding BlurIntensityPercent, Mode=TwoWay}"
                                    Width="180" VerticalAlignment="Center"
                                    TickFrequency="1" SmallChange="1" LargeChange="10"/>
                            <TextBlock Text="{Binding BlurIntensityPercent, StringFormat={}{0:F0}%}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       VerticalAlignment="Center" Margin="8,0" Width="40"/>
                        </StackPanel>
                        <CheckBox Content="Enable Blur"
                                  IsChecked="{Binding BlurEnabled}"
                                  Margin="0,4,0,0"
                                  Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Font Selection -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Font Family"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    <ListBox Grid.Column="1"
                             x:Name="FontList"
                             ItemsSource="{Binding AvailableFonts}"
                             SelectedItem="{Binding SelectedFont}"
                             MaxHeight="120"
                             Background="{DynamicResource Brush.Background.Card}"
                             Foreground="{DynamicResource Brush.Text.Primary}"
                             BorderBrush="{DynamicResource Brush.Stroke.Card}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding FamilyName}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text.Primary}"
                                               FontFamily="{Binding FontFamily}"
                                               FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Background Style -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Background Style"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <RadioButton Content="Solid"
                                     GroupName="BgStyle"
                                     Margin="0,0,20,0"
                                     IsChecked="{Binding BackgroundSolid, Mode=OneWay}"
                                     Command="{Binding BackgroundStyleCommand}"
                                     CommandParameter="Solid"
                                     Foreground="{DynamicResource Brush.Text.Primary}"
                                     AutomationProperties.Name="Solid Background Style"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"/>
                        <RadioButton Content="Gradient"
                                     GroupName="BgStyle"
                                     IsChecked="{Binding BackgroundGradient, Mode=OneWay}"
                                     Command="{Binding BackgroundStyleCommand}"
                                     CommandParameter="Gradient"
                                     Foreground="{DynamicResource Brush.Text.Primary}"
                                     AutomationProperties.Name="Gradient Background Style"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Live Preview Area -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="Preview"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                <Border x:Name="PreviewArea"
                        Height="160"
                        CornerRadius="{DynamicResource MediumRadius}"
                        Background="{DynamicResource Brush.Background.Card}"
                        BorderBrush="{DynamicResource Brush.Stroke.Card}"
                        BorderThickness="1"
                        Padding="16"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <Grid SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Theme Preview"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True">
                            <TextBlock Text="Sample Heading" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"/>
                            <TextBlock Text="Sample body text for preview purposes"
                                       FontSize="12"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       Margin="0,8,0,0"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"/>
                            <Border Width="80"
                                    Height="6"
                                    CornerRadius="3"
                                    Background="{DynamicResource Brush.Accent.Primary}"
                                    Margin="0,12,0,0"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True"/>
                        </StackPanel>
                    </Grid>
                </Border>
                </StackPanel>
            </Border>

            <!-- Apply / Cancel -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <Button Content="Apply"
                            Width="120"
                            Height="34"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding ApplyThemeCommand}"
                            Margin="0,0,10,0"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True"/>
                    <Button Content="Cancel"
                            Width="120"
                            Height="34"
                            Style="{DynamicResource GhostButton}"
                            Command="{Binding CancelPreviewCommand}"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
