<controls:ModernWindow x:Class="Som3a_WPF_UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        Title="Settings"
        Height="620"
        Width="942"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <controls:ModernWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/AccentSwatchStyles.xaml"/>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/SettingsPanelStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Sidebar Full Template (labels visible) -->
            <DataTemplate x:Key="SidebarFullTemplate">
                <Grid ToolTip="{Binding DisplayName}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Icon}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DisplayName}"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>

            <!-- Sidebar Icon Template (collapsed, only icons with tooltips) -->
            <DataTemplate x:Key="SidebarIconTemplate">
                <Grid HorizontalAlignment="Center"
                      ToolTip="{Binding DisplayName}">
                    <TextBlock Text="{Binding Icon}"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </controls:ModernWindow.Resources>

    <!-- ROOT -->
    <Border CornerRadius="{DynamicResource WindowRadius}"
            Background="{DynamicResource Brush.Background.Root}"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <Grid Margin="{DynamicResource Padding.Medium}">

            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Settings"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="{DynamicResource SubHeaderFontSize}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1"
                  Margin="8,14,8,14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border x:Name="SidebarPanel"
                        Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource LargeRadius}"
                        Margin="0,0,14,0">

                    <Grid Margin="{DynamicResource Padding.Medium}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Categories"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <ListBox x:Name="SidebarList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Categories}"
                                 SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                 Style="{DynamicResource SidebarListBoxStyle}"
                                 AutomationProperties.Name="Settings Categories"
                                 KeyboardNavigation.TabNavigation="Local"
                                 ItemTemplate="{StaticResource SidebarFullTemplate}"/>

                    </Grid>

                </Border>

                <!-- MAIN PANEL -->
                <Border Grid.Column="1"
                        Style="{DynamicResource PanelContainerStyle}">

                    <ContentControl Content="{Binding CurrentPanel}"
                                    AutomationProperties.Name="Settings Panel Content"/>

                </Border>

            </Grid>

            <!-- FOOTER -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Som3a Add-in Settings"
                           Foreground="{DynamicResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="120"
                        Height="34"
                        Content="Save"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding SaveCommand}"/>

                <Button Grid.Column="3"
                        Width="120"
                        Height="34"
                        Content="Cancel"
                        Style="{DynamicResource GhostButton}"
                        Command="{Binding CancelCommand}"/>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>
