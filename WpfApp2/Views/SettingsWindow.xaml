<controls:ModernWindow x:Class="Som3a_WPF_UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        Title="Settings"
        Height="620"
        Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <controls:ModernWindow.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ThemeResources.xaml"/>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Effects/Shadows.xaml"/>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Effects/Glow.xaml"/>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/ThemeCardStyles.xaml"/>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/AccentSwatchStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Accent Swatches (non-selected) -->
            <Style x:Key="BlueSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Blue}"/>
                <Setter Property="Tag" Value="#3A86FF"/>
            </Style>
            <Style x:Key="GreenSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Green}"/>
                <Setter Property="Tag" Value="#2ED573"/>
            </Style>
            <Style x:Key="PurpleSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Purple}"/>
                <Setter Property="Tag" Value="#A855F7"/>
            </Style>
            <Style x:Key="OrangeSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Orange}"/>
                <Setter Property="Tag" Value="#FFA502"/>
            </Style>
            <Style x:Key="PinkSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Pink}"/>
                <Setter Property="Tag" Value="#EC4899"/>
            </Style>
            <Style x:Key="TealSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Teal}"/>
                <Setter Property="Tag" Value="#14B8A6"/>
            </Style>
            <Style x:Key="RedSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Red}"/>
                <Setter Property="Tag" Value="#EF4444"/>
            </Style>
            <Style x:Key="CyanSwatch" TargetType="{x:Type Ellipse}" BasedOn="{StaticResource AccentSwatchInteractive}">
                <Setter Property="Fill" Value="{DynamicResource Swatch.Cyan}"/>
                <Setter Property="Tag" Value="#06B6D4"/>
            </Style>

        </ResourceDictionary>

    </controls:ModernWindow.Resources>

    <!-- ROOT -->
    <Border CornerRadius="18"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <Border.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#FF102A43"
                              Offset="0"/>
                <GradientStop Color="#FF0F3B3B"
                              Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="14">

            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Settings"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1"
                  Margin="8,14,8,14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Margin="0,0,14,0">

                    <StackPanel Margin="12">

                        <TextBlock Text="Categories"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <Button Content="General"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource PrimaryButton}"/>

                        <Button Content="Appearance"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                        <Button Content="Excel"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                        <Button Content="Primavera"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                    </StackPanel>

                </Border>

                <!-- MAIN -->
                <Border Grid.Column="1"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="18">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <!-- GENERAL -->
                            <TextBlock Text="General Settings"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSubBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- THEME CARDS -->
                            <Grid Margin="0,0,0,16">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Theme"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource TextSubBrush}"
                                           Margin="0,4,0,0"/>

                                <!-- Theme Cards Panel -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <!-- DARK -->
                                    <ToggleButton x:Name="CardDark"
                                                  Width="140"
                                                  Height="120"
                                                  Margin="0,0,16,0"
                                                  Tag="Dark"
                                                  Click="ThemeCard_Click"
                                                  PreviewKeyDown="ThemeCard_KeyDown"
                                                  Style="{DynamicResource ThemeCardToggleStyle}">
                                        <Grid>
                                            <Border CornerRadius="10,10,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#0E1720" Offset="0"/>
                                                        <GradientStop Color="#1C2B3A" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Height="6" Background="{DynamicResource AccentBrush}"/>
                                            <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10">
                                                <TextBlock Text="Dark" Foreground="{DynamicResource TextMainBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="Full dark theme" Foreground="{DynamicResource TextSubBrush}" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>

                                    <!-- LIGHT -->
                                    <ToggleButton x:Name="CardLight"
                                                  Width="140"
                                                  Height="120"
                                                  Margin="0,0,16,0"
                                                  Tag="Light"
                                                  Click="ThemeCard_Click"
                                                  PreviewKeyDown="ThemeCard_KeyDown"
                                                  Style="{DynamicResource ThemeCardToggleStyle}">
                                        <Grid>
                                            <Border CornerRadius="10,10,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FAFAFA" Offset="0"/>
                                                        <GradientStop Color="#FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Height="6" Background="{DynamicResource AccentBrush}"/>
                                            <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10">
                                                <TextBlock Text="Light" Foreground="#1A1A1A" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="Clean light theme" Foreground="#666666" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>

                                    <!-- CUSTOM -->
                                    <ToggleButton x:Name="CardCustom"
                                                  Width="140"
                                                  Height="120"
                                                  Tag="Custom"
                                                  Click="ThemeCard_Click"
                                                  PreviewKeyDown="ThemeCard_KeyDown"
                                                  Style="{DynamicResource ThemeCardToggleStyle}">
                                        <Grid>
                                            <Border CornerRadius="10,10,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#0E1720" Offset="0"/>
                                                        <GradientStop Color="#1C2B3A" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Height="6">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="{DynamicResource AccentColorValue}" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource AccentColorValue}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10">
                                                <TextBlock Text="Custom" Foreground="{DynamicResource TextMainBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="Your accent color" Foreground="{DynamicResource TextSubBrush}" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>

                                </StackPanel>

                            </Grid>

                            <!-- ACCENT SWATCHES (Custom theme only) -->
                            <Grid x:Name="AccentSwatchesPanel"
                                  Margin="0,0,0,16"
                                  Visibility="Collapsed">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Accent Color"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <Ellipse x:Name="SwatchBlue"
                                             Style="{StaticResource BlueSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             Margin="0,0,10,0"
                                             AutomationProperties.Name="Blue accent"/>
                                    <Ellipse x:Name="SwatchGreen"
                                             Style="{StaticResource GreenSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             Margin="0,0,10,0"
                                             AutomationProperties.Name="Green accent"/>
                                    <Ellipse x:Name="SwatchPurple"
                                             Style="{StaticResource PurpleSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             Margin="0,0,10,0"
                                             AutomationProperties.Name="Purple accent"/>
                                    <Ellipse x:Name="SwatchOrange"
                                             Style="{StaticResource OrangeSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             Margin="0,0,10,0"
                                             AutomationProperties.Name="Orange accent"/>
                                    <Ellipse x:Name="SwatchPink"
                                             Style="{StaticResource PinkSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             Margin="0,0,10,0"
                                             AutomationProperties.Name="Pink accent"/>
                                    <Ellipse x:Name="SwatchTeal"
                                             Style="{StaticResource TealSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             Margin="0,0,10,0"
                                             AutomationProperties.Name="Teal accent"/>
                                    <Ellipse x:Name="SwatchRed"
                                             Style="{StaticResource RedSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             Margin="0,0,10,0"
                                             AutomationProperties.Name="Red accent"/>
                                    <Ellipse x:Name="SwatchCyan"
                                             Style="{StaticResource CyanSwatch}"
                                             MouseLeftButtonDown="AccentSwatch_Click"
                                             PreviewKeyDown="AccentSwatch_KeyDown"
                                             Focusable="True"
                                             AutomationProperties.Name="Cyan accent"/>

                                </StackPanel>

                            </Grid>

                            <!-- FONT SIZE -->
                            <Grid Margin="0,0,0,16">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Font Size"
                                           Foreground="{DynamicResource TextSubBrush}"
                                           VerticalAlignment="Center"/>

                                <Slider Grid.Column="1"
                                        Minimum="10"
                                        Maximum="20"
                                        Value="13"/>

                            </Grid>

                            <!-- CHECKS -->
                            <CheckBox Content="Enable animations"
                                      Foreground="{DynamicResource TextSubBrush}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Enable Excel integration"
                                      Foreground="{DynamicResource TextSubBrush}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Auto-save configuration"
                                      Foreground="{DynamicResource TextSubBrush}"
                                      Margin="0,0,0,10"/>

                        </StackPanel>

                    </ScrollViewer>

                </Border>

            </Grid>

            <!-- FOOTER -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Som3a Add-in Settings"
                           Foreground="{DynamicResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="120"
                        Height="34"
                        Content="Save"
                        Style="{DynamicResource PrimaryButton}"
                        Click="Save_Click"/>

                <Button Grid.Column="3"
                        Width="120"
                        Height="34"
                        Content="Cancel"
                        Style="{DynamicResource GhostButton}"
                        Click="Cancel_Click"/>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>