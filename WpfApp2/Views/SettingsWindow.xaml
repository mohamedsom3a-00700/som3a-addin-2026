<controls:ModernWindow x:Class="Som3a_WPF_UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        Title="Settings"
        Height="620"
        Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <controls:ModernWindow.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ThemeResources.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </controls:ModernWindow.Resources>

    <!-- ROOT -->

    <Border CornerRadius="18"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <Border.Background>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">

                <GradientStop Color="#FF102A43"
                              Offset="0"/>

                <GradientStop Color="#FF0F3B3B"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.Background>

        <Grid Margin="14">

            <Grid.RowDefinitions>

                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <!-- TITLE BAR -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <TextBlock Text="Settings"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- CONTENT -->

            <Grid Grid.Row="1"
                  Margin="8,14,8,14">

                <Grid.ColumnDefinitions>

                    <!-- SIDEBAR -->
                    <ColumnDefinition Width="220"/>

                    <!-- CONTENT -->
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->

                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Margin="0,0,14,0">

                    <StackPanel Margin="12">

                        <TextBlock Text="Categories"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <Button Content="General"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource PrimaryButton}"/>

                        <Button Content="Appearance"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                        <Button Content="Excel"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                        <Button Content="Primavera"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                    </StackPanel>

                </Border>

                <!-- MAIN -->

                <Border Grid.Column="1"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="18">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <!-- GENERAL -->

                            <TextBlock Text="General Settings"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,20"/>

                            <!-- THEME -->

                            <Grid Margin="0,0,0,16">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Theme"
                                           VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="1"
                                          Height="36"
                                          Style="{DynamicResource RoundComboBox}">

                                    <ComboBoxItem Content="Dark"/>
                                    <ComboBoxItem Content="Light"/>
                                    <ComboBoxItem Content="Blue"/>

                                </ComboBox>

                            </Grid>

                            <!-- FONT SIZE -->

                            <Grid Margin="0,0,0,16">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Font Size"
                                           VerticalAlignment="Center"/>

                                <Slider Grid.Column="1"
                                        Minimum="10"
                                        Maximum="20"
                                        Value="13"/>

                            </Grid>

                            <!-- CHECKS -->

                            <CheckBox Content="Enable animations"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Enable Excel integration"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Auto-save configuration"
                                      Margin="0,0,0,10"/>

                        </StackPanel>

                    </ScrollViewer>

                </Border>

            </Grid>

            <!-- FOOTER -->

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <TextBlock Text="Som3a Add-in Settings"
                           Foreground="{DynamicResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="120"
                        Height="34"
                        Content="Save"
                        Style="{DynamicResource PrimaryButton}"/>

                <Button Grid.Column="3"
                        Width="120"
                        Height="34"
                        Content="Cancel"
                        Style="{DynamicResource GhostButton}"/>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>