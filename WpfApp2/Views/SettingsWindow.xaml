<controls:ModernWindow x:Class="Som3a_WPF_UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        Title="Settings"
        Height="620"
        Width="942"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <controls:ModernWindow.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Controls/AccentSwatchStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>



        </ResourceDictionary>

    </controls:ModernWindow.Resources>

    <!-- ROOT -->
    <Border CornerRadius="{DynamicResource WindowRadius}"
            Background="{DynamicResource Brush.Background.Root}"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <Grid Margin="{DynamicResource Padding.Medium}">

            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

<TextBlock Text="Settings"
                            Foreground="{DynamicResource TextMainBrush}"
                            FontSize="{DynamicResource SubHeaderFontSize}"
                            FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1"
                  Margin="8,14,8,14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource LargeRadius}"
                        Margin="0,0,14,0">

                    <StackPanel Margin="{DynamicResource Padding.Medium}">

                        <TextBlock Text="Categories"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <Button Content="General"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource PrimaryButton}"/>

                        <Button Content="Appearance"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                        <Button Content="Excel"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                        <Button Content="Primavera"
                                Height="34"
                                Margin="0,0,0,8"
                                Style="{DynamicResource BaseButton}"/>

                    </StackPanel>

                </Border>

                <!-- MAIN -->
                <Border Grid.Column="1"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource LargeRadius}"
                        Padding="{DynamicResource Padding.XLarge}">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <!-- GENERAL -->
                            <TextBlock Text="General Settings"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSubBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- THEME CARDS -->
                            <Grid Margin="0,0,0,16">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Theme"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource TextSubBrush}"
                                           Margin="0,4,0,0"/>

                                <!-- Theme Cards Panel -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <!-- DARK -->
                                    <ToggleButton Width="{DynamicResource Component.ThemeCard.Width}"
                                                  Height="{DynamicResource Component.ThemeCard.Height}"
                                                  Margin="0,0,16,0"
                                                  Tag="Dark"
                                                  Command="{Binding ThemeCardCommand}"
                                                  CommandParameter="Dark"
                                                   IsChecked="{Binding IsDarkSelected, Mode=OneWay}"
                                                   Style="{DynamicResource ThemeCardToggleStyle}">
                                        <Grid>
                                            <Border CornerRadius="{DynamicResource MediumRadius}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{DynamicResource Color.Background.RootStart}" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource Color.Background.RootEnd}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Height="6" Background="{DynamicResource AccentBrush}"/>
                                            <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10">
                                                <TextBlock Text="Dark" Foreground="{DynamicResource TextMainBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="Full dark theme" Foreground="{DynamicResource TextSubBrush}" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>

                                    <!-- LIGHT -->
                                    <ToggleButton Width="{DynamicResource Component.ThemeCard.Width}"
                                                   Height="{DynamicResource Component.ThemeCard.Height}"
                                                   Margin="0,0,16,0"
                                                   Tag="Light"
                                                   Command="{Binding ThemeCardCommand}"
                                                   CommandParameter="Light"
                                                   IsChecked="{Binding IsLightSelected, Mode=OneWay}"
                                                  Style="{DynamicResource ThemeCardToggleStyle}">
                                        <Grid>
                                            <Border CornerRadius="{DynamicResource MediumRadius}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{DynamicResource Color.Background.RootStart.Light}" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource Color.Background.RootEnd.Light}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Height="6" Background="{DynamicResource AccentBrush}"/>
                                            <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10">
                                                <TextBlock Text="Light" Foreground="{DynamicResource TextMainBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="Clean light theme" Foreground="{DynamicResource TextSubBrush}" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>

                                    <!-- CUSTOM -->
                                    <ToggleButton Width="{DynamicResource Component.ThemeCard.Width}"
                                                  Height="{DynamicResource Component.ThemeCard.Height}"
                                                  Tag="Custom"
                                                  Command="{Binding ThemeCardCommand}"
                                                  CommandParameter="Custom"
                                                   IsChecked="{Binding IsCustomSelected, Mode=OneWay}"
                                                  Style="{DynamicResource ThemeCardToggleStyle}">
                                        <Grid>
                                            <Border CornerRadius="{DynamicResource MediumRadius}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{DynamicResource Color.Background.RootStart}" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource Color.Background.RootEnd}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Height="6">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="{DynamicResource AccentColorValue}" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource AccentColorLight}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10">
                                                <TextBlock Text="Custom" Foreground="{DynamicResource TextMainBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="Your accent color" Foreground="{DynamicResource TextSubBrush}" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </ToggleButton>

                                </StackPanel>

                            </Grid>

                            <!-- ACCENT SWATCHES (Custom theme only) -->
                            <Grid Margin="0,0,0,16">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AccentSwatchesVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Accent Color"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           VerticalAlignment="Center"/>

                                <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding AccentSwatches}"
                                              VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.AccentSwatchCommand, RelativeSource={RelativeSource AncestorType={x:Type controls:ModernWindow}}}"
                                                    CommandParameter="{Binding Hex}"
                                                    ToolTip="{Binding Name}"
                                                    Focusable="True"
                                                    AutomationProperties.Name="{Binding AutomationName}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    Margin="0,0,10,0"
                                                    Width="26"
                                                    Height="26">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Ellipse Fill="{Binding Brush}"
                                                                     Width="22" Height="22"
                                                                     Stroke="{DynamicResource Brush.Control.Stroke}"
                                                                     StrokeThickness="1"/>
                                                            <Border Width="26" Height="26"
                                                                    CornerRadius="13"
                                                                    BorderBrush="{DynamicResource AccentBrush}"
                                                                    BorderThickness="2"
                                                                    Opacity="0">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                <Setter Property="Opacity" Value="1"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>

                            <!-- FONT SIZE -->
                            <Grid Margin="0,0,0,16">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Font Size"
                                           Foreground="{DynamicResource TextSubBrush}"
                                           VerticalAlignment="Center"/>

                                <Slider Grid.Column="1"
                                        Minimum="10"
                                        Maximum="20"
                                        Value="13"/>

                            </Grid>

                            <!-- CHECKS -->
                            <CheckBox Content="Enable animations"
                                      Foreground="{DynamicResource TextSubBrush}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Enable Excel integration"
                                      Foreground="{DynamicResource TextSubBrush}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Auto-save configuration"
                                      Foreground="{DynamicResource TextSubBrush}"
                                      Margin="0,0,0,10"/>

                        </StackPanel>

                    </ScrollViewer>

                </Border>

            </Grid>

            <!-- FOOTER -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Som3a Add-in Settings"
                           Foreground="{DynamicResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="120"
                        Height="34"
                        Content="Save"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding SaveCommand}"/>

                <Button Grid.Column="3"
                        Width="120"
                        Height="34"
                        Content="Cancel"
                        Style="{DynamicResource GhostButton}"
                        Command="{Binding CancelCommand}"/>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>