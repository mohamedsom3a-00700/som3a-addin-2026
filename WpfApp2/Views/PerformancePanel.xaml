<UserControl x:Class="Som3a_WPF_UI.Views.PerformancePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <ResourceDictionary/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
        <StackPanel SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

            <!-- Animation Speed -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.AnimationSpeed]}"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <StackPanel Margin="0,0,0,12"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
<RadioButton Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.AnimationOff]}"
                                      GroupName="AnimSpeed"
                                     Margin="0,0,0,8"
                                     IsChecked="{Binding AnimationOff, Mode=OneWay}"
                                     Command="{Binding AnimationSpeedCommand}"
                                     CommandParameter="Off"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     AutomationProperties.Name="Animation Speed Off"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"/>
<RadioButton Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.AnimationReduced]}"
                                      GroupName="AnimSpeed"
                                     Margin="0,0,0,8"
                                     IsChecked="{Binding AnimationReduced, Mode=OneWay}"
                                     Command="{Binding AnimationSpeedCommand}"
                                     CommandParameter="Reduced"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     AutomationProperties.Name="Animation Speed Reduced"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"/>
<RadioButton Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.AnimationFull]}"
                                      GroupName="AnimSpeed"
                                     IsChecked="{Binding AnimationFull, Mode=OneWay}"
                                     Command="{Binding AnimationSpeedCommand}"
                                     CommandParameter="Full"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     AutomationProperties.Name="Animation Speed Full"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- UI Density -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.UiDensity]}"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <StackPanel Margin="0,0,0,12"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
<RadioButton Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.DensityCompact]}"
                                  GroupName="UiDensity"
                                 Margin="0,0,0,8"
                                 IsChecked="{Binding DensityCompact, Mode=OneWay}"
                                 Command="{Binding DensityCommand}"
                                 CommandParameter="Compact"
                                 Foreground="{DynamicResource TextMainBrush}"
                                 AutomationProperties.Name="UI Density Compact"
                                 SnapsToDevicePixels="True"
                                 UseLayoutRounding="True"/>
<RadioButton Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.DensityNormal]}"
                                  GroupName="UiDensity"
                                 Margin="0,0,0,8"
                                 IsChecked="{Binding DensityNormal, Mode=OneWay}"
                                 Command="{Binding DensityCommand}"
                                 CommandParameter="Normal"
                                 Foreground="{DynamicResource TextMainBrush}"
                                 AutomationProperties.Name="UI Density Normal"
                                 SnapsToDevicePixels="True"
                                 UseLayoutRounding="True"/>
<RadioButton Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PerformancePanel.DensitySpacious]}"
                                  GroupName="UiDensity"
                                 IsChecked="{Binding DensitySpacious, Mode=OneWay}"
                                 Command="{Binding DensityCommand}"
                                 CommandParameter="Spacious"
                                 Foreground="{DynamicResource TextMainBrush}"
                                 AutomationProperties.Name="UI Density Spacious"
                                 SnapsToDevicePixels="True"
                                 UseLayoutRounding="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
