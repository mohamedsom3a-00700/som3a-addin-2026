<UserControl x:Class="Som3a_WPF_UI.Views.AccessibilityPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
             xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
        <StackPanel SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

            <!-- High Contrast -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <TextBlock Text="{l:Loc AccessibilityPanel.HighContrast}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                        <TextBlock Text="{l:Loc AccessibilityPanel.HighContrastDescription}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   Margin="0,4,0,0"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1"
                                  Width="44"
                                  Height="22"
                                  IsChecked="{Binding CurrentSettings.HighContrastEnabled}"
                                  Style="{DynamicResource ToggleSwitchStyle}"
                                  AutomationProperties.Name="High Contrast Toggle"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True"/>
                </Grid>
            </Border>

            <!-- Focus Indicator -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <TextBlock Text="{l:Loc AccessibilityPanel.FocusIndicator}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                        <TextBlock Text="{l:Loc AccessibilityPanel.FocusIndicatorDescription}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   Margin="0,4,0,0"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1"
                                  Width="44"
                                  Height="22"
                                  IsChecked="{Binding CurrentSettings.FocusIndicatorEnabled}"
                                  Style="{DynamicResource ToggleSwitchStyle}"
                                  AutomationProperties.Name="Focus Indicator Toggle"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
