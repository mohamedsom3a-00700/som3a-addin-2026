<Window x:Class="Som3a_WPF_UI.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="600" Height="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        x:Name="SplashRoot">
    <Border CornerRadius="12" Background="{DynamicResource Brush.Background.Primary}"
            BorderBrush="{DynamicResource Brush.Border.Default}" BorderThickness="1"
            Effect="{DynamicResource Shadow.Large}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Viewbox Grid.Row="0" Stretch="Uniform" Margin="40">
                <Grid Width="400" Height="220">
                    <Canvas x:Name="BlueprintCanvas" Width="400" Height="220"
                            Opacity="0.3" IsHitTestVisible="False">
                        <Line x:Name="BlueprintLine1" X1="20" Y1="180" X2="100" Y2="60"
                              Stroke="{DynamicResource Brush.Accent.Cyan}" StrokeThickness="1"
                              Opacity="0">
                            <Line.StrokeDashArray>
                                <DoubleCollection>4 3</DoubleCollection>
                            </Line.StrokeDashArray>
                        </Line>
                        <Line x:Name="BlueprintLine2" X1="100" Y1="60" X2="200" Y2="40"
                              Stroke="{DynamicResource Brush.Accent.Cyan}" StrokeThickness="1"
                              Opacity="0">
                            <Line.StrokeDashArray>
                                <DoubleCollection>4 3</DoubleCollection>
                            </Line.StrokeDashArray>
                        </Line>
                        <Line x:Name="BlueprintLine3" X1="200" Y1="40" X2="300" Y2="80"
                              Stroke="{DynamicResource Brush.Accent.Cyan}" StrokeThickness="1"
                              Opacity="0">
                            <Line.StrokeDashArray>
                                <DoubleCollection>4 3</DoubleCollection>
                            </Line.StrokeDashArray>
                        </Line>
                        <Line x:Name="BlueprintLine4" X1="300" Y1="80" X2="380" Y2="180"
                              Stroke="{DynamicResource Brush.Accent.Cyan}" StrokeThickness="1"
                              Opacity="0">
                            <Line.StrokeDashArray>
                                <DoubleCollection>4 3</DoubleCollection>
                            </Line.StrokeDashArray>
                        </Line>
                        <Ellipse x:Name="BlueprintNode1" Canvas.Left="95" Canvas.Top="55"
                                 Width="10" Height="10" Fill="{DynamicResource Brush.Accent.Cyan}"
                                 Opacity="0" Effect="{DynamicResource Glow.Brand.Cyan}"/>
                        <Ellipse x:Name="BlueprintNode2" Canvas.Left="195" Canvas.Top="35"
                                 Width="10" Height="10" Fill="{DynamicResource Brush.Accent.Cyan}"
                                 Opacity="0" Effect="{DynamicResource Glow.Brand.Cyan}"/>
                        <Ellipse x:Name="BlueprintNode3" Canvas.Left="295" Canvas.Top="75"
                                 Width="10" Height="10" Fill="{DynamicResource Brush.Accent.Cyan}"
                                 Opacity="0" Effect="{DynamicResource Glow.Brand.Cyan}"/>
                    </Canvas>

                    <TextBlock x:Name="LogoText" Text="PLANOVA"
                               FontFamily="{DynamicResource FontFamily.Inter}"
                               FontSize="48" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                              Color="{DynamicResource AccentColorValue}" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock x:Name="SubtitleText" Text="Planning Platform"
                               FontFamily="{DynamicResource FontFamily.Inter}"
                               FontSize="14" FontWeight="Normal"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               Margin="0,0,0,40" Opacity="0"/>
                </Grid>
            </Viewbox>

            <Border Grid.Row="1" Height="4" Margin="40,0,40,30"
                    CornerRadius="2" Background="{DynamicResource Primitive.Black.13}">
                <Border x:Name="ProgressBar" Width="0" Height="4"
                        CornerRadius="2" HorizontalAlignment="Left"
                        Background="{DynamicResource Brush.Accent.Primary}"/>
            </Border>

            <TextBlock x:Name="StatusText" Grid.Row="1"
                       Text="Initializing..."
                       FontFamily="{DynamicResource FontFamilyPrimary}"
                       FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
        </Grid>
    </Border>
</Window>
