<UserControl x:Class="Som3a_WPF_UI.Views.ExcelPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
             xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
        <StackPanel SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

            <!-- Render Mode -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{l:Loc ExcelPanel.RenderMode}"
                               Style="{DynamicResource SettingLabelStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                    <ComboBox Grid.Column="1"
                              Width="200"
                              HorizontalAlignment="Left"
                              SelectedValue="{Binding CurrentSettings.RenderMode, Mode=TwoWay}"
                              SelectedValuePath="Content"
                              Style="{DynamicResource SettingsComboBoxStyle}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                        <ComboBoxItem Content="{l:Loc ExcelPanel.RenderModeAuto}"/>
                        <ComboBoxItem Content="{l:Loc ExcelPanel.RenderModeSafe}"/>
                        <ComboBoxItem Content="{l:Loc ExcelPanel.RenderModeFull}"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Safe Mode Toggle -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                        <TextBlock Text="{l:Loc ExcelPanel.SafeMode}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                        <TextBlock Text="{l:Loc ExcelPanel.SafeModeDescription}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   Margin="0,4,0,0"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1"
                                  Width="44"
                                  Height="22"
                                  IsChecked="{Binding CurrentSettings.SafeModeEnabled}"
                                  Style="{DynamicResource ToggleSwitchStyle}"
                                  AutomationProperties.Name="Safe Mode Toggle"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True"/>
                </Grid>
            </Border>

            <!-- DPI Info -->
            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <TextBlock Text="{l:Loc ExcelPanel.DpiInformation}"
                               Style="{DynamicResource SectionHeaderStyle}"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>
                    <Border Background="{DynamicResource Brush.Control.Hover}"
                            CornerRadius="{DynamicResource MediumRadius}"
                            Padding="12"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <TextBlock Text="{l:Loc ExcelPanel.DpiDescription}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   TextWrapping="Wrap"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
