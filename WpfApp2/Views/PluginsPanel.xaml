<UserControl x:Class="Som3a_WPF_UI.Views.PluginsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
             xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
        <StackPanel SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

            <Border Style="{DynamicResource PanelSectionStyle}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <StackPanel SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                    <Grid SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{l:Loc PluginsPanel.InstalledPlugins}"
                                   Style="{DynamicResource SectionHeaderStyle}"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                        <Button Grid.Column="1"
                                Content="{l:Loc PluginsPanel.Refresh}"
                                Style="{DynamicResource ActionButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding Modules}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              EnableRowVirtualization="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              MaxHeight="400"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{l:Loc PluginsGrid.Module}" Binding="{Binding ModuleId}" Width="150"/>
                            <DataGridTextColumn Header="{l:Loc PluginsGrid.Version}" Binding="{Binding Version}" Width="70"/>
                            <DataGridTextColumn Header="{l:Loc PluginsGrid.State}" Binding="{Binding StateDisplay}" Width="80"/>
                            <DataGridTextColumn Header="{l:Loc PluginsGrid.Capabilities}" Binding="{Binding Capabilities}" Width="120"/>
                            <DataGridTextColumn Header="{l:Loc PluginsGrid.Memory}" Binding="{Binding MemoryDisplay}" Width="80"/>
                            <DataGridTextColumn Header="{l:Loc PluginsGrid.LoadTime}" Binding="{Binding LoadTimeDisplay}" Width="70"/>
                            <DataGridTextColumn Header="{l:Loc PluginsGrid.LastError}" Binding="{Binding LastError}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
