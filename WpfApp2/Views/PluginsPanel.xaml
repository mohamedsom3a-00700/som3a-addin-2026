<UserControl x:Class="Som3a_WPF_UI.Views.PluginsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid VerticalAlignment="Center"
          HorizontalAlignment="Center">
        <Border Background="{DynamicResource Brush.Control.Hover}"
                CornerRadius="{DynamicResource MediumRadius}"
                Padding="24">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No plugins installed"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMainBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Plugins will appear here once installed."
                           FontSize="12"
                           Foreground="{DynamicResource TextSubBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
