<Page x:Class="Som3a_WPF_UI.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="{DynamicResource Brush.Background.Primary}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Page.Resources>
        <ResourceDictionary/>
    </Page.Resources>

    <Grid Margin="{DynamicResource Padding.Medium}">

        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">

            <TextBlock Text="Settings"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="{DynamicResource SubHeaderFontSize}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1"
              Margin="8,14,8,14">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border x:Name="SidebarPanel"
                    Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Margin="0,0,14,0">

                <Grid Margin="{DynamicResource Padding.Medium}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Categories"
                               FontSize="16"
                               Foreground="{DynamicResource TextSubBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <ListBox x:Name="SidebarList"
                             Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             Style="{DynamicResource SidebarListBoxStyle}"
                             AutomationProperties.Name="Settings Categories"
                             KeyboardNavigation.TabNavigation="Local"
                             ItemTemplate="{StaticResource SidebarFullTemplate}"/>

                </Grid>

            </Border>

            <!-- MAIN PANEL -->
            <Border Grid.Column="1"
                    Style="{DynamicResource PanelContainerStyle}">

                <ContentControl Content="{Binding CurrentPanel}"
                                AutomationProperties.Name="Settings Panel Content"/>

            </Border>

        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Som3a Add-in Settings"
                       Foreground="{DynamicResource TextSubBrush}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Width="120"
                    Height="34"
                    Content="Save"
                    Style="{DynamicResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>

            <Button Grid.Column="3"
                    Width="120"
                    Height="34"
                    Content="Cancel"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding CancelCommand}"/>

        </Grid>

    </Grid>

</Page>
