<Page x:Class="Som3a_WPF_UI.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Som3a_WPF_UI.ViewModels"
      xmlns:views="clr-namespace:Som3a_WPF_UI.Views"
      Title="Settings"
      Background="{DynamicResource Brush.Background.Primary}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Views/SettingControlTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="{DynamicResource Padding.Medium}">

        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">

            <TextBlock Text="Settings"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="{DynamicResource SubHeaderFontSize}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1"
              Margin="8,14,8,14">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border x:Name="SidebarPanel"
                    Grid.Column="0"
                    Background="Gray"
                    BorderBrush="DimGray"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,14,0">

                <Grid Background="Transparent" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Background="Transparent">
                        <TextBlock Text="Categories"
                                   FontSize="16"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>
                        <TextBlock x:Name="DebugCount"
                                   Text="..."
                                   FontSize="12"
                                   Foreground="Lime"
                                   Margin="0,0,0,8"/>
                    </StackPanel>

                    <ListBox x:Name="SidebarList"
                             Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             AutomationProperties.Name="Settings Categories"
                             KeyboardNavigation.TabNavigation="Local">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="16" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" Foreground="White"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>

            </Border>

            <!-- MAIN PANEL -->
            <Border Grid.Column="1" Style="{DynamicResource PanelContainerStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                    <StackPanel>
                        <ContentControl Content="{Binding CurrentPanel}"
                                        AutomationProperties.Name="Settings Panel Content"/>

                        <ItemsControl ItemsSource="{Binding DynamicSections}"
                                      Visibility="{Binding DynamicSections.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                      Margin="0,16,0,0"
                                      BorderThickness="0"
                                      Background="Transparent">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:SettingsSectionViewModel">
                                    <views:SettingsSectionView/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Som3a Add-in Settings"
                       Foreground="{DynamicResource TextSubBrush}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Width="100"
                    Height="34"
                    Content="Export"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding ExportSettingsCommand}"/>

            <Button Grid.Column="3"
                    Width="100"
                    Height="34"
                    Content="Import"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding ImportSettingsCommand}"/>

            <Button Grid.Column="5"
                    Width="120"
                    Height="34"
                    Content="Save"
                    Style="{DynamicResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>

            <Button Grid.Column="7"
                    Width="120"
                    Height="34"
                    Content="Cancel"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding CancelCommand}"/>

        </Grid>

    </Grid>

</Page>
