<Page x:Class="Som3a_WPF_UI.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Som3a_WPF_UI.ViewModels"
      xmlns:views="clr-namespace:Som3a_WPF_UI.Views"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      xmlns:fluentIcons="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.Title]}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Views/SettingControlTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="{DynamicResource Padding.Medium}">

        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">

            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.Heading]}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="{DynamicResource SubHeaderFontSize}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1"
              Margin="8,14,8,14">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border x:Name="SidebarPanel"
                    Grid.Column="0"
                    Background="{DynamicResource Brush.Background.Secondary.Translucent}"
                    BorderBrush="{DynamicResource Brush.Stroke.Card}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource MediumRadius}"
                    Margin="0,0,14,0">

                <Grid Background="Transparent" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Background="Transparent">
                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.Categories]}"
                                   FontSize="16"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>
                        <TextBlock x:Name="DebugCount"
                                   Text="..."
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.Accent.Success}"
                                   Margin="0,0,0,8"/>
                    </StackPanel>

                     <ListBox x:Name="SidebarList"
                              Grid.Row="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{DynamicResource Brush.Text.Primary}"
                               AutomationProperties.Name="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.CategoriesAutomation]}"
                              KeyboardNavigation.TabNavigation="Local">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <fluentIcons:FluentIcon Icon="Circle"
                                                           FontSize="14"
                                                           Width="16" Height="16"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>

            </Border>

            <!-- MAIN PANEL -->
            <Border Grid.Column="1" Style="{DynamicResource PanelContainerStyle}"
                    CornerRadius="{DynamicResource MediumRadius}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True"
                              PreviewMouseWheel="OnScrollViewerPreviewMouseWheel">
                    <StackPanel>
                        <ContentControl Content="{Binding CurrentPanel}"
                                        AutomationProperties.Name="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.PanelContentAutomation]}"
                                        VerticalAlignment="Top"/>

                        <ItemsControl ItemsSource="{Binding DynamicSections}"
                                      Visibility="{Binding DynamicSections.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                      Margin="0,16,0,0"
                                      BorderThickness="0"
                                      Background="Transparent">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:SettingsSectionViewModel">
                                    <views:SettingsSectionView/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.FooterText]}"
                       Foreground="{DynamicResource TextSubBrush}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Width="100"
                    Height="34"
                    Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.Export]}"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding ExportSettingsCommand}"/>

            <Button Grid.Column="3"
                    Width="100"
                    Height="34"
                    Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.Import]}"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding ImportSettingsCommand}"/>

            <Button Grid.Column="5"
                    Width="120"
                    Height="34"
                    Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.Save]}"
                    Style="{DynamicResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>

            <Button Grid.Column="7"
                    Width="120"
                    Height="34"
                    Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[SettingsPage.Cancel]}"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding CancelCommand}"/>

        </Grid>

    </Grid>

</Page>
