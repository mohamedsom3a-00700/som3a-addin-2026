<Page x:Class="Som3a_WPF_UI.Pages.RelationshipGeneratorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      mc:Ignorable="d"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.Title]}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" Margin="{DynamicResource TitleBarMargin}">
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.Heading]}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- CONTENT CARD -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnGenerate" Grid.Column="0" Height="34"
                                Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.GenerateRelationships]}"
                                Style="{DynamicResource PrimaryButton}"
                                Click="btnGenerate_Click"/>
                        <Button x:Name="btnAcceptAll" Grid.Column="3" Height="34"
                                Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.AcceptAll]}"
                                Style="{DynamicResource BaseButton}"
                                Click="btnAcceptAll_Click"/>
                        <Button x:Name="btnRejectAll" Grid.Column="5" Height="34"
                                Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.RejectAll]}"
                                Style="{DynamicResource BaseButton}"
                                Click="btnRejectAll_Click"/>
                        <Button x:Name="btnCancel" Grid.Column="7" Height="34"
                                Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.Cancel]}"
                                Style="{DynamicResource BaseButton}"
                                Click="btnCancel_Click"
                                Visibility="Collapsed"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <TabControl Background="Transparent"
                                    BorderThickness="0">
                            <TabItem Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorTab.Relationships]}"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     Background="{DynamicResource CardBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="txtGenerationStatus" Grid.Row="0"
                                               Foreground="{DynamicResource TextSubBrush}"
                                               Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.GenerateHint]}"/>
                                    <controls:RelationshipEditorGrid x:Name="RelationshipGrid" Grid.Row="2"/>
                                </Grid>
                            </TabItem>
                            <TabItem Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorTab.Validation]}"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     Background="{DynamicResource CardBrush}">
                                <Grid>
                                    <TextBlock x:Name="txtValidationSummary"
                                               Foreground="{DynamicResource TextSubBrush}"
                                               Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.ValidationHint]}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </TabItem>
                            <TabItem Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorTab.Analysis]}"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     Background="{DynamicResource CardBrush}">
                                <Grid>
                                    <TextBlock x:Name="txtAnalysis" Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.AnalysisHint]}"
                                               Foreground="{DynamicResource TextSubBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </TabItem>
                            <TabItem Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorTab.Export]}"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     Background="{DynamicResource CardBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Button x:Name="btnExport" Height="34"
                                                Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.ExportToExcel]}"
                                                Style="{DynamicResource PrimaryButton}"
                                                Click="btnExport_Click"
                                                Margin="0,0,8,0"/>
                                    </StackPanel>
                                    <Border Grid.Row="2" Margin="0,8,0,0"
                                            Background="{DynamicResource Brush.Fill.Info}"
                                            CornerRadius="{DynamicResource MediumRadius}"
                                            Padding="10">
                                        <TextBlock x:Name="txtExportStatus"
                                                   Foreground="{DynamicResource TextSubBrush}"
                                                   Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.ExportHint]}"/>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Border>

            <!-- FOOTER -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{DynamicResource Brush.Fill.Status}"
                        CornerRadius="{DynamicResource CardRadius}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1" Padding="12,0">
                    <TextBlock x:Name="txtFooterStatus" Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.Ready]}"
                               Foreground="{DynamicResource TextSubBrush}"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- BUSY OVERLAY -->
            <Grid x:Name="BusyOverlay" Grid.RowSpan="3"
                  Visibility="Collapsed"
                  Background="{DynamicResource Brush.Background.Primary}">
                <Border Background="{DynamicResource Brush.Background.Secondary}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1" Padding="16"
                        CornerRadius="{DynamicResource LargeRadius}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ProgressBar Width="130" Height="16"
                                     IsIndeterminate="True"/>
                        <TextBlock x:Name="txtBusy" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   VerticalAlignment="Center" Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[RelationshipGeneratorPage.Working]}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
