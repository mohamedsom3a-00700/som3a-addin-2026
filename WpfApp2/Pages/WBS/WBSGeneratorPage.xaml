<Page x:Class="WpfApp2.Pages.WBS.WBSGeneratorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AI WBS Generation">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AI-Powered WBS Generation" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Project Description" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}" 
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                         IsEnabled="{Binding CanGenerate}"/>
                <TextBlock Text="Describe your project type, scope, and key deliverables." 
                           Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Generated WBS Preview" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border BorderThickness="1" BorderBrush="LightGray" MinHeight="120" Padding="8">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding GeneratedWbs.Children}" 
                                      Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}"/>
                    </ScrollViewer>
                </Border>
                <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="Generate WBS" Command="{Binding GenerateCommand}" 
                    IsEnabled="{Binding CanGenerate}" Padding="20,10" Margin="0,0,8,0"/>
            <Button Content="Regenerate" Command="{Binding RegenerateCommand}" 
                    IsEnabled="{Binding HasResult}" Padding="20,10" Margin="8,0"/>
            <Button Content="Accept" Command="{Binding AcceptCommand}" 
                    IsEnabled="{Binding HasResult}" Padding="20,10" Margin="8,0"/>
        </StackPanel>

        <ProgressBar Grid.Row="3" IsIndeterminate="{Binding IsGenerating}" 
                     Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibility}}"
                     Height="4" Margin="0,8,0,0"/>
    </Grid>
</Page>
