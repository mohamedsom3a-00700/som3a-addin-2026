<Page x:Class="Som3a_WPF_UI.Pages.WBS.WBSGeneratorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wbs="clr-namespace:Som3a_WPF_UI.Services.WBS"
      Title="AI WBS Generation"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AI-Powered WBS Generation" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Project Description" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                         IsEnabled="{Binding CanGenerate}"/>
                <TextBlock Text="Describe your project type, scope, and key deliverables."
                           Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Generated WBS Preview" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border BorderThickness="1" BorderBrush="{DynamicResource Brush.Control.Stroke}" MinHeight="120" Padding="4">
                    <ScrollViewer Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TreeView ItemsSource="{Binding GeneratedWbs.Children}" BorderThickness="0"
                                  ItemContainerStyleSelector="{StaticResource WBSNodeLevelStyleSelector}">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type wbs:WBSNode}" ItemsSource="{Binding Children}">
                                    <TextBlock Margin="0,1">
                                        <Run Text="{Binding Code}" FontWeight="SemiBold"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </ScrollViewer>
                </Border>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="Load BOQ" Command="{Binding LoadBoqCommand}"
                    IsEnabled="{Binding CanLoadBoq}" Padding="20,10" Margin="0,0,8,0"/>
            <Button Content="Generate WBS" Command="{Binding GenerateCommand}"
                    IsEnabled="{Binding CanGenerate}" Padding="20,10" Margin="8,0"/>
            <Button Content="Regenerate" Command="{Binding RegenerateCommand}"
                    IsEnabled="{Binding HasResult}" Padding="20,10" Margin="8,0"/>
            <Button Content="Accept" Command="{Binding AcceptCommand}"
                    IsEnabled="{Binding HasResult}" Padding="20,10" Margin="8,0"/>
        </StackPanel>

        <ProgressBar Grid.Row="3" IsIndeterminate="{Binding IsGenerating}"
                     Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}"
                     Height="4" Margin="0,8,0,0"/>
    </Grid>
</Page>
