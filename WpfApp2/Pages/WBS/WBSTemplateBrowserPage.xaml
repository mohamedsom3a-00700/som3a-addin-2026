<Page x:Class="WpfApp2.Pages.WBS.WBSTemplateBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WBS Templates"
      Loaded="OnLoaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="WBS Templates" FontSize="20" FontWeight="SemiBold" 
                       VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="Get Recommendations" Command="{Binding GetRecommendationsCommand}" 
                    Margin="0,0,8,0" Padding="12,6"/>
            <TextBox Text="{Binding ProjectContext, UpdateSourceTrigger=PropertyChanged}" 
                     Width="250" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Categories}" 
                     SelectedItem="{Binding ActiveCategory}" 
                     Margin="0,0,12,0" BorderThickness="0"/>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding ActiveCategory, StringFormat='Category: {0}'}" 
                           FontSize="14" Margin="0,0,0,8"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding Templates}" 
                         SelectedItem="{Binding SelectedTemplate}"
                         DisplayMemberPath="Name"/>
            </Grid>
        </Grid>

        <Button Grid.Row="2" Content="Select Template" 
                IsEnabled="{Binding CanPreview}" 
                Margin="0,12,0,0" Padding="16,8" HorizontalAlignment="Right"/>
    </Grid>
</Page>
