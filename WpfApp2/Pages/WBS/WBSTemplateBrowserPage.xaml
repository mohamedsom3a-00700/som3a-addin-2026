<Page x:Class="Som3a_WPF_UI.Pages.WBS.WBSTemplateBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
      xmlns:wbs="clr-namespace:Som3a_WPF_UI.Services.WBS"
      
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
      Title="{l:Loc WBSTemplateBrowserPage.Title}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True"
      Loaded="OnLoaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{l:Loc WBSTemplateBrowserPage.Heading}" FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="{l:Loc WBSTemplateBrowserPage.GetRecommendations}" Command="{Binding GetRecommendationsCommand}"
                    Margin="0,0,8,0" Padding="12,6"/>
            <TextBox Text="{Binding ProjectContext, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding ActiveCategory}"
                     Margin="0,0,12,0" BorderThickness="0"/>

            <Grid Grid.Column="1" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontSize="14" Margin="0,0,0,8">
                    <Run Text="{l:Loc WBSTemplateBrowserPage.CategoryFormat}"/>
                    <Run Text="{Binding ActiveCategory}"/>
                </TextBlock>
                <ListBox Grid.Row="1" ItemsSource="{Binding Templates}"
                         SelectedItem="{Binding SelectedTemplate}"
                         DisplayMemberPath="Name"/>
            </Grid>

            <Border Grid.Column="2" BorderThickness="1" BorderBrush="{DynamicResource Brush.Control.Stroke}"
                    Width="250" Padding="4" Visibility="{Binding HasPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                <TreeView ItemsSource="{Binding PreviewRoot.Children}" BorderThickness="0"
                          ItemContainerStyleSelector="{StaticResource WBSNodeLevelStyleSelector}">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type wbs:WBSNode}" ItemsSource="{Binding Children}">
                            <TextBlock Margin="0,1">
                                <Run Text="{Binding Code}" FontWeight="SemiBold"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding Name}"/>
                            </TextBlock>
                        </HierarchicalDataTemplate>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{l:Loc WBSTemplateBrowserPage.ImportFromExcel}" Command="{Binding ImportTemplateFromExcelCommand}"
                    Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="{l:Loc WBSTemplateBrowserPage.ExportToExcel}" Command="{Binding ExportTemplateToExcelCommand}"
                    IsEnabled="{Binding CanPreview}" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="{l:Loc WBSTemplateBrowserPage.SelectTemplate}" Command="{Binding SelectTemplateCommand}"
                    IsEnabled="{Binding CanPreview}" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Page>
