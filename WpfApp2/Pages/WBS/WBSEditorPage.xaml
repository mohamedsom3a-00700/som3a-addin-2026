<Page x:Class="WpfApp2.Pages.WBS.WBSEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WBS Editor">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="WBS Tree Editor" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <TreeView Grid.Column="0" ItemsSource="{Binding RootNode.Children}" 
                      SelectedItemChanged="OnSelectionChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Code, StringFormat='{0} - '}"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Node Details" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding SelectedNode.Code, StringFormat='Code: {0}'}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding SelectedNode.Name, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,8" IsEnabled="{Binding SelectedNode, Converter={StaticResource IsNotNull}}"/>

                <Button Content="Rename" Command="{Binding RenameNodeCommand}" 
                        IsEnabled="{Binding SelectedNode, Converter={StaticResource IsNotNull}}"
                        Margin="0,0,0,12" Padding="8,4"/>

                <Separator Margin="0,0,0,12"/>

                <TextBlock Text="Add Child Node" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Text="{Binding NewNodeName, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,8"/>
                <Button Content="Add Child" Command="{Binding AddChildCommand}" 
                        IsEnabled="{Binding CanAddChild}" Padding="8,4" Margin="0,0,0,12"/>

                <Button Content="Remove Selected" Command="{Binding RemoveNodeCommand}" 
                        IsEnabled="{Binding CanRemove}" Padding="8,4" Margin="0,0,0,12"/>

                <Separator Margin="0,0,0,12"/>

                <Button Content="Save as Template" Command="{Binding SaveAsTemplateCommand}" 
                        IsEnabled="{Binding HasTree}" Padding="8,4" Margin="0,0,0,8"/>
                <Button Content="Undo" Command="{Binding UndoCommand}" 
                        IsEnabled="{Binding CanUndo}" Padding="8,4"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" 
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Page>
