<Page x:Class="WpfApp2.Pages.WBS.WBSExportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WBS Export">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Export WBS" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <GroupBox Grid.Row="1" Header="Export Format" Margin="0,0,0,12">
            <StackPanel>
                <RadioButton Content="Excel (.xlsx) - Hierarchical with indentation" 
                             IsChecked="{Binding SelectedFormat, Converter={StaticResource RadioBoolConverter}, ConverterParameter=Excel}"
                             GroupName="Format" Margin="0,4"/>
                <RadioButton Content="JSON (.json) - Structured node tree" 
                             IsChecked="{Binding SelectedFormat, Converter={StaticResource RadioBoolConverter}, ConverterParameter=JSON}"
                             GroupName="Format" Margin="0,4"/>
                <RadioButton Content="XML (.xml) - Hierarchical XML" 
                             IsChecked="{Binding SelectedFormat, Converter={StaticResource RadioBoolConverter}, ConverterParameter=XML}"
                             GroupName="Format" Margin="0,4"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Destination File" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" 
                         IsReadOnly="True" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFileCommand}" Padding="12,4"/>
            </Grid>
        </GroupBox>

        <Button Grid.Row="3" Content="Export" Command="{Binding ExportCommand}" 
                IsEnabled="{Binding CanExport}" Padding="24,10" HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center"/>
    </Grid>
</Page>
