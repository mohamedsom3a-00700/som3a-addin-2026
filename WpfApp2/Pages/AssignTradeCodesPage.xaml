<Page x:Class="Som3a_WPF_UI.Pages.AssignTradeCodesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
      mc:Ignorable="d"
      Title="{l:Loc AssignTradeCodesPage.Title}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="14">

        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">

            <TextBlock Text="{l:Loc AssignTradeCodesPage.Heading}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SETTINGS -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="14" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc AssignTradeCodesPage.MainSheet}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Margin="10,0,0,0"
                              Height="34" ItemsSource="{Binding Sheets}"
                              SelectedItem="{Binding MainSheet, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource RoundComboBox}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc AssignTradeCodesPage.ReferenceSheet}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Margin="10,0,0,0"
                              Height="34" ItemsSource="{Binding Sheets}"
                              SelectedItem="{Binding RefSheet, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource RoundComboBox}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{l:Loc AssignTradeCodesPage.CodeColumn}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0"
                                Orientation="Horizontal">
                        <TextBox Width="70" Height="34" Margin="0,0,10,0"
                                 Text="{Binding CodeColLetter}" IsReadOnly="True"
                                 Style="{DynamicResource ReadOnlyTextBox}"/>
                        <TextBox Width="220" Height="34"
                                 Text="{Binding CodeColHeader}" IsReadOnly="True"
                                 Style="{DynamicResource ReadOnlyTextBox}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="{l:Loc AssignTradeCodesPage.ActivityIdColumn}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,0"
                                Orientation="Horizontal">
                        <TextBox Width="70" Height="34" Margin="0,0,10,0"
                                 Text="{Binding ActivityColLetter}" IsReadOnly="True"
                                 Style="{DynamicResource ReadOnlyTextBox}"/>
                        <TextBox Width="220" Height="34"
                                 Text="{Binding ActivityColHeader}" IsReadOnly="True"
                                 Style="{DynamicResource ReadOnlyTextBox}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="{l:Loc AssignTradeCodesPage.StatusColumn}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Margin="10,0,0,0"
                             Height="34" Text="{Binding StatusColLetter}"
                             IsReadOnly="True" Style="{DynamicResource ReadOnlyTextBox}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0"
                               Text="{l:Loc AssignTradeCodesPage.ReferenceMap}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Margin="10,0,0,0"
                             Height="34"
                             Text="{l:Loc AssignTradeCodesPage.ReferenceMapHint}"
                             IsReadOnly="True" Style="{DynamicResource ReadOnlyTextBox}"/>
                </Grid>
            </Border>

            <!-- LISTVIEW -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="10" Margin="0,0,0,14">
                <ListView ItemsSource="{Binding LogItems}"
                          Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{l:Loc AssignTradeCodesGrid.Row}" Width="60"
                                            DisplayMemberBinding="{Binding Row}"/>
                            <GridViewColumn Header="{l:Loc AssignTradeCodesGrid.Activity}" Width="240"
                                            DisplayMemberBinding="{Binding Activity}"/>
                            <GridViewColumn Header="{l:Loc AssignTradeCodesGrid.TradeCode}" Width="100"
                                            DisplayMemberBinding="{Binding TradeCode}"/>
                            <GridViewColumn Header="{l:Loc AssignTradeCodesGrid.Status}" Width="160"
                                            DisplayMemberBinding="{Binding Status}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- PROGRESS -->
            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="20" Margin="0,0,10,0"
                        Background="{DynamicResource Brush.Progress.Background}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MediumRadius}"
                        VerticalAlignment="Center">
                    <Grid ClipToBounds="True">
                        <Border CornerRadius="{DynamicResource MediumRadius}"
                                HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5"
                                Background="{DynamicResource Brush.Accent.ProgressFill}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleY="1"
                                    ScaleX="{Binding ProgressPercent, Converter={StaticResource PercentToScaleConverter}}"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Height="30"
                        Background="{DynamicResource ControlBgBrush}"
                        BorderBrush="{DynamicResource ControlStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MediumRadius}"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextOnAccentBrush}"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- BUTTONS -->
            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="34" Content="{l:Loc AssignTradeCodesPage.Run}"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding RunCommand}"
                        IsEnabled="{Binding CanRun}"/>
                <Button Grid.Column="2" Height="34" Content="{l:Loc AssignTradeCodesPage.Stop}"
                        Style="{DynamicResource BaseButton}"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsBusy}"/>
                <Button Grid.Column="4" Height="34" Content="{l:Loc AssignTradeCodesPage.Cancel}"
                        Style="{DynamicResource GhostButton}"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsBusy}"/>
            </Grid>

            <!-- STATUS -->
            <Border Grid.Row="4" Padding="{DynamicResource StatusBarPadding}"
                    Background="{DynamicResource Brush.Fill.Status}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource CardRadius}">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSubBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

        </Grid>

    </Grid>

</Page>
