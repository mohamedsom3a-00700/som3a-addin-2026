<Page x:Class="Som3a_WPF_UI.Pages.PrimaveraResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraResultsPage.Title]}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraResultsPage.Heading]}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Result}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSubBrush}"
                               Text="{Binding Result.Summary}"/>
                </StackPanel>
            </Border>

            <!-- TABS -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="10">
                <TabControl>
                    <TabItem Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraResultsTab.Activities]}">
                        <DataGrid ItemsSource="{Binding ActivityRows}"/>
                    </TabItem>
                    <TabItem Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraResultsTab.Relationships]}">
                        <DataGrid ItemsSource="{Binding RelationshipRows}"/>
                    </TabItem>
                    <TabItem Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraResultsTab.Resources]}">
                        <DataGrid ItemsSource="{Binding ResourceRows}"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>

</Page>
