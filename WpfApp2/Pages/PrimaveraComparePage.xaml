<Page x:Class="Som3a_WPF_UI.Pages.PrimaveraComparePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.Title]}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.Heading]}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- CONNECTION -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="14" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.DatabaseType]}"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource TextSubBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.ConnectionString]}"
                               Foreground="{DynamicResource TextSubBrush}"
                               Margin="14,0,0,6" FontWeight="SemiBold"/>

                    <ComboBox Grid.Row="1" Grid.Column="0" Height="38"
                              Style="{DynamicResource RoundComboBox}"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding SelectedDatabaseType}">
                        <ComboBoxItem Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.Sqlite]}"/>
                        <ComboBoxItem Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.Oracle]}"/>
                    </ComboBox>

                    <TextBox Grid.Row="1" Grid.Column="1" Height="38"
                             Margin="14,0,0,0" Style="{DynamicResource ReadOnlyTextBox}"
                             Text="{Binding ConnectionString}"/>

                    <Button Grid.Row="1" Grid.Column="2" Height="38"
                            Margin="14,0,0,0" Style="{DynamicResource BaseButton}"
                            Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.Browse]}" Click="BrowseButton_Click"/>

                    <Button Grid.Row="1" Grid.Column="3" Height="38"
                            Margin="10,0,0,0" Style="{DynamicResource PrimaryButton}"
                            Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.Connect]}"
                            Command="{Binding ConnectCommand}"/>
                </Grid>
            </Border>

            <!-- SEARCH -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <TextBox Height="38"
                         Style="{DynamicResource ReadOnlyTextBox}"
                         Text="{Binding SearchText}"/>
                <Button Grid.Column="1" Height="38"
                        Margin="14,0,0,0" Style="{DynamicResource PrimaryButton}"
                        Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraComparePage.Compare]}" Command="{Binding CompareCommand}"/>
            </Grid>

            <!-- GRID -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="0">
                <DataGrid x:Name="ProjectsGrid"
                          ItemsSource="{Binding FilteredProjects}"
                          AutoGenerateColumns="False"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          SelectionChanged="ProjectsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraCompareGrid.ProjectId]}" Binding="{Binding ProjectId}" Width="110"/>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraCompareGrid.ProjectCode]}" Binding="{Binding ProjectCode}" Width="180"/>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraCompareGrid.ProjectName]}" Binding="{Binding ProjectName}" Width="*"/>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraCompareGrid.Status]}" Binding="{Binding Status}" Width="140"/>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraCompareGrid.PlannedStart]}" Binding="{Binding PlannedStartDate, StringFormat=d}" Width="130"/>
                        <DataGridTextColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[PrimaveraCompareGrid.PlannedFinish]}" Binding="{Binding PlannedFinishDate, StringFormat=d}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- STATUS -->
            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSubBrush}"
                           Margin="0,0,0,8"/>
                <ProgressBar Grid.Row="1" Height="16"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}"/>
            </Grid>
        </Grid>
    </Grid>

</Page>
