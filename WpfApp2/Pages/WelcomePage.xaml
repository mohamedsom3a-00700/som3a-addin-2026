<pages:PageBase x:Class="Som3a_WPF_UI.Pages.WelcomePage"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pages="clr-namespace:Som3a_WPF_UI.Pages"
                    xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
                    Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[WelcomePage.Title]}"
                    Tag="welcome"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
    <Grid Style="{DynamicResource Style.WelcomePage.Container}">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="500">
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[WelcomePage.WelcomeMessage]}"
                       Style="{DynamicResource Style.WelcomePage.Title}"/>
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[WelcomePage.Instruction]}"
                       Style="{DynamicResource Style.WelcomePage.Description}"/>
        </StackPanel>
    </Grid>
</pages:PageBase>
