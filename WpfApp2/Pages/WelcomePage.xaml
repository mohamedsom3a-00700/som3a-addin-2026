<pages:PageBase x:Class="Som3a_WPF_UI.Pages.WelcomePage"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
                    xmlns:pages="clr-namespace:Som3a_WPF_UI.Pages"
      
                    xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
                    Title="{l:Loc WelcomePage.Title}"
                    Tag="welcome"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
    <Grid Style="{DynamicResource Style.WelcomePage.Container}">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="500">
            <TextBlock Text="{l:Loc WelcomePage.WelcomeMessage}"
                       Style="{DynamicResource Style.WelcomePage.Title}"/>
            <TextBlock Text="{l:Loc WelcomePage.Instruction}"
                       Style="{DynamicResource Style.WelcomePage.Description}"/>
        </StackPanel>
    </Grid>
</pages:PageBase>
