<Page x:Class="Som3a_WPF_UI.Pages.XerEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      mc:Ignorable="d"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.Title]}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.Heading]}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Margin="0,0,12,0">
                <StackPanel Margin="14">
                    <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.SidebarTitle]}" TextAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.LoadXer]}"
                            Command="{Binding LoadCommand}"
                            Style="{DynamicResource PrimaryButton}"
                            Margin="0,0,0,10" Height="32"/>

                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.ExportToExcel]}"
                            Command="{Binding ExportExcelCommand}"
                            Style="{DynamicResource PrimaryButton}"
                            Margin="0,0,0,10" Height="32"/>

                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.ImportFromExcel]}"
                            Command="{Binding ImportFromExcelCommand}"
                            Style="{DynamicResource PrimaryButton}"
                            Margin="0,0,0,10" Height="32"/>

                    <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.ExportXer]}"
                            Command="{Binding ExportXerCommand}"
                            Style="{DynamicResource PrimaryButton}"
                            Margin="0,0,0,10" Height="32"/>
                </StackPanel>
            </Border>

            <!-- MAIN PANEL -->
            <Grid Grid.Column="1">
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource LargeRadius}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorPage.LoadedTables]}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   Margin="0,0,0,14"/>

                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding Tables}"
                                  Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="50">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorGrid.Code]}" Width="120"
                                                    DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorGrid.TableName]}" Width="280"
                                                    DisplayMemberBinding="{Binding DisplayName}"/>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorGrid.Records]}" Width="120"
                                                    DisplayMemberBinding="{Binding Count}"/>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[XerEditorGrid.Status]}" Width="180"
                                                    DisplayMemberBinding="{Binding Status}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>

</Page>
