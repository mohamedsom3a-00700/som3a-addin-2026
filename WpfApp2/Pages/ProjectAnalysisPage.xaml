<Page x:Class="Som3a_WPF_UI.Pages.ProjectAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Som3a_WPF_UI.Converters"
      Title="Project Analysis"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Page.Resources>
        <ResourceDictionary/>
    </Page.Resources>

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">

            <TextBlock Text="Project Analysis"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- SETTINGS -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardStrokeBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource LargeRadius}"
                Padding="14">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Activities"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMainBrush}"/>

                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding AvailableSheets}"
                          SelectedItem="{Binding SelectedActivitiesSheet}"
                          Style="{DynamicResource RoundComboBox}"
                          Margin="0,7,0,8"/>

                <TextBlock Grid.Row="0" Grid.Column="3"
                           Text="Relationships"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMainBrush}"/>

                <ComboBox Grid.Row="0" Grid.Column="4"
                          ItemsSource="{Binding AvailableSheets}"
                          SelectedItem="{Binding SelectedLogicSheet}"
                          Style="{DynamicResource RoundComboBox}"
                          Margin="0,7,0,8"/>

                <TextBlock Grid.Row="0" Grid.Column="6"
                           Text="Resources"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMainBrush}"/>

                <ComboBox Grid.Row="0" Grid.Column="7"
                          ItemsSource="{Binding AvailableSheets}"
                          SelectedItem="{Binding SelectedResourcesSheet}"
                          Style="{DynamicResource RoundComboBox}"
                          Margin="0,7,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Finish date"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMainBrush}"/>

                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding FinishDateText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,7,0,8"/>

                <Button Grid.Row="1" Grid.Column="3"
                        Content="Check Sheets"
                        Style="{DynamicResource BaseButton}"
                        Command="{Binding ValidateCommand}"
                        Margin="0,7,0,8"/>

                <Button Grid.Row="1" Grid.Column="4"
                        Content="Run Analysis"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding RunCommand}"
                        Margin="0,7,0,8"/>

                <Button Grid.Row="1" Grid.Column="7"
                        Content="Clear Summary"
                        Style="{DynamicResource BaseButton}"
                        Command="{Binding ClearSummaryCommand}"
                        Margin="0,7,0,8"/>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Check Sheets Results"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <ListView Grid.Row="2"
                              ItemsSource="{Binding SheetChecks}"
                              ItemContainerStyle="{DynamicResource AccentListViewItem}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Sheet/Section" Width="150"
                                                DisplayMemberBinding="{Binding Section}"/>
                                <GridViewColumn Header="Required Column" Width="190"
                                                DisplayMemberBinding="{Binding RequiredColumn}"/>
                                <GridViewColumn Header="Found" Width="70"
                                                DisplayMemberBinding="{Binding HeaderFound}"/>
                                <GridViewColumn Header="Location" Width="110"
                                                DisplayMemberBinding="{Binding Location}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Summary"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <ListView Grid.Row="2"
                              ItemsSource="{Binding SummaryRows}"
                              ItemContainerStyle="{DynamicResource AccentListViewItem}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Type" Width="130"
                                                DisplayMemberBinding="{Binding Type}"/>
                                <GridViewColumn Header="Count" Width="70"
                                                DisplayMemberBinding="{Binding Count}"/>
                                <GridViewColumn Header="Sheet" Width="140"
                                                DisplayMemberBinding="{Binding SheetName}"/>
                                <GridViewColumn Header="Details" Width="430"
                                                DisplayMemberBinding="{Binding Details}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <TextBlock Grid.Row="4" Text="Log"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <ListView Grid.Row="6"
                              ItemsSource="{Binding LogRows}"
                              ItemContainerStyle="{DynamicResource AccentListViewItem}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="90"
                                                DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Header="Level" Width="80"
                                                DisplayMemberBinding="{Binding Level}"/>
                                <GridViewColumn Header="Message" Width="600"
                                                DisplayMemberBinding="{Binding Message}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- PROGRESS -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Height="24"
                    CornerRadius="{DynamicResource MediumRadius}"
                    Background="{DynamicResource Brush.Progress.Background}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center" Margin="0,0,10,0">
                <Grid ClipToBounds="True">
                    <Border CornerRadius="{DynamicResource MediumRadius}"
                            HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5"
                            Background="{DynamicResource Brush.Accent.ProgressFill}">
                        <Border.Effect>
                            <DynamicResource ResourceKey="ProgressGlow"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleY="1"
                                ScaleX="{Binding ProgressPct, Converter={StaticResource PercentToScaleConverter}}"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Border>
            <Border Grid.Column="1" Height="30"
                    CornerRadius="{DynamicResource MediumRadius}"
                    Background="{DynamicResource ControlBgBrush}"
                    BorderBrush="{DynamicResource ControlStrokeBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding ProgressPct, StringFormat={}{0:0}%}"
                           Foreground="{DynamicResource TextOnAccentBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- BUTTONS -->
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Run"
                    Style="{DynamicResource PrimaryButton}"
                    Command="{Binding RunCommand}"/>
            <Button Grid.Column="2" Content="Close"
                    Style="{DynamicResource BaseButton}"
                    Command="{Binding CloseCommand}"/>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="9"
                Background="{DynamicResource Brush.Fill.Status}"
                CornerRadius="{DynamicResource CardRadius}"
                BorderBrush="{DynamicResource CardStrokeBrush}"
                BorderThickness="1"
                Padding="{DynamicResource StatusBarPadding}">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource TextSubBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

    </Grid>

</Page>
