<Page x:Class="Som3a_WPF_UI.Pages.FixPieColorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
      mc:Ignorable="d"
      Title="{l:Loc FixPieColorsPage.Title}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">
            <TextBlock Text="{l:Loc FixPieColorsPage.Heading}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- CONTENT CARD -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{l:Loc FixPieColorsPage.SelectSheet}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>
                        <ComboBox x:Name="cmbSheets" Grid.Column="1"
                                  Style="{DynamicResource RoundComboBox}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{l:Loc FixPieColorsPage.CategoryRange}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>
                        <TextBox x:Name="txtCategoryRange" Grid.Column="1"
                                 Margin="8,0" Text="R6:R13"/>
                        <Button x:Name="btnPickRange" Grid.Column="2"
                                Content="{l:Loc FixPieColorsPage.Pick}" Style="{DynamicResource BaseButton}"
                                Click="btnPickRange_Click"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{l:Loc FixPieColorsPage.ColorTableRange}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>
                        <TextBox x:Name="txtColorTableRange" Grid.Column="1"
                                 Margin="8,0" Text="A2:B9"/>
                        <Button x:Name="btnPickColorTable" Grid.Column="2"
                                Content="{l:Loc FixPieColorsPage.PickColorTable}" Style="{DynamicResource BaseButton}"
                                Click="btnPickColorTable_Click"/>
                    </Grid>

                    <Border Grid.Row="6" Padding="10"
                            CornerRadius="{DynamicResource MediumRadius}"
                            Background="{DynamicResource Brush.Fill.Info}"
                            BorderBrush="{DynamicResource Brush.Stroke.Status}"
                            BorderThickness="1">
                        <TextBlock Text="{l:Loc FixPieColorsPage.Instruction}"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- FOOTER -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{DynamicResource Brush.Fill.Status}"
                        CornerRadius="{DynamicResource CardRadius}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1" Padding="12,0">
                    <TextBlock x:Name="txtStatus" Text="{l:Loc FixPieColorsPage.Ready}"
                               Foreground="{DynamicResource TextSubBrush}"
                               VerticalAlignment="Center"/>
                </Border>
                <Button x:Name="btnRun" Grid.Column="2" Height="34"
                        Content="{l:Loc FixPieColorsPage.Run}" Style="{DynamicResource PrimaryButton}"
                        Click="btnRun_Click"/>
            </Grid>

            <!-- BUSY OVERLAY -->
            <Grid x:Name="BusyOverlay" Grid.RowSpan="3"
                  Visibility="Collapsed"
                  Background="{DynamicResource Brush.Background.Primary}">
                <Border Background="{DynamicResource Brush.Background.Secondary}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1" Padding="16"
                        CornerRadius="{DynamicResource LargeRadius}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ProgressBar Width="130" Height="16"
                                     IsIndeterminate="True"/>
                        <TextBlock x:Name="txtBusy" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   VerticalAlignment="Center" Text="{l:Loc FixPieColorsPage.Working}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

    </Grid>

</Page>
