<Page x:Class="Som3a_WPF_UI.Pages.StyleSelectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
      Title="{l:Loc StyleSelectorPage.Title}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">
            <TextBlock Text="{l:Loc StyleSelectorPage.Heading}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{l:Loc StyleSelectorPage.ChooseStyle}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMainBrush}"
                       Margin="0,0,0,14"/>

            <ComboBox Grid.Row="1" Margin="0,0,0,16" Height="36"
                      Style="{DynamicResource RoundComboBox}"
                      ItemsSource="{Binding StyleOptions}"
                      SelectedValue="{Binding SelectedStyleId}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"/>

            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="10">
                <ListView ItemsSource="{Binding StylePreviews}"
                          Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{l:Loc StyleSelectorGrid.Level}" Width="100"
                                            DisplayMemberBinding="{Binding Level}"/>
                            <GridViewColumn Header="{l:Loc StyleSelectorGrid.Hex}" Width="180"
                                            DisplayMemberBinding="{Binding Hex}"/>
                            <GridViewColumn Header="{l:Loc StyleSelectorGrid.Color}" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="22"
                                                CornerRadius="{DynamicResource SmallRadius}"
                                                BorderBrush="{DynamicResource Brush.Control.Stroke}"
                                                BorderThickness="1"
                                                Background="{Binding Brush}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{l:Loc StyleSelectorPage.Save}" Width="110" Height="34"
                        Margin="0,0,10,0"
                        Command="{Binding SaveCommand}"
                        Style="{DynamicResource PrimaryButton}"/>
                <Button Content="{l:Loc StyleSelectorPage.Cancel}" Width="110" Height="34"
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource GhostButton}"/>
            </StackPanel>
        </Grid>
    </Grid>

</Page>
