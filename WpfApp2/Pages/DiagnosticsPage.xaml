<local:PageBase x:Class="Som3a_WPF_UI.Pages.DiagnosticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Som3a_WPF_UI.Pages"
      xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.Title]}"
      Background="{DynamicResource Brush.Background.Primary}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.Heading]}" Foreground="{DynamicResource Brush.Text.Primary}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.Refresh]}" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource Brush.Accent.Primary}"
                    Margin="16,0,0,0" Padding="8,4"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Text.Secondary}"
                       FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Style="{DynamicResource MaterialDesignScrollViewer}">
            <StackPanel>
                <controls:WidgetCard Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.RenderModeCard]}" Icon="&#xF0440;" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="14" FontWeight="SemiBold"
                                   Text="{Binding CurrentSnapshot.RenderMode}" Margin="0,0,0,4"/>
                        <TextBlock Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12"
                                   Text="{Binding CurrentSnapshot.RenderModeSource}"/>
                    </StackPanel>
                </controls:WidgetCard>

                <controls:WidgetCard Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.ThemeCard]}" Icon="&#xF0509;" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="14" Margin="0,0,0,4">
                            <Run Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.ActiveLabel]}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                            <Run Text="{Binding CurrentSnapshot.ActiveTheme, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="14">
                            <Run Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.AccentLabel]}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                            <Run Text="{Binding CurrentSnapshot.AccentColor, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </controls:WidgetCard>

                <controls:WidgetCard Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.MemoryCard]}" Icon="&#xF035B;" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="14" Margin="0,0,0,4">
                            <Run Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.WorkingSetLabel]}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                            <Run Text="{Binding CurrentSnapshot.MemoryWorkingSetMB, StringFormat='{}{0:F1}', Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.MemoryUnit]}"/>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource Brush.Text.Primary}" FontSize="14">
                            <Run Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.ManagedLabel]}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                            <Run Text="{Binding CurrentSnapshot.MemoryManagedMB, StringFormat='{}{0:F1}', Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.MemoryUnit]}"/>
                        </TextBlock>
                    </StackPanel>
                </controls:WidgetCard>

                <controls:WidgetCard Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.GpuCard]}" Icon="&#xF0219;" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource Brush.Accent.Danger}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSnapshot.GpuAvailable}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource Brush.Accent.Success}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding CurrentSnapshot.GpuName}" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>
                </controls:WidgetCard>

                <controls:WidgetCard Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.PopupCard]}" Icon="&#xF0417;" Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding CurrentSnapshot.PopupStatus}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12" Margin="0,0,0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:WidgetCard>

                <controls:WidgetCard Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.ValidationCard]}" Icon="&#xF0189;" Margin="0,0,0,12">
                    <StackPanel>
                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[DiagnosticsPage.RunValidation]}" Command="{Binding RunValidationCommand}"
                                Style="{DynamicResource MaterialDesignFlatButton}"
                                Foreground="{DynamicResource Brush.Accent.Primary}"
                                HorizontalContentAlignment="Left"
                                Padding="4,2" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ValidationResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12" Margin="0,0,0,2">
                                        <Run Text="["/>
                                        <Run Text="{Binding Severity, Mode=OneWay}"/>
                                        <Run Text="] "/>
                                        <Run Text="{Binding Description, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </controls:WidgetCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</local:PageBase>
