<Page x:Class="Som3a_WPF_UI.Pages.BOQActivityGeneratorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="BOQ Activity Generator"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" Margin="{DynamicResource TitleBarMargin}">
            <TextBlock Text="BOQ Activity Generator"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- CONTENT CARD -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnLoadBoq" Grid.Column="0" Height="34"
                                Content="Load BOQ"
                                Style="{DynamicResource BaseButton}"
                                Click="btnLoadBoq_Click"/>
                        <TextBlock Grid.Column="2"
                                   Text="Generate construction activities from BOQ data using AI"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="btnGenerate" Grid.Column="4" Height="34"
                                Content="Generate Activities"
                                Style="{DynamicResource PrimaryButton}"
                                Click="btnGenerate_Click"/>
                        <Button x:Name="btnCancel" Grid.Column="6" Height="34"
                                Content="Cancel"
                                Style="{DynamicResource BaseButton}"
                                Click="btnCancel_Click"
                                Visibility="Collapsed"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <TabControl Background="Transparent"
                                    BorderThickness="0">
                            <TabItem Header="BOQ Preview"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     Background="{DynamicResource CardBrush}">
                                <DataGrid x:Name="dgBoqPreview"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          EnableRowVirtualization="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          Background="{DynamicResource CardBrush}"
                                          Foreground="{DynamicResource TextMainBrush}"
                                          BorderBrush="{DynamicResource CardStrokeBrush}"
                                          RowBackground="{DynamicResource CardBrush}"
                                          AlternatingRowBackground="{DynamicResource Brush.Background.Secondary}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Item #" Binding="{Binding ItemNumber}" Width="80"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                        <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                                        <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Generated Activities"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     Background="{DynamicResource CardBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="txtGenerationStatus" Grid.Row="0"
                                               Foreground="{DynamicResource TextSubBrush}"
                                               Text="Click 'Generate Activities' to start."
                                               Visibility="Visible"/>
                                    <TextBlock x:Name="txtEmptyState" Grid.Row="1"
                                           Foreground="{DynamicResource TextSubBrush}"
                                           Text="No activities generated yet. Click 'Generate Activities' above to start."
                                           Visibility="Visible"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <DataGrid x:Name="dgActivities" Grid.Row="2"
                                               AutoGenerateColumns="False"
                                               EnableRowVirtualization="True"
                                               VirtualizingPanel.VirtualizationMode="Recycling"
                                               Background="{DynamicResource CardBrush}"
                                               Foreground="{DynamicResource TextMainBrush}"
                                               BorderBrush="{DynamicResource CardStrokeBrush}"
                                               RowBackground="{DynamicResource CardBrush}"
                                               AlternatingRowBackground="{DynamicResource Brush.Background.Secondary}"
                                               CellEditEnding="dgActivities_CellEditEnding">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="HasErrors">
                                                        <Setter Property="Background" Value="#1AFF0000"/>
                                                        <Setter Property="ToolTip" Value="This activity has validation errors."/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="HasWarnings">
                                                        <Setter Property="Background" Value="#1AFFA500"/>
                                                        <Setter Property="ToolTip" Value="This activity has warnings."/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ValidationStatus}" Value="Passed">
                                                        <Setter Property="Background" Value="#1A00AA00"/>
                                                        <Setter Property="ToolTip" Value="Validation passed."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Activity ID" Binding="{Binding ActivityId}" IsReadOnly="True" Width="90"/>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"/>
                                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="250"/>
                                            <DataGridTextColumn Header="BOQ Reference" Binding="{Binding BoqReferencesDisplay}" IsReadOnly="True" Width="120"/>
                                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                                            <DataGridTextColumn Header="Validation" Binding="{Binding ValidationStatus}" IsReadOnly="True" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Sequencing"
                                      Foreground="{DynamicResource TextMainBrush}"
                                      Background="{DynamicResource CardBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="200"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button x:Name="btnSequence" Height="30"
                                                Content="Sequence Activities"
                                                Style="{DynamicResource PrimaryButton}"
                                                Click="btnSequence_Click"
                                                Margin="0,0,8,0"/>
                                        <Button x:Name="btnSuggestDeps" Height="30"
                                                Content="Suggest Dependencies"
                                                Style="{DynamicResource BaseButton}"
                                                Click="btnSuggestDeps_Click"/>
                                    </StackPanel>
                                    <DataGrid x:Name="dgSequence" Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              Background="{DynamicResource CardBrush}"
                                              Foreground="{DynamicResource TextMainBrush}"
                                              BorderBrush="{DynamicResource CardStrokeBrush}"
                                              RowBackground="{DynamicResource CardBrush}"
                                              AlternatingRowBackground="{DynamicResource Brush.Background.Secondary}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Order" Binding="{Binding SortOrder}" IsReadOnly="True" Width="60"/>
                                            <DataGridTextColumn Header="Activity ID" Binding="{Binding ActivityId}" IsReadOnly="True" Width="90"/>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="WBS Path" Binding="{Binding WbsPath}" Width="150"/>
                                            <DataGridTextColumn Header="Parallel Group" Binding="{Binding ParallelGroup}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Grid.Row="2" Text="Suggested Dependencies"
                                               Foreground="{DynamicResource TextMainBrush}"
                                               FontWeight="SemiBold" Margin="0,8,0,4"/>
                                    <DataGrid x:Name="dgDependencies" Grid.Row="3"
                                              AutoGenerateColumns="False"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              Background="{DynamicResource CardBrush}"
                                              Foreground="{DynamicResource TextMainBrush}"
                                              BorderBrush="{DynamicResource CardStrokeBrush}"
                                              RowBackground="{DynamicResource CardBrush}"
                                              AlternatingRowBackground="{DynamicResource Brush.Background.Secondary}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Predecessor" Binding="{Binding PredecessorId}" IsReadOnly="True" Width="100"/>
                                            <DataGridTextColumn Header="Successor" Binding="{Binding SuccessorId}" IsReadOnly="True" Width="100"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" IsReadOnly="True" Width="100"/>
                                            <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" IsReadOnly="True" Width="80"/>
                                            <DataGridTextColumn Header="Rationale" Binding="{Binding Rationale}" IsReadOnly="True" Width="*"/>
                                            <DataGridCheckBoxColumn Header="Accepted" Binding="{Binding IsAccepted}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Export"
                                     Foreground="{DynamicResource TextMainBrush}"
                                     Background="{DynamicResource CardBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Button x:Name="btnExport" Height="34"
                                                Content="Export to Excel"
                                                Style="{DynamicResource PrimaryButton}"
                                                Click="btnExport_Click"
                                                Margin="0,0,8,0"/>
                                        <CheckBox x:Name="chkIncludeDependencies"
                                                  Content="Include Dependencies"
                                                  Foreground="{DynamicResource TextMainBrush}"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Row="2" Margin="0,8,0,0"
                                            Background="{DynamicResource Brush.Fill.Info}"
                                            CornerRadius="{DynamicResource MediumRadius}"
                                            Padding="10">
                                        <TextBlock x:Name="txtExportStatus"
                                                   Foreground="{DynamicResource TextSubBrush}"
                                                   Text="Export will create a 'Generated Activities' sheet in the active workbook."/>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Border>

            <!-- FOOTER -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{DynamicResource Brush.Fill.Status}"
                        CornerRadius="{DynamicResource CardRadius}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1" Padding="12,0">
                    <TextBlock x:Name="txtStatus" Text="Ready"
                               Foreground="{DynamicResource TextSubBrush}"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- BUSY OVERLAY -->
            <Grid x:Name="BusyOverlay" Grid.RowSpan="3"
                  Visibility="Collapsed"
                  Background="{DynamicResource Brush.Background.Primary}">
                <Border Background="{DynamicResource Brush.Background.Secondary}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1" Padding="16"
                        CornerRadius="{DynamicResource LargeRadius}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ProgressBar Width="130" Height="16"
                                     IsIndeterminate="True"/>
                        <TextBlock x:Name="txtBusy" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   VerticalAlignment="Center" Text="Working..."/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- DATA PRIVACY OVERLAY -->
            <Grid x:Name="PrivacyOverlay" Grid.RowSpan="3"
                  Visibility="Visible"
                  Background="{DynamicResource Brush.Background.Primary}">
                <Border Background="{DynamicResource Brush.Background.Secondary}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1" Padding="24"
                        CornerRadius="{DynamicResource LargeRadius}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="480">
                    <StackPanel>
                        <TextBlock Text="Data Privacy Consent"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   Margin="0,0,0,16">
                        This feature uses AI to generate construction activities from your BOQ data.
                        The BOQ data will be sent to an AI provider for processing.
                        No data is stored or used for training purposes.
                        <LineBreak/><LineBreak/>
                        Do you consent to sending BOQ data for AI-powered activity generation?
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnConsent" Height="34"
                                    Content="I Consent"
                                    Style="{DynamicResource PrimaryButton}"
                                    Click="btnConsent_Click"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="btnDecline" Height="34"
                                    Content="Decline"
                                    Style="{DynamicResource BaseButton}"
                                    Click="btnDecline_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
