<Page x:Class="Som3a_WPF_UI.Pages.FloatPathPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:Som3a.Shared.Models;assembly=Som3a.Shared"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.Title]}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">

            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.Heading]}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <Border Padding="12" CornerRadius="{DynamicResource CardRadius}"
                                Background="{DynamicResource Brush.Fill.Info}"
                                BorderBrush="{DynamicResource Brush.Stroke.Status}"
                                BorderThickness="1" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.Project]}" FontSize="13"
                                           Foreground="{DynamicResource TextSubBrush}"/>
                                <TextBlock Text="{Binding ProjectName}" FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.LoadXer]}" FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   Margin="0,0,0,10"/>

                        <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.BrowseXer]}"
                                Command="{Binding LoadXerCommand}"
                                Style="{DynamicResource PrimaryButton}"
                                Height="42" Margin="0,0,0,16"/>

                        <Border Background="{DynamicResource Brush.Background.CardSubtle}"
                                BorderBrush="{DynamicResource Brush.Stroke.Status}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource CardRadius}"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.SelectActivity]}"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Activities}"
                                          SelectedItem="{Binding SelectedActivity}"
                                          DisplayMemberPath="Code"
                                          Margin="0,0,0,12"
                                          Style="{DynamicResource RoundComboBox}"/>

                                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.NumberOfPaths]}"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding PathCount}"
                                         Style="{DynamicResource ReadOnlyTextBox}"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.MaxPathDepth]}"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding MaxDepth}"
                                         Style="{DynamicResource ReadOnlyTextBox}"
                                         Margin="0,0,0,12"/>

                                <CheckBox Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.HighlightCritical]}"
                                          IsChecked="{Binding HighlightCritical}"
                                          Margin="0,0,0,16"/>

                                <Button Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.RunFloatPath]}"
                                        Command="{Binding RunCommand}"
                                        Style="{DynamicResource PrimaryButton}"
                                        Height="42"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.ViewMode]}" FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   Margin="0,20,0,8"/>

                        <ComboBox ItemsSource="{Binding ViewModes}"
                                  SelectedItem="{Binding SelectedViewMode, Mode=TwoWay}"
                                  Style="{DynamicResource RoundComboBox}"/>

                        <Border Margin="0,20,0,0" Padding="10"
                                CornerRadius="{DynamicResource CardRadius}"
                                Background="{DynamicResource Brush.Fill.Info}"
                                BorderBrush="{DynamicResource Brush.Stroke.Status}"
                                BorderThickness="1">
                            <Grid>
                                <ProgressBar Height="20"
                                             IsIndeterminate="{Binding IsLoading}"/>
                                <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[FloatPathPage.Processing]}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMainBrush}"
                                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="10">
                <Grid>
                    <TreeView Visibility="{Binding IsWbsView, Converter={StaticResource BoolToVisibilityConverter}}"
                              ItemsSource="{Binding WBSItems}"
                              SelectedItemChanged="Tree_SelectedItemChanged"
                              Panel.ZIndex="1"
                              Background="Transparent"
                              BorderThickness="0">

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="False"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border x:Name="RowBorder"
                                                        Background="{Binding Background}"
                                                        CornerRadius="8" Margin="0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ToggleButton x:Name="Expander" Grid.Column="0"
                                                                      Width="14" Height="14" Margin="6,0"
                                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                      ClickMode="Press">
                                                            <TextBlock Text="+" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontWeight="Bold"/>
                                                        </ToggleButton>
                                                        <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                                          VerticalAlignment="Center" Margin="6,4"/>
                                                    </Grid>
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost"
                                                    Visibility="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseDirectlyOver" Value="True">
                                                    <Setter TargetName="RowBorder" Property="Background"
                                                            Value="{DynamicResource Brush.Control.HoverBackground}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="RowBorder" Property="Background"
                                                            Value="{DynamicResource Brush.Control.SelectedBackground}"/>
                                                </Trigger>
                                                <Trigger Property="IsExpanded" Value="True">
                                                    <Setter TargetName="Expander" Property="Content">
                                                        <Setter.Value>
                                                            <TextBlock Text="-" FontWeight="Bold"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility"
                                                            Value="Hidden"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>

                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type models:WbsItem}"
                                                      ItemsSource="{Binding Items}">
                                <TextBlock Text="{Binding Display}" FontWeight="Bold" Margin="5,2"/>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type models:Activity}">
                                <TextBlock Text="{Binding DisplayActivity}" Margin="5,2"/>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <wv2:WebView2 x:Name="GraphBrowser"
                                  Visibility="{Binding IsGraphView, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Panel.ZIndex="2"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>

</Page>
