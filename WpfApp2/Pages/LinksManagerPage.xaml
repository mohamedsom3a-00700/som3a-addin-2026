<Page x:Class="Som3a_WPF_UI.Pages.LinksManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Title]}"
      Background="{DynamicResource Brush.Background.Primary.Translucent}"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid Margin="14">

        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Margin="{DynamicResource TitleBarMargin}">

            <TextBlock Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Heading]}"
                       Foreground="{DynamicResource TextMainBrush}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SETTINGS -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource LargeRadius}"
                    Padding="14" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Workbook]}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Height="34"
                              ItemsSource="{Binding Workbooks}"
                              SelectedItem="{Binding SelectedWorkbook}"
                              DisplayMemberPath="Name"
                              Style="{DynamicResource RoundComboBox}"/>
                    <Button Grid.Row="0" Grid.Column="3" Height="34"
                            Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Refresh]}" Style="{DynamicResource BaseButton}"
                            Command="{Binding RefreshWorkbooksCommand}"/>
                    <Button Grid.Row="0" Grid.Column="4" Height="34"
                            Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.LoadTypes]}" Style="{DynamicResource BaseButton}"
                            Command="{Binding LoadTypesCommand}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Type]}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Height="34"
                              ItemsSource="{Binding LinkTypes}"
                              SelectedItem="{Binding SelectedType}"
                              DisplayMemberPath="DisplayName"
                              Style="{DynamicResource RoundComboBox}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3"
                               Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Search]}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>
                    <TextBox Grid.Row="1" Grid.Column="4" Height="34"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ReadOnlyTextBox}"/>
                    <Button Grid.Row="1" Grid.Column="6" Height="34"
                            Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Reload]}" Style="{DynamicResource PrimaryButton}"
                            Command="{Binding ReloadLinksCommand}"/>
                </Grid>
            </Border>

            <!-- MAIN AREA -->
            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource LargeRadius}"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Types]}" FontSize="16"
                                   FontWeight="SemiBold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextMainBrush}"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding LinkTypes}"
                                  SelectedItem="{Binding SelectedType}"
                                  ItemContainerStyle="{DynamicResource AccentListViewItem}"
                                  Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerTypeGrid.Type]}" Width="250"
                                                    DisplayMemberBinding="{Binding DisplayName}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource LargeRadius}"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.All]}" Padding="14,6"
                                    Style="{DynamicResource BaseButton}"
                                    Command="{Binding SelectAllLinksCommand}"/>
                            <Button Grid.Column="2" Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.None]}" Padding="14,6"
                                    Style="{DynamicResource BaseButton}"
                                    Command="{Binding UnselectAllLinksCommand}"/>
                            <TextBlock Grid.Column="4" Text="{Binding SelectedCountText}"
                                       Foreground="{DynamicResource TextSubBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{Binding Links}"
                                  ItemContainerStyle="{DynamicResource AccentListViewItem}"
                                  Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerGrid.Select]}" Width="50">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerGrid.LinkSource]}" Width="200"
                                                    DisplayMemberBinding="{Binding LinkSource}"/>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerGrid.SheetObject]}" Width="160"
                                                    DisplayMemberBinding="{Binding SheetOrObject}"/>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerGrid.CellDetail]}" Width="160"
                                                    DisplayMemberBinding="{Binding CellOrDetail}"/>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerGrid.Type]}" Width="120"
                                                    DisplayMemberBinding="{Binding Type}"/>
                                    <GridViewColumn Header="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerGrid.Status]}" Width="120"
                                                    DisplayMemberBinding="{Binding Status}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- PROGRESS -->
            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="20"
                        CornerRadius="{DynamicResource MediumRadius}"
                        Background="{DynamicResource Brush.Progress.Background}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Center" Margin="0,0,10,0">
                    <Grid ClipToBounds="True">
                        <Border CornerRadius="{DynamicResource MediumRadius}"
                                HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5"
                                Background="{DynamicResource Brush.Accent.ProgressFill}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleY="1"
                                    ScaleX="{Binding ProgressPercent, Converter={StaticResource PercentToScaleConverter}}"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Height="30"
                        CornerRadius="{DynamicResource MediumRadius}"
                        Background="{DynamicResource ControlBgBrush}"
                        BorderBrush="{DynamicResource ControlStrokeBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                               Foreground="{DynamicResource TextOnAccentBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- BUTTONS -->
            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="34" Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Break]}"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding BreakSelectedCommand}"
                        IsEnabled="{Binding CanBreak}"/>
                <Button Grid.Column="2" Height="34" Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[LinksManagerPage.Close]}"
                        Style="{DynamicResource GhostButton}"
                        Command="{Binding CloseCommand}"/>
            </Grid>

            <!-- STATUS -->
            <Border Grid.Row="4"
                    Background="{DynamicResource Brush.Fill.Status}"
                    CornerRadius="{DynamicResource CardRadius}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    Padding="{DynamicResource StatusBarPadding}">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSubBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

        </Grid>

    </Grid>

</Page>
