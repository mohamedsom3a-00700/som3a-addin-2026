<controls:ModernWindow x:Class="Som3a_WPF_UI.Windows.PrimaveraComparison.PrimaveraCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        Title="Primavera Compare"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">



    <!-- ROOT -->

    <Border CornerRadius="18"
            Background="{DynamicResource Brush.Background.Root}"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <Grid Margin="14">

            <Grid.RowDefinitions>

                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <!-- TITLE BAR -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <TextBlock Text="Primavera Compare"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- CONTENT -->

            <Grid Grid.Row="1"
                  Margin="8">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- CONNECTION -->

                <Border Grid.Row="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,16">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>

                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Database Type"
                                   Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="1"
                                   Text="Connection String"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   Margin="14,0,0,6"
                                   FontWeight="SemiBold"/>

                        <ComboBox Grid.Row="1"
                                  Grid.Column="0"
                                  Height="38"
                                  Style="{DynamicResource RoundComboBox}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding SelectedDatabaseType}">

                            <ComboBoxItem Content="SQLite"/>
                            <ComboBoxItem Content="Oracle"/>

                        </ComboBox>

                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Height="38"
                                 Margin="14,0,0,0"
                                 Style="{DynamicResource ReadOnlyTextBox}"
                                 Text="{Binding ConnectionString}"/>

                        <Button Grid.Row="1"
                                Grid.Column="2"
                                Height="38"
                                Margin="14,0,0,0"
                                Style="{DynamicResource BaseButton}"
                                Content="Browse"
                                Click="BrowseButton_Click"/>

                        <Button Grid.Row="1"
                                Grid.Column="3"
                                Height="38"
                                Margin="10,0,0,0"
                                Style="{DynamicResource PrimaryButton}"
                                Content="Connect"
                                Command="{Binding ConnectCommand}"/>

                    </Grid>

                </Border>

                <!-- SEARCH -->

                <Grid Grid.Row="1"
                      Margin="0,0,0,16">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>

                    </Grid.ColumnDefinitions>

                    <TextBox Height="38"
                             Style="{DynamicResource ReadOnlyTextBox}"
                             Text="{Binding SearchText}"/>

                    <Button Grid.Column="1"
                            Height="38"
                            Margin="14,0,0,0"
                            Style="{DynamicResource PrimaryButton}"
                            Content="Compare"
                            Command="{Binding CompareCommand}"/>

                </Grid>

                <!-- GRID -->

                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="0">

                    <DataGrid x:Name="ProjectsGrid"
                              ItemsSource="{Binding FilteredProjects}"
                              AutoGenerateColumns="False"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              SelectionChanged="ProjectsGrid_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Project ID"
                                                Binding="{Binding ProjectId}"
                                                Width="110"/>

                            <DataGridTextColumn Header="Project Code"
                                                Binding="{Binding ProjectCode}"
                                                Width="180"/>

                            <DataGridTextColumn Header="Project Name"
                                                Binding="{Binding ProjectName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="140"/>

                            <DataGridTextColumn Header="Planned Start"
                                                Binding="{Binding PlannedStartDate, StringFormat=d}"
                                                Width="130"/>

                            <DataGridTextColumn Header="Planned Finish"
                                                Binding="{Binding PlannedFinishDate, StringFormat=d}"
                                                Width="130"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Border>

                <!-- STATUS -->

                <Grid Grid.Row="3"
                      Margin="0,16,0,0">

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource TextSubBrush}"
                               Margin="0,0,0,8"/>

                    <ProgressBar Grid.Row="1"
                                 Height="16"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue}"/>

                </Grid>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>