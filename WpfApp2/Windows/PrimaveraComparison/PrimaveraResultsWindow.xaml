<controls:ModernWindow x:Class="Som3a_WPF_UI.Windows.PrimaveraComparison.PrimaveraResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        Title="Primavera Comparison Results"
        Height="760"
        Width="1220"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <controls:ModernWindow.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ThemeResources.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </controls:ModernWindow.Resources>

    <Border CornerRadius="18"
            Background="{DynamicResource Brush.Background.Root}"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <Grid Margin="14">

            <Grid.RowDefinitions>

                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <!-- TITLE BAR -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <TextBlock Text="Primavera Comparison Results"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- CONTENT -->

            <Grid Grid.Row="1"
                  Margin="8">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <!-- HEADER -->

                <Border Grid.Row="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16"
                        Margin="0,0,0,16">

                    <StackPanel>

                        <TextBlock Text="{Binding Result}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   Text="{Binding Result.Summary}"/>

                    </StackPanel>

                </Border>

                <!-- TABS -->

                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10">

                    <TabControl>

                        <TabItem Header="Activities">
                            <DataGrid ItemsSource="{Binding ActivityRows}"/>
                        </TabItem>

                        <TabItem Header="Relationships">
                            <DataGrid ItemsSource="{Binding RelationshipRows}"/>
                        </TabItem>

                        <TabItem Header="Resources">
                            <DataGrid ItemsSource="{Binding ResourceRows}"/>
                        </TabItem>

                    </TabControl>

                </Border>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>