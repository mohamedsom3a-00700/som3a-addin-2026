<controls:ModernWindow x:Class="Som3a_WPF_UI.UnmergeFillDownWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:local="clr-namespace:Som3a_WPF_UI.Converters"
                        mc:Ignorable="d"
                        Title="Unmerge Fill Down"
                        Height="460"
                        Width="640"
                        ResizeMode="NoResize"
                        WindowStartupLocation="CenterOwner"
                        WindowStyle="None"
                        AllowsTransparency="True"
                        Background="Transparent"
                        TitleBarHeight="40"
                        ShowMaximizeButton="False"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        Loaded="Window_Loaded">

    <controls:ModernWindow.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ThemeResources.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </controls:ModernWindow.Resources>

    <!-- ===================================================== -->
    <!-- ROOT CARD -->
    <!-- ===================================================== -->

    <Border x:Name="RootBorder"
            CornerRadius="18"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <!-- BACKGROUND -->

        <Border.Background>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">

                <GradientStop Color="#FF102A43"
                              Offset="0"/>

                <GradientStop Color="#FF0F3B3B"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.Background>

        <!-- ================================================= -->
        <!-- ROOT GRID -->
        <!-- ================================================= -->

        <Grid Margin="12">

            <Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <RowDefinition Height="42"/>

                <!-- CONTENT -->
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <!-- ================================================= -->
            <!-- TITLE BAR -->
            <!-- ================================================= -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="8"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <!-- TITLE -->

                <TextBlock Text="Unmerge Fill Down"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- MINIMIZE -->

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <!-- CLOSE -->

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- ================================================= -->
            <!-- MAIN CONTENT -->
            <!-- ================================================= -->

            <Grid Grid.Row="1">

                <Grid.RowDefinitions>

                    <!-- SETTINGS -->
                    <RowDefinition Height="Auto"/>

                    <!-- SPACING -->
                    <RowDefinition Height="14"/>

                    <!-- PROGRESS -->
                    <RowDefinition Height="Auto"/>

                    <!-- SPACING -->
                    <RowDefinition Height="14"/>

                    <!-- BUTTONS -->
                    <RowDefinition Height="Auto"/>

                    <!-- SPACING -->
                    <RowDefinition Height="14"/>

                    <!-- STATUS -->
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- ============================================= -->
                <!-- SETTINGS -->
                <!-- ============================================= -->

                <Border Grid.Row="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="220"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="42"/>

                            <RowDefinition Height="42"/>

                            <RowDefinition Height="42"/>

                            <RowDefinition Height="Auto"/>

                        </Grid.RowDefinitions>

                        <!-- ACTIVE SHEET -->

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Active Sheet"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Margin="8,0,0,0"
                                 Text="{Binding ActiveSheetName}"
                                 IsReadOnly="True"/>

                        <!-- HEADER ROW -->

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Header Row"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="8,0,0,0"
                                 Text="{Binding HeaderRow}"/>

                        <!-- COLUMN -->

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Column Letter"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="8,0,0,0"
                                  ItemsSource="{Binding Columns}"
                                  SelectedItem="{Binding SelectedColumn, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource RoundComboBox}"/>

                        <!-- INFO -->

                        <Border Grid.Row="3"
                                Grid.ColumnSpan="2"
                                Margin="0,12,0,0"
                                Padding="10"
                                CornerRadius="10"
                                Background="#12FFFFFF"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1">

                            <TextBlock Text="{Binding InfoText}"
                                       Foreground="{DynamicResource TextSubBrush}"
                                       TextWrapping="Wrap"/>

                        </Border>

                    </Grid>

                </Border>

                <!-- ============================================= -->
                <!-- PROGRESS -->
                <!-- ============================================= -->

                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="90"/>

                    </Grid.ColumnDefinitions>

                    <!-- PROGRESS BAR -->

                    <Border Grid.Column="0"
                            Height="24"
                            Margin="0,0,10,0"
                            Background="#22000000"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            VerticalAlignment="Center">

                        <Grid ClipToBounds="True">

                            <Border CornerRadius="10"
                                    HorizontalAlignment="Stretch"
                                    RenderTransformOrigin="0,0.5">

                                <Border.Background>

                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">

                                        <GradientStop Color="#FF1ABC9C"
                                                      Offset="0"/>

                                        <GradientStop Color="#FF2ECC71"
                                                      Offset="1"/>

                                    </LinearGradientBrush>

                                </Border.Background>

                                <!-- IMPORTANT -->
                                <!-- REMOVED DROPSHADOW FOR EXCEL/VSTO -->

                                <Border.RenderTransform>

                                    <ScaleTransform ScaleY="1"
                                                    ScaleX="{Binding ProgressPercent,
                                                    Converter={StaticResource PercentToScaleConverter}}"/>

                                </Border.RenderTransform>

                            </Border>

                        </Grid>

                    </Border>

                    <!-- PERCENT -->

                    <Border Grid.Column="1"
                            Height="30"
                            Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource ControlStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            VerticalAlignment="Center">

                        <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                </Grid>

                <!-- ============================================= -->
                <!-- BUTTONS -->
                <!-- ============================================= -->

                <Grid Grid.Row="4">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="10"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <!-- RUN -->

                    <Button Grid.Column="0"
                            Height="36"
                            Content="Run"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding RunCommand}"
                            IsEnabled="{Binding CanRun}"/>

                    <!-- CLOSE -->

                    <Button Grid.Column="2"
                            Height="36"
                            Content="Close"
                            Style="{DynamicResource BaseButton}"
                            Command="{Binding CloseCommand}"/>

                </Grid>

                <!-- ============================================= -->
                <!-- STATUS -->
                <!-- ============================================= -->

                <Border Grid.Row="6"
                        Background="#1FFFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,6">

                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSubBrush}"
                               TextTrimming="CharacterEllipsis"/>

                </Border>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>