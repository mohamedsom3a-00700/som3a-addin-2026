<controls:ModernWindow x:Class="Som3a_WPF_UI.Views.LinksManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        Title="Links Manager"
        Height="760"
        Width="1100"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">



    <!-- ===================================================== -->
    <!-- ROOT -->
    <!-- ===================================================== -->

    <Border x:Name="RootBorder"
            CornerRadius="18"
            Background="{DynamicResource Brush.Background.Root}"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <!-- ================================================= -->
        <!-- ROOT GRID -->
        <!-- ================================================= -->

        <Grid Margin="14">

            <Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <RowDefinition Height="42"/>

                <!-- CONTENT -->
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <!-- ================================================= -->
            <!-- TITLE BAR -->
            <!-- ================================================= -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <!-- TITLE -->

                <TextBlock Text="Links Manager"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- MINIMIZE -->

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <!-- CLOSE -->

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- ================================================= -->
            <!-- CONTENT -->
            <!-- ================================================= -->

            <Grid Grid.Row="1"
                  Margin="6">

                <Grid.RowDefinitions>

                    <!-- SETTINGS -->
                    <RowDefinition Height="Auto"/>

                    <!-- MAIN -->
                    <RowDefinition Height="*"/>

                    <!-- PROGRESS -->
                    <RowDefinition Height="Auto"/>

                    <!-- BUTTONS -->
                    <RowDefinition Height="Auto"/>

                    <!-- STATUS -->
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- ================================================= -->
                <!-- SETTINGS -->
                <!-- ================================================= -->

                <Border Grid.Row="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,14">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>

                        </Grid.RowDefinitions>

                        <!-- WORKBOOK -->

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Workbook"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <ComboBox Grid.Row="0"
                                  Grid.Column="1"
                                  Height="34"
                                  ItemsSource="{Binding Workbooks}"
                                  SelectedItem="{Binding SelectedWorkbook}"
                                  DisplayMemberPath="Name"
                                  Style="{DynamicResource RoundComboBox}"/>

                        <!-- REFRESH -->

                        <Button Grid.Row="0"
                                Grid.Column="3"
                                Height="34"
                                Content="Refresh"
                                Style="{DynamicResource BaseButton}"
                                Command="{Binding RefreshWorkbooksCommand}"/>

                        <!-- LOAD TYPES -->

                        <Button Grid.Row="0"
                                Grid.Column="4"
                                Height="34"
                                Content="Load Types"
                                Style="{DynamicResource BaseButton}"
                                Command="{Binding LoadTypesCommand}"/>

                        <!-- TYPE -->

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Type"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Height="34"
                                  ItemsSource="{Binding LinkTypes}"
                                  SelectedItem="{Binding SelectedType}"
                                  DisplayMemberPath="DisplayName"
                                  Style="{DynamicResource RoundComboBox}"/>

                        <!-- SEARCH -->

                        <TextBlock Grid.Row="1"
                                   Grid.Column="3"
                                   Text="Search"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <TextBox Grid.Row="1"
                                 Grid.Column="4"
                                 Height="34"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource ReadOnlyTextBox}"/>

                        <!-- RELOAD -->

                        <Button Grid.Row="1"
                                Grid.Column="6"
                                Height="34"
                                Content="Reload"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding ReloadLinksCommand}"/>

                    </Grid>

                </Border>

                <!-- ================================================= -->
                <!-- MAIN AREA -->
                <!-- ================================================= -->

                <Grid Grid.Row="1"
                      Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <!-- TYPES -->

                    <Border Grid.Column="0"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource CardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10">

                        <Grid>

                            <Grid.RowDefinitions>

                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>

                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Types"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"
                                       Foreground="{DynamicResource TextMainBrush}"/>

                            <ListView Grid.Row="1"
                                      ItemsSource="{Binding LinkTypes}"
                                      SelectedItem="{Binding SelectedType}"
                                      ItemContainerStyle="{DynamicResource AccentListViewItem}"
                                      Background="Transparent"
                                      BorderThickness="0">

                                <ListView.View>

                                    <GridView>

                                        <GridViewColumn Header="Type"
                                                        Width="250"
                                                        DisplayMemberBinding="{Binding DisplayName}"/>

                                    </GridView>

                                </ListView.View>

                            </ListView>

                        </Grid>

                    </Border>

                    <!-- LINKS -->

                    <Border Grid.Column="2"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource CardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10">

                        <Grid>

                            <Grid.RowDefinitions>

                                <!-- TOP -->
                                <RowDefinition Height="Auto"/>

                                <!-- LIST -->
                                <RowDefinition Height="*"/>

                            </Grid.RowDefinitions>

                            <!-- ACTIONS -->

                            <Grid Grid.Row="0"
                                  Margin="0,0,0,10">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>

                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="All"
                                        Padding="14,6"
                                        Style="{DynamicResource BaseButton}"
                                        Command="{Binding SelectAllLinksCommand}"/>

                                <Button Grid.Column="2"
                                        Content="None"
                                        Padding="14,6"
                                        Style="{DynamicResource BaseButton}"
                                        Command="{Binding UnselectAllLinksCommand}"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding SelectedCountText}"
                                           Foreground="{DynamicResource TextSubBrush}"
                                           VerticalAlignment="Center"/>

                            </Grid>

                            <!-- LIST -->

                            <ListView Grid.Row="1"
                                      ItemsSource="{Binding Links}"
                                      ItemContainerStyle="{DynamicResource AccentListViewItem}"
                                      Background="Transparent"
                                      BorderThickness="0">

                                <ListView.View>

                                    <GridView>

                                        <!-- SELECT -->

                                        <GridViewColumn Header="Sel."
                                                        Width="50">

                                            <GridViewColumn.CellTemplate>

                                                <DataTemplate>

                                                    <CheckBox IsChecked="{Binding IsSelected,
                                                              Mode=TwoWay,
                                                              UpdateSourceTrigger=PropertyChanged}"/>

                                                </DataTemplate>

                                            </GridViewColumn.CellTemplate>

                                        </GridViewColumn>

                                        <!-- SOURCE -->

                                        <GridViewColumn Header="Link Source"
                                                        Width="200"
                                                        DisplayMemberBinding="{Binding LinkSource}"/>

                                        <!-- SHEET -->

                                        <GridViewColumn Header="Sheet/Object"
                                                        Width="160"
                                                        DisplayMemberBinding="{Binding SheetOrObject}"/>

                                        <!-- DETAIL -->

                                        <GridViewColumn Header="Cell/Detail"
                                                        Width="160"
                                                        DisplayMemberBinding="{Binding CellOrDetail}"/>

                                        <!-- TYPE -->

                                        <GridViewColumn Header="Type"
                                                        Width="120"
                                                        DisplayMemberBinding="{Binding Type}"/>

                                        <!-- STATUS -->

                                        <GridViewColumn Header="Status"
                                                        Width="120"
                                                        DisplayMemberBinding="{Binding Status}"/>

                                    </GridView>

                                </ListView.View>

                            </ListView>

                        </Grid>

                    </Border>

                </Grid>

                <!-- ================================================= -->
                <!-- PROGRESS -->
                <!-- ================================================= -->

                <Grid Grid.Row="2"
                      Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>

                    </Grid.ColumnDefinitions>

                    <!-- BAR -->

                    <Border Grid.Column="0"
                            Height="20"
                            CornerRadius="10"
                            Background="{DynamicResource Brush.Progress.Background}"
                            BorderBrush="{DynamicResource CardStrokeBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">

                        <Grid ClipToBounds="True">

                            <Border CornerRadius="10"
                                    HorizontalAlignment="Stretch"
                                    RenderTransformOrigin="0,0.5"
                                    Background="{DynamicResource Brush.Accent.ProgressFill}">

                                <!-- IMPORTANT -->
                                <!-- REMOVED DROPSHADOW FOR EXCEL/VSTO -->

                                <Border.RenderTransform>

                                    <ScaleTransform ScaleY="1"
                                        ScaleX="{Binding ProgressPercent,
                                        Converter={StaticResource PercentToScaleConverter}}"/>

                                </Border.RenderTransform>

                            </Border>

                        </Grid>

                    </Border>

                    <!-- PERCENT -->

                    <Border Grid.Column="1"
                            Height="30"
                            CornerRadius="10"
                            Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource ControlStrokeBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">

                        <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                </Grid>

                <!-- ================================================= -->
                <!-- BUTTONS -->
                <!-- ================================================= -->

                <Grid Grid.Row="3"
                      Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="34"
                            Content="Break"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding BreakSelectedCommand}"
                            IsEnabled="{Binding CanBreak}"/>

                    <Button Grid.Column="2"
                            Height="34"
                            Content="Close"
                            Style="{DynamicResource GhostButton}"
                            Command="{Binding CloseCommand}"/>

                </Grid>

                <!-- ================================================= -->
                <!-- STATUS -->
                <!-- ================================================= -->

                <Border Grid.Row="4"
                        Background="{DynamicResource Brush.Fill.Status}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        Padding="10,6">

                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSubBrush}"
                               TextTrimming="CharacterEllipsis"/>

                </Border>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>