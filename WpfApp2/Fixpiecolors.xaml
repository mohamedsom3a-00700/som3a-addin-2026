<controls:ModernWindow x:Class="Som3a_WPF_UI.FixPieColorsWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        mc:Ignorable="d"
                        Title="Fix Pie Chart Colors"
                        Height="230"
                        Width="620"
                        WindowStartupLocation="CenterOwner"
                        WindowStyle="None"
                        AllowsTransparency="True"
                        Background="Transparent"
                        TitleBarHeight="36"
                        ShowMaximizeButton="False"
                        ResizeMode="NoResize"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">

    <controls:ModernWindow.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ThemeResources.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </controls:ModernWindow.Resources>

    <!-- ===================================================== -->
    <!-- ROOT CARD -->
    <!-- ===================================================== -->

    <Border x:Name="RootBorder"
            CornerRadius="18"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <!-- BACKGROUND -->

        <Border.Background>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">

                <GradientStop Color="#FF102A43"
                              Offset="0"/>

                <GradientStop Color="#FF0F3B3B"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.Background>

        <!-- ================================================= -->
        <!-- ROOT GRID -->
        <!-- ================================================= -->

        <Grid Margin="12">

            <Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <RowDefinition Height="42"/>

                <!-- CONTENT -->
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <!-- ================================================= -->
            <!-- TITLE BAR -->
            <!-- ================================================= -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="8"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <!-- TITLE -->

                <TextBlock Text="Fix Pie Chart Colors"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- MINIMIZE -->

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <!-- CLOSE -->

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- ================================================= -->
            <!-- MAIN CONTENT -->
            <!-- ================================================= -->

            <Grid Grid.Row="1">

                <Grid.RowDefinitions>

                    <!-- CONTENT -->
                    <RowDefinition Height="*"/>

                    <!-- SPACING -->
                    <RowDefinition Height="12"/>

                    <!-- FOOTER -->
                    <RowDefinition Height="36"/>

                </Grid.RowDefinitions>

                <!-- ============================================= -->
                <!-- CONTENT CARD -->
                <!-- ============================================= -->

                <Border Grid.Row="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16">

                    <Grid>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>

                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>

                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>

                            <RowDefinition Height="Auto"/>

                        </Grid.RowDefinitions>

                        <!-- ===================================== -->
                        <!-- SHEET -->
                        <!-- ===================================== -->

                        <Grid Grid.Row="0">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>

                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Select Sheet for Pie Chart"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMainBrush}"/>

                            <ComboBox x:Name="cmbSheets"
                                      Grid.Column="1"
                                      Style="{DynamicResource RoundComboBox}"/>

                        </Grid>

                        <!-- ===================================== -->
                        <!-- CATEGORY RANGE -->
                        <!-- ===================================== -->

                        <Grid Grid.Row="2">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>

                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Category Range (Labels)"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMainBrush}"/>

                            <TextBox x:Name="txtCategoryRange"
                                     Grid.Column="1"
                                     Margin="8,0"
                                     Text="R6:R13"/>

                            <Button x:Name="btnPickRange"
                                    Grid.Column="2"
                                    Content="Pick"
                                    Style="{DynamicResource BaseButton}"
                                    Click="btnPickRange_Click"/>

                        </Grid>

                        <!-- ===================================== -->
                        <!-- COLOR TABLE RANGE -->
                        <!-- ===================================== -->

                        <Grid Grid.Row="4">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>

                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Color Table Range (Label + Color)"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMainBrush}"/>

                            <TextBox x:Name="txtColorTableRange"
                                     Grid.Column="1"
                                     Margin="8,0"
                                     Text="A2:B9"/>

                            <Button x:Name="btnPickColorTable"
                                    Grid.Column="2"
                                    Content="Pick"
                                    Style="{DynamicResource BaseButton}"
                                    Click="btnPickColorTable_Click"/>

                        </Grid>

                        <!-- ===================================== -->
                        <!-- INFO -->
                        <!-- ===================================== -->

                        <Border Grid.Row="6"
                                Padding="10"
                                CornerRadius="10"
                                Background="#12FFFFFF"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1">

                            <TextBlock Text="Select chart ranges then click Run."
                                       Foreground="{DynamicResource TextSubBrush}"
                                       VerticalAlignment="Center"/>

                        </Border>

                    </Grid>

                </Border>

                <!-- ============================================= -->
                <!-- FOOTER -->
                <!-- ============================================= -->

                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="160"/>

                    </Grid.ColumnDefinitions>

                    <!-- STATUS -->

                    <Border Grid.Column="0"
                            Background="#1FFFFFFF"
                            CornerRadius="12"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            Padding="12,0">

                        <TextBlock x:Name="txtStatus"
                                   Text="Ready"
                                   Foreground="{DynamicResource TextSubBrush}"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <!-- RUN -->

                    <Button x:Name="btnRun"
                            Grid.Column="2"
                            Height="34"
                            Content="Run"
                            Style="{DynamicResource PrimaryButton}"
                            Click="btnRun_Click"/>

                </Grid>

                <!-- ============================================= -->
                <!-- BUSY OVERLAY -->
                <!-- ============================================= -->

                <Grid x:Name="BusyOverlay"
                      Grid.RowSpan="3"
                      Visibility="Collapsed"
                      Background="#66000000">

                    <Border Background="#CC0E1720"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            Padding="16"
                            CornerRadius="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <ProgressBar Width="130"
                                         Height="16"
                                         IsIndeterminate="True"/>

                            <TextBlock x:Name="txtBusy"
                                       Margin="12,0,0,0"
                                       Foreground="{DynamicResource TextMainBrush}"
                                       VerticalAlignment="Center"
                                       Text="Working..."/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>