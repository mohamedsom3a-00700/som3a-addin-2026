<controls:ModernWindow x:Class="Som3a_WPF_UI.AssignTradeCodesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        xmlns:local="clr-namespace:Som3a_WPF_UI.Converters"
        mc:Ignorable="d"
        Title="Trades Codes"
        Height="764"
        Width="640"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">



    <!-- ===================================================== -->
    <!-- ROOT -->
    <!-- ===================================================== -->

    <Border x:Name="RootBorder"
            CornerRadius="18"
            Background="{DynamicResource Brush.Background.Root}"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <!-- ================================================= -->
        <!-- ROOT GRID -->
        <!-- ================================================= -->

        <Grid Margin="14">

            <Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <RowDefinition Height="42"/>

                <!-- CONTENT -->
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <!-- ================================================= -->
            <!-- TITLE BAR -->
            <!-- ================================================= -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <!-- TITLE -->

                <TextBlock Text="Trades Codes"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- MINIMIZE -->

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <!-- CLOSE -->

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- ================================================= -->
            <!-- CONTENT -->
            <!-- ================================================= -->

            <Grid Grid.Row="1"
                  Margin="6">

                <Grid.RowDefinitions>

                    <!-- SETTINGS -->
                    <RowDefinition Height="Auto"/>

                    <!-- LIST -->
                    <RowDefinition Height="*"/>

                    <!-- PROGRESS -->
                    <RowDefinition Height="Auto"/>

                    <!-- BUTTONS -->
                    <RowDefinition Height="Auto"/>

                    <!-- STATUS -->
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- ================================================= -->
                <!-- SETTINGS -->
                <!-- ================================================= -->

                <Border Grid.Row="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,14">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>

                        </Grid.RowDefinitions>

                        <!-- MAIN SHEET -->

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Main Sheet"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <ComboBox Grid.Row="0"
                                  Grid.Column="1"
                                  Margin="10,0,0,0"
                                  Height="34"
                                  ItemsSource="{Binding Sheets}"
                                  SelectedItem="{Binding MainSheet, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource RoundComboBox}"/>

                        <!-- REFERENCE SHEET -->

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Reference Sheet"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="10,0,0,0"
                                  Height="34"
                                  ItemsSource="{Binding Sheets}"
                                  SelectedItem="{Binding RefSheet, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource RoundComboBox}"/>

                        <!-- CODE COLUMN -->

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="CODE Column (Auto)"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Orientation="Horizontal">

                            <TextBox Width="70"
                                     Height="34"
                                     Margin="0,0,10,0"
                                     Text="{Binding CodeColLetter}"
                                     IsReadOnly="True"
                                     Style="{DynamicResource ReadOnlyTextBox}"/>

                            <TextBox Width="220"
                                     Height="34"
                                     Text="{Binding CodeColHeader}"
                                     IsReadOnly="True"
                                     Style="{DynamicResource ReadOnlyTextBox}"/>

                        </StackPanel>

                        <!-- ACTIVITY COLUMN -->

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="Activity ID Column (Auto)"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Orientation="Horizontal">

                            <TextBox Width="70"
                                     Height="34"
                                     Margin="0,0,10,0"
                                     Text="{Binding ActivityColLetter}"
                                     IsReadOnly="True"
                                     Style="{DynamicResource ReadOnlyTextBox}"/>

                            <TextBox Width="220"
                                     Height="34"
                                     Text="{Binding ActivityColHeader}"
                                     IsReadOnly="True"
                                     Style="{DynamicResource ReadOnlyTextBox}"/>

                        </StackPanel>

                        <!-- STATUS COLUMN -->

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="Status Column (Auto)"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Height="34"
                                 Text="{Binding StatusColLetter}"
                                 IsReadOnly="True"
                                 Style="{DynamicResource ReadOnlyTextBox}"/>

                        <!-- REFERENCE MAP -->

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Text="Reference Map"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <TextBox Grid.Row="5"
                                 Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Height="34"
                                 Text="Ref: Activity in Column C, Trade Code in Column A"
                                 IsReadOnly="True"
                                 Style="{DynamicResource ReadOnlyTextBox}"/>

                    </Grid>

                </Border>

                <!-- ================================================= -->
                <!-- LISTVIEW -->
                <!-- ================================================= -->

                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10"
                        Margin="0,0,0,14">

                    <ListView ItemsSource="{Binding LogItems}"
                              Background="Transparent"
                              BorderThickness="0">

                        <ListView.View>

                            <GridView>

                                <GridViewColumn Header="Row"
                                                Width="60"
                                                DisplayMemberBinding="{Binding Row}"/>

                                <GridViewColumn Header="Activity"
                                                Width="240"
                                                DisplayMemberBinding="{Binding Activity}"/>

                                <GridViewColumn Header="Trade Code"
                                                Width="100"
                                                DisplayMemberBinding="{Binding TradeCode}"/>

                                <GridViewColumn Header="Status"
                                                Width="160"
                                                DisplayMemberBinding="{Binding Status}"/>

                            </GridView>

                        </ListView.View>

                    </ListView>

                </Border>

                <!-- ================================================= -->
                <!-- PROGRESS -->
                <!-- ================================================= -->

                <Grid Grid.Row="2"
                      Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>

                    </Grid.ColumnDefinitions>

                    <!-- BAR -->

                    <Border Grid.Column="0"
                            Height="20"
                            Margin="0,0,10,0"
                            Background="{DynamicResource Brush.Progress.Background}"
                            BorderBrush="{DynamicResource CardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            VerticalAlignment="Center">

                        <Grid ClipToBounds="True">

                            <Border CornerRadius="10"
                                    HorizontalAlignment="Stretch"
                                    RenderTransformOrigin="0,0.5"
                                    Background="{DynamicResource Brush.Accent.ProgressFill}">

                                <Border.RenderTransform>

                                    <ScaleTransform ScaleY="1"
                                        ScaleX="{Binding ProgressPercent,
                                        Converter={StaticResource PercentToScaleConverter}}"/>

                                </Border.RenderTransform>

                            </Border>

                        </Grid>

                    </Border>

                    <!-- PERCENT -->

                    <Border Grid.Column="1"
                            Height="30"
                            Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource ControlStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            VerticalAlignment="Center">

                        <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                   FontWeight="SemiBold"/>

                    </Border>

                </Grid>

                <!-- ================================================= -->
                <!-- BUTTONS -->
                <!-- ================================================= -->

                <Grid Grid.Row="3"
                      Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="34"
                            Content="Run"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding RunCommand}"
                            IsEnabled="{Binding CanRun}"/>

                    <Button Grid.Column="2"
                            Height="34"
                            Content="Stop"
                            Style="{DynamicResource BaseButton}"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding IsBusy}"/>

                    <Button Grid.Column="4"
                            Height="34"
                            Content="Cancel"
                            Style="{DynamicResource GhostButton}"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsBusy}"/>

                </Grid>

                <!-- ================================================= -->
                <!-- STATUS -->
                <!-- ================================================= -->

                <Border Grid.Row="4"
                        Padding="10,6"
                        Background="{DynamicResource Brush.Fill.Status}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12">

                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSubBrush}"
                               TextTrimming="CharacterEllipsis"/>

                </Border>

            </Grid>

        </Grid>

    </Border>

</controls:ModernWindow>