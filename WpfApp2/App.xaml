<Application x:Class="Som3a_WPF_UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Som3a_WPF_UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- Core Theme System (aggregates all Base tokens, Effects, Controls, Shell) -->
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ThemeResources.xaml"/>
                <!-- Default Theme (swapped at runtime by ThemeManager) -->
                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/Dark/DarkTheme.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- Culture Formatting Converters -->
            <conv:CultureNumberConverter x:Key="CultureNumberConverter"/>
            <conv:CultureDateConverter x:Key="CultureDateConverter"/>
            <conv:CultureCurrencyConverter x:Key="CultureCurrencyConverter"/>
            <conv:BoolToFlowDirectionConverter x:Key="BoolToFlowDirectionConverter"/>
            <conv:TextFlowDirectionConverter x:Key="TextFlowDirectionConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
