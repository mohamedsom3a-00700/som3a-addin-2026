<controls:ModernWindow x:Class="Som3a_WPF_UI.Controls.Shell.ShellWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
                       xmlns:shell="clr-namespace:Som3a_WPF_UI.Controls.Shell"
                       xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
                       Title="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.Title]}"
                      Width="1200"
                      Height="800"
                      WindowStartupLocation="CenterScreen"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
    <Border CornerRadius="12"
            Effect="{DynamicResource Shadow.Large}"
            Background="{DynamicResource Brush.Background.Card}">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource SurfaceBrush}"
                    Padding="12,0"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="28" Height="28" Style="{DynamicResource TitleBarButton}"
                                ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Navigation.Home]}"
                                Click="OnHomeClick">
                            <TextBlock Text="▤" Foreground="{DynamicResource TextSubBrush}"
                                       FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{DynamicResource TextMainBrush}" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="LanguageBtn" Width="36" Height="32"
                                Style="{DynamicResource TitleBarButton}"
                                ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Settings.Language]}"
                                Click="OnLanguageToggle">
                            <TextBlock Text="&#x1F310;" FontSize="16" Foreground="{DynamicResource TextSubBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="ThemeBtn" Width="36" Height="32"
                                Style="{DynamicResource TitleBarButton}"
                                ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.Theme.Toggle]}"
                                Click="OnThemeToggle">
                            <TextBlock Text="&#x2600;" FontSize="16" Foreground="{DynamicResource TextSubBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Width="36" Height="32" Style="{DynamicResource TitleBarButton}"
                                ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.Minimize]}" Click="OnMinimize">
                            <Path Data="M 6 0 L 6 1 L 18 1 L 18 0 L 6 0 Z" Fill="{DynamicResource TextSubBrush}" Width="12" Height="8" Stretch="Uniform"/>
                        </Button>
                        <Button Width="36" Height="32" Style="{DynamicResource TitleBarButton}"
                                ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.Maximize]}" Click="OnMaximize">
                            <Path Data="M 0 0 L 12 0 L 12 12 L 0 12 Z" Stroke="{DynamicResource TextSubBrush}" StrokeThickness="1.2" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <Button Width="46" Height="32" Style="{DynamicResource CloseButton}"
                                ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.Close]}" Click="OnClose"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Skip Link -->
            <Button x:Name="SkipLink"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Content="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.SkipToContent]}"
                    AutomationProperties.Name="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.SkipToContent]}"
                    IsTabStop="True"
                    Height="0"
                    Opacity="0"
                    Style="{DynamicResource Style.SkipLink}"
                    Click="OnSkipLinkClick"/>

            <!-- Sidebar -->
            <Grid Grid.Row="2"
                  Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Hamburger Toggle Button -->
                <ToggleButton x:Name="CollapseToggle"
                              Grid.Row="0"
                              Content="☰"
                              IsChecked="{Binding IsCollapsed, ElementName=Sidebar}"
                              Style="{DynamicResource Style.ToggleButton.SidebarCollapse}"
                              ToolTip="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.Sidebar.Toggle]}"
                              AutomationProperties.Name="{Binding Source={x:Static services:TranslationSource.Instance}, Path=[Shell.Sidebar.Toggle]}"/>

                <shell:SidebarControl x:Name="Sidebar"
                                      Grid.Row="1"
                                      Items="{Binding Destinations}"
                                      SelectedItem="{Binding SelectedDestination, Mode=TwoWay}"
                                      NavigateCommand="{Binding NavigateToPageCommand}"/>
            </Grid>

            <!-- Workspace -->
            <Border Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,8,8,8"
                    Background="{DynamicResource Brush.Background.Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <shell:WorkspaceHost x:Name="Workspace"
                                         Grid.Row="0"
                                         WelcomePageType="{Binding WelcomePageType}"/>

                    <!-- Status Bar -->
                    <StatusBar Grid.Row="1"
                               Style="{DynamicResource Style.StatusBar}">
                        <StatusBarItem>
                            <TextBlock x:Name="StatusText"
                                       Text="{Binding StatusMessage}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </Border>

            <!-- Command Palette (overlays everything) -->
            <shell:CommandPalette x:Name="Palette"
                                  Grid.Row="0" Grid.RowSpan="3"
                                  Grid.ColumnSpan="2"/>
        </Grid>
    </Border>
</controls:ModernWindow>
