<UserControl x:Class="Som3a_WPF_UI.Controls.Shell.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:Som3a_WPF_UI.Controls.Shell"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid>
        <ListBox x:Name="SidebarListBox"
                 ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Items}"
                 SelectedItem="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=SelectedItem, Mode=TwoWay}"
                 ItemContainerStyle="{DynamicResource Style.Sidebar.Item}"
                 Style="{DynamicResource Style.Sidebar.ListBox}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 IsTabStop="True"
                 KeyboardNavigation.TabNavigation="Continue"
                 KeyboardNavigation.DirectionalNavigation="Cycle"
                 SelectionChanged="OnSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="shell:NavigationDestination">
                    <Grid MinHeight="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Icon}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Label}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
