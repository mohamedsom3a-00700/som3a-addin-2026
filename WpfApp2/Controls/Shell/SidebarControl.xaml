<UserControl x:Class="Som3a_WPF_UI.Controls.Shell.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:l="clr-namespace:Som3a_WPF_UI.MarkupExtensions"
             xmlns:shell="clr-namespace:Som3a_WPF_UI.Controls.Shell"
      
             xmlns:services="clr-namespace:Som3a_WPF_UI.Services"
      
             xmlns:fluentIcons="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
      
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid MouseEnter="OnGridMouseEnter"
          MouseLeave="OnGridMouseLeave"
          PreviewKeyDown="OnPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Planova Logo at top of sidebar -->
        <Border Grid.Row="0" Padding="12,12,12,8" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="{DynamicResource Logo.ImageSource}" Width="28" Height="28"
                       Stretch="Uniform" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="PLANOVA" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Text.Primary}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="1" x:Name="SidebarListBox"
                  SelectedItem="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=SelectedItem, Mode=TwoWay}"
                  ItemContainerStyle="{DynamicResource Style.Sidebar.Item}"
                   VirtualizingPanel.IsVirtualizing="False"
                  KeyboardNavigation.TabNavigation="Continue"
                  KeyboardNavigation.DirectionalNavigation="Cycle"
                  SelectionChanged="OnSelectionChanged">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <Expander IsExpanded="False"
                                                  Header="{Binding Name}"
                                                  Style="{DynamicResource Style.Sidebar.CategoryExpander}">
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.Style>
                <Style TargetType="ListBox" BasedOn="{StaticResource Style.Sidebar.ListBox}">
                    <Setter Property="IsTabStop" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="IsTabStop" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="shell:NavigationDestination">
                    <Grid MinHeight="36"
                          Opacity="1"
                          ToolTip="">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                        <Setter Property="ToolTip" Value="{l:Loc SidebarControl.PageUnavailable}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <fluentIcons:FluentIcon Grid.Column="0"
                                               Icon="{Binding Icon, Converter={StaticResource FluentIconConverter}}"
                                               FontSize="14"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text.Primary}"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Label}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Branding Footer at bottom of sidebar -->
        <Border Grid.Row="2" Padding="12,8,12,12" Background="Transparent"
                BorderBrush="{DynamicResource Brush.Border.Default}" BorderThickness="0,1,0,0">
            <StackPanel>
                <TextBlock Text="Planova Platform" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Text.Secondary}"/>
                <TextBlock Text="v2026.1" FontSize="10"
                           Foreground="{DynamicResource Brush.Text.Disabled}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
