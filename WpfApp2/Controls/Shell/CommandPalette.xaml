<UserControl x:Class="Som3a_WPF_UI.Controls.Shell.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:Som3a_WPF_UI.Controls.Shell"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Popup x:Name="PalettePopup"
           AllowsTransparency="False"
           Placement="Center"
           StaysOpen="False"
           IsOpen="{Binding IsOpen, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Border Style="{DynamicResource Style.CommandPalette.Overlay}"
                Padding="20">
            <Grid Width="400"
                  Background="{DynamicResource Brush.Background.Primary}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="SearchTextBox"
                         Grid.Row="0"
                         Style="{DynamicResource Style.CommandPalette.Input}"
                         TextChanged="OnSearchTextChanged"
                         KeyDown="OnSearchKeyDown"/>
                <ListBox x:Name="ResultsListBox"
                         Grid.Row="1"
                         Margin="0,8,0,0"
                         MaxHeight="300"
                         Background="{DynamicResource Brush.Background.Primary}"
                         BorderThickness="0"
                         ItemContainerStyle="{DynamicResource Style.CommandPalette.ResultItem}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         MouseDoubleClick="OnResultDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="shell:NavigationDestination">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Icon}"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text.Primary}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Label}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text.Primary}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Popup>
</UserControl>
