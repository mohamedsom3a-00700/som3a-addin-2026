<Window x:Class="Som3a_WPF_UI.Controls.Toast.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ToastIcon" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="ToastText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
    </Window.Resources>

    <Border x:Name="ToastBorder"
            CornerRadius="8"
            Padding="16,12"
            Margin="10"
            Effect="{DynamicResource Shadow.Popup}">

        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="IconText" Style="{StaticResource ToastIcon}"/>
            <TextBlock x:Name="MessageText" Style="{StaticResource ToastText}"/>
        </StackPanel>
    </Border>
</Window>