<controls:ModernWindow x:Class="Som3a_WPF_UI.Controls.Toast.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="ToastIcon" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource HeaderFontSize}"/>
            <Setter Property="FontWeight" Value="{DynamicResource FontWeightBold}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="ToastText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
            <Setter Property="FontSize" Value="{DynamicResource BodyFontSize}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
    </Window.Resources>

    <Border x:Name="ToastBorder"
            Background="{DynamicResource Brush.Background.Root}"
            CornerRadius="{DynamicResource SmallRadius}"
            Padding="{DynamicResource Padding.Large}"
            Margin="{DynamicResource Padding.Small}"
            Effect="{DynamicResource Shadow.Popup}">

        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="IconText"
                       Text="{Binding Icon}"
                       Foreground="{Binding Foreground}"
                       Style="{DynamicResource ToastIcon}"/>
            <TextBlock x:Name="MessageText"
                       Text="{Binding Message}"
                       Style="{DynamicResource ToastText}"/>
        </StackPanel>
    </Border>
</controls:ModernWindow>
