<controls:ModernWindow x:Class="Som3a_WPF_UI.Ui.ProjectAnalysisWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:local="clr-namespace:Som3a_WPF_UI.Converters"
                        xmlns:controls="clr-namespace:Som3a_WPF_UI.Controls"
                        Title="Project Analysis"
                        Height="760"
                        Width="1180"
                        ResizeMode="NoResize"
                        WindowStartupLocation="CenterOwner"
                        WindowStyle="None"
                        AllowsTransparency="True"
                        Background="Transparent"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">

    <controls:ModernWindow.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="/Som3a_WPF_UI;component/Theme/ThemeResources.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </controls:ModernWindow.Resources>

    <!-- ===================================================== -->
    <!-- ROOT CARD -->
    <!-- ===================================================== -->

    <Border x:Name="RootBorder"
            CornerRadius="18"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="1">

        <!-- BACKGROUND -->

        <Border.Background>

            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">

                <GradientStop Color="#FF102A43"
                              Offset="0"/>

                <GradientStop Color="#FF0F3B3B"
                              Offset="1"/>

            </LinearGradientBrush>

        </Border.Background>

        <!-- ================================================= -->
        <!-- ROOT GRID -->
        <!-- ================================================= -->

        <Grid Margin="12">

            <Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <RowDefinition Height="42"/>

                <!-- SETTINGS -->
                <RowDefinition Height="Auto"/>

                <!-- SPACING -->
                <RowDefinition Height="12"/>

                <!-- MAIN -->
                <RowDefinition Height="*"/>

                <!-- SPACING -->
                <RowDefinition Height="12"/>

                <!-- PROGRESS -->
                <RowDefinition Height="Auto"/>

                <!-- SPACING -->
                <RowDefinition Height="12"/>

                <!-- BUTTONS -->
                <RowDefinition Height="36"/>

                <!-- SPACING -->
                <RowDefinition Height="12"/>

                <!-- STATUS -->
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <!-- ================================================= -->
            <!-- TITLE BAR -->
            <!-- ================================================= -->

            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Margin="4,2,4,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="8"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <!-- TITLE -->

                <TextBlock Text="Project Analysis"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- MINIMIZE -->

                <Button Grid.Column="1"
                        Width="34"
                        Height="28"
                        Content="—"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnMin_Click"/>

                <!-- CLOSE -->

                <Button Grid.Column="3"
                        Width="34"
                        Height="28"
                        Content="X"
                        Style="{DynamicResource BaseButton}"
                        Click="BtnClose_Click"/>

            </Grid>

            <!-- ================================================= -->
            <!-- SETTINGS -->
            <!-- ================================================= -->

            <Border Grid.Row="1"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="12"/>

                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="12"/>

                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>

                    </Grid.RowDefinitions>

                    <!-- ACTIVITIES -->

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Activities"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>

                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              ItemsSource="{Binding AvailableSheets}"
                              SelectedItem="{Binding SelectedActivitiesSheet}"
                              Style="{DynamicResource RoundComboBox}"
                              Margin="0,7,0,8"/>

                    <!-- RELATIONSHIPS -->

                    <TextBlock Grid.Row="0"
                               Grid.Column="3"
                               Text="Relationships"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>

                    <ComboBox Grid.Row="0"
                              Grid.Column="4"
                              ItemsSource="{Binding AvailableSheets}"
                              SelectedItem="{Binding SelectedLogicSheet}"
                              Style="{DynamicResource RoundComboBox}"
                              Margin="0,7,0,8"/>

                    <!-- RESOURCES -->

                    <TextBlock Grid.Row="0"
                               Grid.Column="6"
                               Text="Resources"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>

                    <ComboBox Grid.Row="0"
                              Grid.Column="7"
                              ItemsSource="{Binding AvailableSheets}"
                              SelectedItem="{Binding SelectedResourcesSheet}"
                              Style="{DynamicResource RoundComboBox}"
                              Margin="0,7,0,8"/>

                    <!-- FINISH DATE -->

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Finish date"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMainBrush}"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding FinishDateText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,7,0,8"/>

                    <!-- CHECK -->

                    <Button Grid.Row="1"
                            Grid.Column="3"
                            Content="Check Sheets"
                            Style="{DynamicResource BaseButton}"
                            Command="{Binding ValidateCommand}"
                            Margin="0,7,0,8"/>

                    <!-- RUN -->

                    <Button Grid.Row="1"
                            Grid.Column="4"
                            Content="Run Analysis"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding RunCommand}"
                            Margin="0,7,0,8"/>

                    <!-- CLEAR -->

                    <Button Grid.Row="1"
                            Grid.Column="7"
                            Content="Clear Summary"
                            Style="{DynamicResource BaseButton}"
                            Command="{Binding ClearSummaryCommand}"
                            Margin="0,7,0,8"/>

                </Grid>

            </Border>

            <!-- ================================================= -->
            <!-- MAIN -->
            <!-- ================================================= -->

            <Grid Grid.Row="3">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="460"/>

                    <ColumnDefinition Width="12"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <!-- ============================================= -->
                <!-- CHECK RESULTS -->
                <!-- ============================================= -->

                <Border Grid.Column="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10">

                    <Grid>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="10"/>

                            <RowDefinition Height="*"/>

                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Check Sheets Results"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <ListView Grid.Row="2"
                                  ItemsSource="{Binding SheetChecks}"
                                  ItemContainerStyle="{DynamicResource AccentListViewItem}">

                            <ListView.View>

                                <GridView>

                                    <GridViewColumn Header="Sheet/Section"
                                                    Width="150"
                                                    DisplayMemberBinding="{Binding Section}"/>

                                    <GridViewColumn Header="Required Column"
                                                    Width="190"
                                                    DisplayMemberBinding="{Binding RequiredColumn}"/>

                                    <GridViewColumn Header="Found"
                                                    Width="70"
                                                    DisplayMemberBinding="{Binding HeaderFound}"/>

                                    <GridViewColumn Header="Location"
                                                    Width="110"
                                                    DisplayMemberBinding="{Binding Location}"/>

                                </GridView>

                            </ListView.View>

                        </ListView>

                    </Grid>

                </Border>

                <!-- ============================================= -->
                <!-- SUMMARY -->
                <!-- ============================================= -->

                <Border Grid.Column="2"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10">

                    <Grid>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="10"/>

                            <RowDefinition Height="*"/>

                            <RowDefinition Height="12"/>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="10"/>

                            <RowDefinition Height="*"/>

                        </Grid.RowDefinitions>

                        <!-- SUMMARY TITLE -->

                        <TextBlock Grid.Row="0"
                                   Text="Summary"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <!-- SUMMARY LIST -->

                        <ListView Grid.Row="2"
                                  ItemsSource="{Binding SummaryRows}"
                                  ItemContainerStyle="{DynamicResource AccentListViewItem}">

                            <ListView.View>

                                <GridView>

                                    <GridViewColumn Header="Type"
                                                    Width="130"
                                                    DisplayMemberBinding="{Binding Type}"/>

                                    <GridViewColumn Header="Count"
                                                    Width="70"
                                                    DisplayMemberBinding="{Binding Count}"/>

                                    <GridViewColumn Header="Sheet"
                                                    Width="140"
                                                    DisplayMemberBinding="{Binding SheetName}"/>

                                    <GridViewColumn Header="Details"
                                                    Width="430"
                                                    DisplayMemberBinding="{Binding Details}"/>

                                </GridView>

                            </ListView.View>

                        </ListView>

                        <!-- LOG TITLE -->

                        <TextBlock Grid.Row="4"
                                   Text="Log"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMainBrush}"/>

                        <!-- LOG LIST -->

                        <ListView Grid.Row="6"
                                  ItemsSource="{Binding LogRows}"
                                  ItemContainerStyle="{DynamicResource AccentListViewItem}">

                            <ListView.View>

                                <GridView>

                                    <GridViewColumn Header="Time"
                                                    Width="90"
                                                    DisplayMemberBinding="{Binding Time}"/>

                                    <GridViewColumn Header="Level"
                                                    Width="80"
                                                    DisplayMemberBinding="{Binding Level}"/>

                                    <GridViewColumn Header="Message"
                                                    Width="600"
                                                    DisplayMemberBinding="{Binding Message}"/>

                                </GridView>

                            </ListView.View>

                        </ListView>

                    </Grid>

                </Border>

            </Grid>

            <!-- ================================================= -->
            <!-- PROGRESS -->
            <!-- ================================================= -->

            <Grid Grid.Row="5">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="90"/>

                </Grid.ColumnDefinitions>

                <!-- PROGRESS BAR -->

                <Border Grid.Column="0"
                        Height="24"
                        CornerRadius="10"
                        Background="#22000000"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">

                    <Grid ClipToBounds="True">

                        <Border CornerRadius="10"
                                HorizontalAlignment="Stretch"
                                RenderTransformOrigin="0,0.5">

                            <Border.Background>

                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">

                                    <GradientStop Color="#FF1ABC9C"
                                                  Offset="0"/>

                                    <GradientStop Color="#FF2ECC71"
                                                  Offset="1"/>

                                </LinearGradientBrush>

                            </Border.Background>

                            <Border.Effect>

                                <DropShadowEffect Color="#6600FF9C"
                                                  BlurRadius="8"
                                                  ShadowDepth="0"
                                                  Opacity="0.8"/>

                            </Border.Effect>

                            <Border.RenderTransform>

                                <ScaleTransform ScaleY="1"
                                                ScaleX="{Binding ProgressPct, Converter={StaticResource PercentToScaleConverter}}"/>

                            </Border.RenderTransform>

                        </Border>

                    </Grid>

                </Border>

                <!-- PERCENT -->

                <Border Grid.Column="1"
                        Height="30"
                        CornerRadius="10"
                        Background="{DynamicResource ControlBgBrush}"
                        BorderBrush="{DynamicResource ControlStrokeBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Center">

                    <TextBlock Text="{Binding ProgressPct, StringFormat={}{0:0}%}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <!-- ================================================= -->
            <!-- BUTTONS -->
            <!-- ================================================= -->

            <Grid Grid.Row="7">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="10"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <!-- RUN -->

                <Button Grid.Column="0"
                        Content="Run"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding RunCommand}"/>

                <!-- CLOSE -->

                <Button Grid.Column="2"
                        Content="Close"
                        Style="{DynamicResource BaseButton}"
                        Command="{Binding CloseCommand}"/>

            </Grid>

            <!-- ================================================= -->
            <!-- STATUS -->
            <!-- ================================================= -->

            <Border Grid.Row="9"
                    Background="#1FFFFFFF"
                    CornerRadius="12"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    Padding="10,6">

                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSubBrush}"
                           TextTrimming="CharacterEllipsis"/>

            </Border>

        </Grid>

    </Border>

</controls:ModernWindow>